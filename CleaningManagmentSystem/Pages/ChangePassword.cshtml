@page
@model CleaningManagmentSystem.Pages.ChangePasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Change Default Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        *, body { font-family: 'Inter', sans-serif; }
        body {
            background: linear-gradient(135deg, #0d1b2a 0%, #1a3a5c 50%, #0d6efd22 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 1rem;
        }

        .card-wrap {
            width: 100%;
            max-width: 440px;
            background: rgba(255,255,255,0.97);
            border-radius: 1.5rem;
            box-shadow: 0 25px 60px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.1);
            overflow: hidden;
        }

        .card-header-banner {
            background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);
            padding: 2rem;
            text-align: center;
            color: #fff;
        }

        .lock-icon {
            width: 64px;
            height: 64px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            margin-bottom: 1rem;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .card-body-inner { padding: 2rem; }

        .info-box {
            background: #fff3cd;
            border: 1px solid #ffc107;
            border-radius: .75rem;
            padding: .85rem 1rem;
            font-size: .855rem;
            color: #6b4400;
            margin-bottom: 1.5rem;
            display: flex;
            gap: .6rem;
            align-items: flex-start;
        }

        .form-label-modern {
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #6c757d;
            margin-bottom: .4rem;
        }

        .input-wrap { position: relative; }

        .form-control-modern {
            border-radius: .65rem;
            border: 1.5px solid #e9ecef;
            padding: .75rem 2.8rem .75rem 1rem;
            font-size: .9rem;
            transition: all .2s;
            background: #f8f9fa;
            width: 100%;
        }

        .form-control-modern:focus {
            border-color: #fd7e14;
            background: #fff;
            box-shadow: 0 0 0 4px rgba(253, 126, 20, 0.12);
            outline: none;
        }

        .toggle-pw {
            position: absolute;
            right: .8rem;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            cursor: pointer;
            color: #adb5bd;
            font-size: 1.1rem;
            padding: 0;
            line-height: 1;
        }

        .toggle-pw:hover { color: #6c757d; }

        /* Password strength bar */
        .strength-bar-wrap {
            height: 4px;
            border-radius: 4px;
            background: #e9ecef;
            margin-top: .4rem;
            overflow: hidden;
        }
        .strength-bar {
            height: 100%;
            border-radius: 4px;
            transition: width .3s, background .3s;
            width: 0%;
        }

        .strength-label {
            font-size: .72rem;
            font-weight: 600;
            margin-top: .25rem;
        }

        .requirements li {
            font-size: .78rem;
            color: #6c757d;
            margin-bottom: .15rem;
            display: flex;
            align-items: center;
            gap: .4rem;
            transition: color .2s;
        }

        .requirements li.ok { color: #198754; }
        .requirements li.ok .req-icon::before { content: '\F26B'; }
        .requirements li:not(.ok) .req-icon::before { content: '\F287'; }
        .req-icon { font-family: 'bootstrap-icons'; font-style: normal; }

        .btn-change {
            background: linear-gradient(135deg, #fd7e14 0%, #e8590c 100%);
            border: none;
            color: #fff;
            border-radius: .65rem;
            padding: .8rem;
            font-weight: 700;
            font-size: .95rem;
            width: 100%;
            cursor: pointer;
            transition: all .2s;
            box-shadow: 0 4px 15px rgba(253,126,20,.35);
        }

        .btn-change:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(253,126,20,.45);
        }

        .btn-change:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
        }
    </style>
</head>
<body>
    <div class="card-wrap">
        <!-- Banner -->
        <div class="card-header-banner">
            <div class="lock-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <h5 class="fw-bold mb-1">Password Change Required</h5>
            <p class="mb-0" style="font-size:.88rem;opacity:.9;">You are using a default password. For your security, you must set a new password before continuing.</p>
        </div>

        <!-- Form -->
        <div class="card-body-inner">
            <div class="info-box">
                <i class="bi bi-info-circle-fill" style="flex-shrink:0;margin-top:.1rem;color:#e8590c;"></i>
                <span>This is a <strong>one-time action</strong>. Once changed, you will be taken to your dashboard automatically.</span>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger py-2 mb-3 rounded-3" style="font-size:.855rem;">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
                </div>
            }

            <form method="post" id="changePwForm">
                @Html.AntiForgeryToken()

                <!-- New Password -->
                <div class="mb-3">
                    <label class="form-label-modern">New Password</label>
                    <div class="input-wrap">
                        <input type="password" name="NewPassword" id="newPw"
                               class="form-control-modern" required
                               placeholder="Enter new password"
                               oninput="checkStrength(this.value)" autocomplete="new-password" />
                        <button type="button" class="toggle-pw" onclick="togglePw('newPw', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <!-- Strength bar -->
                    <div class="strength-bar-wrap mt-2">
                        <div class="strength-bar" id="strengthBar"></div>
                    </div>
                    <div class="strength-label" id="strengthLabel" style="color:#adb5bd;">—</div>
                </div>

                <!-- Requirements -->
                <ul class="requirements list-unstyled mb-3" id="reqList">
                    <li id="req-len"><span class="req-icon"></span>At least 8 characters</li>
                    <li id="req-upper"><span class="req-icon"></span>One uppercase letter</li>
                    <li id="req-num"><span class="req-icon"></span>One number</li>
                    <li id="req-special"><span class="req-icon"></span>One special character (!@@#$%)</li>
                </ul>

                <!-- Confirm Password -->
                <div class="mb-4">
                    <label class="form-label-modern">Confirm Password</label>
                    <div class="input-wrap">
                        <input type="password" name="ConfirmPassword" id="confirmPw"
                               class="form-control-modern" required
                               placeholder="Repeat new password"
                               oninput="checkMatch()" autocomplete="new-password" />
                        <button type="button" class="toggle-pw" onclick="togglePw('confirmPw', this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="strength-label" id="matchLabel" style="color:#adb5bd; margin-top:.25rem;"></div>
                </div>

                <button type="submit" class="btn-change" id="submitBtn" disabled>
                    <i class="bi bi-shield-check me-2"></i>Set New Password & Continue
                </button>
            </form>
        </div>
    </div>

    <script>
        const BAR = document.getElementById('strengthBar');
        const LBL = document.getElementById('strengthLabel');
        const BTN = document.getElementById('submitBtn');

        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            const isText = inp.type === 'text';
            inp.type = isText ? 'password' : 'text';
            btn.querySelector('i').className = isText ? 'bi bi-eye' : 'bi bi-eye-slash';
        }

        function checkStrength(val) {
            const reqs = {
                'req-len':     val.length >= 8,
                'req-upper':   /[A-Z]/.test(val),
                'req-num':     /[0-9]/.test(val),
                'req-special': /[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(val),
            };
            let score = Object.values(reqs).filter(Boolean).length;

            Object.entries(reqs).forEach(([id, ok]) => {
                document.getElementById(id).classList.toggle('ok', ok);
            });

            const states = [
                { width:'0%',   color:'#dee2e6', label:'—',        labelColor:'#adb5bd' },
                { width:'25%',  color:'#dc3545', label:'Weak',      labelColor:'#dc3545' },
                { width:'50%',  color:'#fd7e14', label:'Fair',      labelColor:'#fd7e14' },
                { width:'75%',  color:'#0d6efd', label:'Good',      labelColor:'#0d6efd' },
                { width:'100%', color:'#198754', label:'Strong ✓',  labelColor:'#198754' },
            ];
            const s = states[score];
            BAR.style.width  = s.width;
            BAR.style.background = s.color;
            LBL.textContent  = s.label;
            LBL.style.color  = s.labelColor;

            checkMatch();
        }

        function checkMatch() {
            const pw  = document.getElementById('newPw').value;
            const cpw = document.getElementById('confirmPw').value;
            const ml  = document.getElementById('matchLabel');
            const allReqs = pw.length >= 8 &&
                            /[A-Z]/.test(pw) &&
                            /[0-9]/.test(pw) &&
                            /[!@@#$%^&*()_+\-=\[\]{};':"\\|,.<>\/?]/.test(pw);

            if (!cpw) {
                ml.textContent = '';
                BTN.disabled = true;
                return;
            }

            if (pw === cpw && allReqs) {
                ml.textContent = '✓ Passwords match';
                ml.style.color = '#198754';
                BTN.disabled = false;
            } else if (pw !== cpw) {
                ml.textContent = '✗ Passwords do not match';
                ml.style.color = '#dc3545';
                BTN.disabled = true;
            } else {
                ml.textContent = 'Please meet all password requirements';
                ml.style.color = '#fd7e14';
                BTN.disabled = true;
            }
        }
    </script>
</body>
</html>
