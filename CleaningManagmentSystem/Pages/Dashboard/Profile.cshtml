@page
@model CleaningManagmentSystem.Pages.Dashboard.ProfileModel
@using CleaningManagmentSystem.Pages.Dashboard
@{
    Layout = null;
    var sessionRole = HttpContext.Session.GetString("UserRole") ?? "";
    var sessionName = HttpContext.Session.GetString("UserName") ?? "User";

    // Sidebar partial path per role
    string sidebarPartial = sessionRole.ToLower() switch {
        "hr"              => "~/Pages/Dashboard/HR/_Sidebar.cshtml",
        "superadmin"      => "~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml",
        "manager"         => "~/Pages/Dashboard/Manager/_Sidebar.cshtml",
        "staff"           => "~/Pages/Dashboard/Staff/sidebar.cshtml",
        "driver"          => "~/Pages/Dashboard/Driver/_Sidebar.cshtml",
        "dispatchofficer" => "~/Pages/Dashboard/DispatchOfficer/_Sidebar.cshtml",
        "weredamahberat"  => "~/Pages/Dashboard/WeredaMahberat/_Sidebar.cshtml",
        "wereda_mahberat" => "~/Pages/Dashboard/WeredaMahberat/_Sidebar.cshtml",
        "cleaner"         => "~/Pages/Dashboard/Cleaner/_Sidebar.cshtml",
        "user"            => "~/Pages/Dashboard/User/_Sidebar.cshtml",
        _                 => "~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml"
    };

    string backUrl = sessionRole.ToLower() switch {
        "hr"              => "/Dashboard/HR",
        "superadmin"      => "/Dashboard/SuperAdmin",
        "manager"         => "/Dashboard/Manager",
        "staff"           => "/Dashboard/Staff",
        "driver"          => "/Dashboard/Driver",
        "dispatchofficer" => "/Dashboard/DispatchOfficer",
        "weredamahberat"  => "/Dashboard/WeredaMahberat",
        "wereda_mahberat" => "/Dashboard/WeredaMahberat",
        "cleaner"         => "/Dashboard/Cleaner",
        "user"            => "/Dashboard/User",
        _                 => "/"
    };

    var emp      = Model.Employee;
    bool hasPhoto = emp != null && !string.IsNullOrEmpty(emp.PhotoUrl);

    string modeLabel = Model.Mode switch {
        ProfileModel.ViewMode.HrManage    => "HR — Managing Profile",
        ProfileModel.ViewMode.ManagerView => "Manager — Viewing Profile",
        _                                 => "My Profile"
    };
    string heroGrad = Model.Mode switch {
        ProfileModel.ViewMode.HrManage    => "linear-gradient(135deg,#198754,#146c43)",
        ProfileModel.ViewMode.ManagerView => "linear-gradient(135deg,#fd7e14,#e8590c)",
        _                                 => "linear-gradient(135deg,#1a56db,#0d6efd)"
    };
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1"/>
    <title>@modeLabel — Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/dashboard.css"/>
    <style>
        .profile-hero  { border-radius:0 0 24px 24px; }
        .avatar-circle { width:90px;height:90px;border-radius:50%;border:3px solid rgba(255,255,255,.35);object-fit:cover; }
        .avatar-ini    { width:90px;height:90px;border-radius:50%;border:3px solid rgba(255,255,255,.35);display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:2rem;font-weight:700;color:#fff;flex-shrink:0; }
        .info-row      { display:flex;padding:.42rem 0;border-bottom:1px solid #f0f2f5;font-size:.875rem; }
        .info-row:last-child { border-bottom:none; }
        .info-lbl      { min-width:135px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;padding-top:.18rem;flex-shrink:0; }
        .info-val      { color:#212529;font-weight:500; }
        .sec-head      { font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#0d6efd;border-bottom:2px solid #e7f0ff;padding-bottom:.32rem;margin:1.1rem 0 .75rem; }
        .sec-head:first-child { margin-top:0; }
        .role-chip     { font-size:.72rem;padding:2px 11px;border-radius:20px;background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.3); }
        .mode-chip     { font-size:.68rem;padding:1px 9px;border-radius:20px;background:rgba(0,0,0,.15);color:rgba(255,255,255,.75); }
    </style>
</head>
<body>

<!-- ── Sidebar backdrop (mobile) ── -->
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

<!-- ── Top navbar (desktop) ── -->
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-none d-lg-flex">
    <div class="container-fluid">
        <a class="navbar-brand" href="@backUrl"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
        <div class="nav-user">
            @{ var _profPhoto = HttpContext.Session.GetString("UserPhoto") ?? ""; }
            @{ var _profInit  = sessionName.Length > 0 ? sessionName[0].ToString().ToUpper() : "U"; }
            <div class="dropdown">
                <button class="profile-btn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="p-wrap">
                        @if (!string.IsNullOrEmpty(_profPhoto))
                        {
                            <img src="@_profPhoto" class="p-avatar" alt="@sessionName"
                                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                            <span class="p-initial" style="display:none">@_profInit</span>
                        }
                        else { <span class="p-initial">@_profInit</span> }
                        <span class="p-dot"></span>
                    </span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end profile-dropdown">
                    <li>
                        <div class="pd-header">
                            <div class="pd-big-wrap">
                                @if (!string.IsNullOrEmpty(_profPhoto))
                                {
                                    <img src="@_profPhoto" class="pd-big-avatar" alt="@sessionName"
                                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
                                    <span class="pd-big-initial" style="display:none">@_profInit</span>
                                }
                                else { <span class="pd-big-initial">@_profInit</span> }
                                <span class="pd-online-dot"></span>
                            </div>
                            <div class="pd-info">
                                <div class="pd-name">@sessionName</div>
                                <div class="pd-role"><span class="pd-role-badge">@sessionRole</span></div>
                                <div class="pd-status">Online</div>
                            </div>
                        </div>
                    </li>
                    <li><div class="pd-section-label">Account</div></li>
                    <li><a class="dropdown-item" href="/Dashboard/Profile">
                        <span class="pd-icon" style="background:#eff6ff;color:#2563eb"><i class="bi bi-person-circle"></i></span>
                        <span class="pd-item-label">My Profile <span class="badge bg-primary ms-1" style="font-size:.6rem">Current</span></span>
                    </a></li>
                    <li><a class="dropdown-item" href="@backUrl">
                        <span class="pd-icon" style="background:#f0fdf4;color:#16a34a"><i class="bi bi-speedometer2"></i></span>
                        <span class="pd-item-label">Dashboard</span>
                        <i class="bi bi-chevron-right pd-arrow"></i>
                    </a></li>
                    <li><hr class="dropdown-divider"/></li>
                    <li><a class="dropdown-item pd-danger" href="/Login?logout=1">
                        <span class="pd-icon"><i class="bi bi-box-arrow-right"></i></span>
                        <span class="pd-item-label">Sign Out</span>
                    </a></li>
                    <li><div style="padding:6px 16px 10px;font-size:.65rem;color:#94a3b8;text-align:center">Yeka Cleaning v1.0</div></li>
                </ul>
            </div>
        </div>
    </div>
</nav>

<!-- ── Top navbar (mobile) ── -->
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
    <div class="container-fluid">
        <button class="navbar-toggler" onclick="toggleSidebar()"><span class="navbar-toggler-icon"></span></button>
        <a class="navbar-brand" href="@backUrl"><i class="bi bi-droplet-fill"></i> Yeka</a>
        <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-left"></i></a>
    </div>
</nav>

<!-- ── Mobile sidebar ── -->
<nav id="sidebarMenu" class="sidebar d-lg-none">
    @await Html.PartialAsync(sidebarPartial)
</nav>

<!-- ── Desktop sidebar ── -->
<nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform:none;padding-top:56px">
    @await Html.PartialAsync(sidebarPartial)
</nav>

<!-- ── Main content ── -->
<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5" style="margin-top:56px">

    <!-- Hero banner -->
    <div class="profile-hero text-white px-4 pt-3 pb-4 mb-4" style="background:@heroGrad;margin:-1.5rem -1.5rem 1.5rem -1.5rem">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-1">
            <a href="@backUrl" class="text-white-50 text-decoration-none small">
                <i class="bi bi-arrow-left me-1"></i>Dashboard
            </a>
            <span class="mode-chip">@modeLabel</span>
        </div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            @if (hasPhoto) {
                <img src="@emp!.PhotoUrl" alt="@emp.FullName" class="avatar-circle">
            } else if (emp != null) {
                <div class="avatar-ini">@emp.Initials</div>
            } else {
                <div class="avatar-ini"><i class="bi bi-person-circle" style="font-size:2.2rem"></i></div>
            }
            <div>
                <h4 class="fw-bold mb-1 text-white">@Model.UserName</h4>
                <span class="role-chip">@Model.UserRole.ToUpper()</span>
                @if (emp != null) {
                    <div class="mt-1 opacity-80 small text-white-50">
                        @if (!string.IsNullOrEmpty(emp.Position)) { <span>@emp.Position</span> }
                        @if (!string.IsNullOrEmpty(emp.Department)) { <span>&nbsp;·&nbsp; @emp.Department</span> }
                        @if (!string.IsNullOrEmpty(emp.EmployeeCode)) { <span>&nbsp;·&nbsp; <code class="text-white-50">@emp.EmployeeCode</code></span> }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3 shadow-sm">
            <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-3 shadow-sm">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- ════ LEFT COLUMN ════ -->
        <div class="col-lg-4">

            <!-- Account info -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="sec-head"><i class="bi bi-person-circle me-1"></i>Account</div>
                    <div class="info-row"><span class="info-lbl">User ID</span><span class="info-val text-muted">#@Model.UserId</span></div>
                    <div class="info-row"><span class="info-lbl">Name</span><span class="info-val">@Model.UserName</span></div>
                    <div class="info-row"><span class="info-lbl">Email</span><span class="info-val" style="word-break:break-all">@Model.UserEmail</span></div>
                    <div class="info-row"><span class="info-lbl">Role</span><span class="info-val"><span class="badge bg-primary rounded-pill">@Model.UserRole</span></span></div>
                    <div class="info-row"><span class="info-lbl">Phone</span><span class="info-val">@(string.IsNullOrEmpty(Model.UserPhone)?"—":Model.UserPhone)</span></div>
                    <div class="info-row"><span class="info-lbl">Since</span><span class="info-val text-muted">@Model.UserCreatedAt.ToString("MMM dd, yyyy")</span></div>
                </div>
            </div>

            @* Edit form — own profile OR HR managing *@
            @if (Model.IsOwnProfile || Model.IsHrManage) {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="sec-head"><i class="bi bi-pencil me-1"></i>Edit Account</div>
                    <form method="post" asp-page-handler="UpdateProfile">
                        <input type="hidden" name="targetUserId" value="@Model.UserId">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Full Name</label>
                            <input type="text" name="NewName" value="@Model.NewName" class="form-control form-control-sm rounded-3" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Phone</label>
                            <input type="text" name="NewPhone" value="@Model.NewPhone" class="form-control form-control-sm rounded-3">
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted">Email (read-only)</label>
                            <input type="email" value="@Model.UserEmail" class="form-control form-control-sm rounded-3 bg-light" readonly>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 mt-2 w-100">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                    </form>
                </div>
            </div>
            }

            @* Change password — own profile only *@
            @if (Model.IsOwnProfile) {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="sec-head"><i class="bi bi-key me-1"></i>Change Password</div>
                    <form method="post" asp-page-handler="ChangePassword">
                        <div class="mb-2">
                            <label class="form-label small fw-bold">Current Password</label>
                            <input type="password" name="CurrPwd" class="form-control form-control-sm rounded-3" required>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold">New Password</label>
                            <input type="password" name="NewPwd" id="newPwd" class="form-control form-control-sm rounded-3" required minlength="6">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Confirm</label>
                            <input type="password" name="ConfirmPwd" id="confirmPwd" class="form-control form-control-sm rounded-3" required>
                        </div>
                        <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-4 w-100">
                            <i class="bi bi-lock me-1"></i>Change Password
                        </button>
                    </form>
                </div>
            </div>
            }

            @* HR: link employee record *@
            @if (Model.IsHrManage) {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="sec-head"><i class="bi bi-link-45deg me-1"></i>Link Employee Record</div>
                    <p class="text-muted small mb-3">
                        @if (emp != null) {
                            <span>Linked: <strong>@emp.FullName</strong> (@emp.EmployeeCode)</span>
                        } else {
                            <span class="text-warning">Not linked yet.</span>
                        }
                    </p>
                    <form method="post" asp-page-handler="LinkEmployee">
                        <input type="hidden" name="targetUserId" value="@Model.UserId">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Select Employee</label>
                            <select name="employeeId" class="form-select form-select-sm rounded-3">
                                <option value="0">— Remove Link —</option>
                                @foreach (var e2 in Model.AllEmployees) {
                                    <option value="@e2.Id" selected="@(emp?.Id == e2.Id ? true : (bool?)null)">
                                        @e2.FullName — @e2.Department (@e2.EmployeeCode)@(e2.IsLinked ? " ✓" : "")
                                    </option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success btn-sm rounded-pill px-4 w-100">
                            <i class="bi bi-link me-1"></i>Save Link
                        </button>
                    </form>
                </div>
            </div>
            }
        </div>

        <!-- ════ RIGHT COLUMN ════ -->
        <div class="col-lg-8">

        @if (emp != null) {
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <div class="sec-head mb-0"><i class="bi bi-person-badge me-1"></i>Employee Record</div>
                        @{ var stCls = emp.EmploymentStatus == "Active" ? "bg-success" : "bg-danger"; }
                        <span class="badge @stCls rounded-pill">@emp.EmploymentStatus</span>
                    </div>

                    <div class="row g-4 mt-1">
                        <!-- Personal -->
                        <div class="col-md-6">
                            <div class="sec-head">Personal</div>
                            <div class="info-row"><span class="info-lbl">Full Name</span><span class="info-val">@emp.FullName</span></div>
                            <div class="info-row"><span class="info-lbl">Gender</span><span class="info-val">@(string.IsNullOrEmpty(emp.Gender)?"—":emp.Gender)</span></div>
                            <div class="info-row"><span class="info-lbl">Date of Birth</span><span class="info-val">@(emp.DateOfBirth?.ToString("MMM dd, yyyy") ?? "—")</span></div>
                            <div class="info-row"><span class="info-lbl">Nationality</span><span class="info-val">@(string.IsNullOrEmpty(emp.Nationality)?"—":emp.Nationality)</span></div>
                            <div class="info-row"><span class="info-lbl">Marital Status</span><span class="info-val">@(string.IsNullOrEmpty(emp.MaritalStatus)?"—":emp.MaritalStatus)</span></div>
                            <div class="info-row"><span class="info-lbl">National ID</span><span class="info-val">@(string.IsNullOrEmpty(emp.NationalId)?"—":emp.NationalId)</span></div>
                            <div class="info-row"><span class="info-lbl">Blood Type</span><span class="info-val">@(string.IsNullOrEmpty(emp.BloodType)?"—":emp.BloodType)</span></div>
                        </div>

                        <!-- Employment -->
                        <div class="col-md-6">
                            <div class="sec-head">Employment</div>
                            <div class="info-row"><span class="info-lbl">Code</span><span class="info-val text-primary fw-bold">@emp.EmployeeCode</span></div>
                            <div class="info-row"><span class="info-lbl">Department</span><span class="info-val">@(string.IsNullOrEmpty(emp.Department)?"—":emp.Department)</span></div>
                            <div class="info-row"><span class="info-lbl">Position</span><span class="info-val">@(string.IsNullOrEmpty(emp.Position)?"—":emp.Position)</span></div>
                            <div class="info-row"><span class="info-lbl">Job Grade</span><span class="info-val">@(string.IsNullOrEmpty(emp.JobGrade)?"—":emp.JobGrade)</span></div>
                            <div class="info-row"><span class="info-lbl">Type</span><span class="info-val"><span class="badge bg-light text-dark border">@emp.EmploymentType</span></span></div>
                            <div class="info-row"><span class="info-lbl">Hire Date</span><span class="info-val">@emp.HireDate.ToString("MMM dd, yyyy")</span></div>
                            <div class="info-row"><span class="info-lbl">Service</span><span class="info-val">@emp.YearsService yr@(emp.YearsService!=1?"s":"")</span></div>
                            <div class="info-row"><span class="info-lbl">Work Location</span><span class="info-val">@(string.IsNullOrEmpty(emp.WorkLocation)?"—":emp.WorkLocation)</span></div>
                        </div>
                    </div>

                    @* Salary/bank — HR only *@
                    @if (Model.ShowSensitive) {
                    <div class="sec-head mt-3"><i class="bi bi-cash-stack me-1"></i>Financial <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem">HR Only</span></div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="info-row"><span class="info-lbl">Base Salary</span><span class="info-val fw-bold text-success">@((emp.Salary ?? 0).ToString("N2")) ETB</span></div>
                            <div class="info-row"><span class="info-lbl">Bank Name</span><span class="info-val">@(string.IsNullOrEmpty(emp.BankName)?"—":emp.BankName)</span></div>
                            <div class="info-row"><span class="info-lbl">Bank Account</span><span class="info-val">@(string.IsNullOrEmpty(emp.BankAccount)?"—":emp.BankAccount)</span></div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-row"><span class="info-lbl">Tax ID (TIN)</span><span class="info-val">@(string.IsNullOrEmpty(emp.TaxId)?"—":emp.TaxId)</span></div>
                            <div class="info-row"><span class="info-lbl">Pension ID</span><span class="info-val">@(string.IsNullOrEmpty(emp.PensionId)?"—":emp.PensionId)</span></div>
                        </div>
                    </div>
                    }

                    @* Education *@
                    @if (!string.IsNullOrEmpty(emp.HighestEducation) || !string.IsNullOrEmpty(emp.Skills)) {
                    <div class="sec-head mt-3"><i class="bi bi-mortarboard me-1"></i>Education & Skills</div>
                    <div class="row g-2">
                        <div class="col-md-6">
                            <div class="info-row"><span class="info-lbl">Education</span><span class="info-val">@(string.IsNullOrEmpty(emp.HighestEducation)?"—":emp.HighestEducation)</span></div>
                            <div class="info-row"><span class="info-lbl">Field</span><span class="info-val">@(string.IsNullOrEmpty(emp.FieldOfStudy)?"—":emp.FieldOfStudy)</span></div>
                            <div class="info-row"><span class="info-lbl">Institution</span><span class="info-val">@(string.IsNullOrEmpty(emp.Institution)?"—":emp.Institution)</span></div>
                            <div class="info-row"><span class="info-lbl">Grad. Year</span><span class="info-val">@(emp.GraduationYear.HasValue?emp.GraduationYear.ToString():"—")</span></div>
                        </div>
                        @if (!string.IsNullOrEmpty(emp.Skills)) {
                        <div class="col-md-6">
                            <span class="info-lbl d-block mb-1">Skills</span>
                            <p class="small text-muted mb-0" style="white-space:pre-wrap">@emp.Skills</p>
                        </div>
                        }
                    </div>
                    }

                    @if (Model.IsHrManage && !string.IsNullOrEmpty(emp.Notes)) {
                    <div class="sec-head mt-3"><i class="bi bi-journal-text me-1"></i>Notes</div>
                    <p class="small text-muted mb-0" style="white-space:pre-wrap">@emp.Notes</p>
                    }

                    @if (Model.IsHrManage) {
                    <div class="mt-4 pt-3 border-top d-flex gap-2 flex-wrap">
                        <a href="/Dashboard/HR/EmployeeProfile?id=@emp.Id" class="btn btn-sm btn-outline-success rounded-pill">
                            <i class="bi bi-person-lines-fill me-1"></i>Full HR Profile
                        </a>
                        <a href="/Dashboard/HR/Employees" class="btn btn-sm btn-outline-secondary rounded-pill">
                            <i class="bi bi-people me-1"></i>All Employees
                        </a>
                    </div>
                    }
                </div>
            </div>

        } else {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body py-5 text-center">
                    <i class="bi bi-person-badge fs-1 text-muted opacity-25 d-block mb-3"></i>
                    @if (Model.IsHrManage) {
                        <h5 class="fw-bold mb-2">No Employee Record Linked</h5>
                        <p class="text-muted small mb-0">Use the "Link Employee Record" panel on the left.</p>
                    } else if (Model.IsManagerView) {
                        <h5 class="fw-bold mb-2">No Employee Record</h5>
                        <p class="text-muted small mb-0">This user has no linked employee record.</p>
                    } else {
                        <h5 class="fw-bold mb-2">No Employee Record Linked</h5>
                        <p class="text-muted small mb-0">Your account is not yet linked to an employee record. Contact HR.</p>
                    }
                </div>
            </div>
        }

        </div><!-- /right col -->
    </div><!-- /row -->
</main>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleSidebar() {
    document.getElementById('sidebarMenu').classList.toggle('show');
    document.getElementById('sidebarBackdrop').classList.toggle('show');
}
document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(l) {
    l.addEventListener('click', function() { if (window.innerWidth < 992) toggleSidebar(); });
});
document.querySelector('form[asp-page-handler="ChangePassword"]')?.addEventListener('submit', function(e) {
    if (document.getElementById('newPwd')?.value !== document.getElementById('confirmPwd')?.value) {
        e.preventDefault(); alert('New passwords do not match.');
    }
});
</script>
</body>
</html>
