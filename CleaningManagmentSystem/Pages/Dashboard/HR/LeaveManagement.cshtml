@page
@model CleaningManagmentSystem.Pages.Dashboard.HR.LeaveManagementModel
@{
    Layout = "_HRLayout";
    ViewData["Title"] = "Leave Management";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-calendar-check text-warning me-2"></i>Leave Management</h4>
        <p class="text-muted mb-0">Process leave requests, track balances, and manage approvals.</p>
    </div>
    <button class="btn btn-warning text-dark" data-bs-toggle="modal" data-bs-target="#addLeaveModal">
        <i class="bi bi-plus-circle me-1"></i> New Leave Request
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-warning">@Model.Leaves.Count(l => l.ApprovalStatus == "Pending")</div>
            <div class="text-muted small">Pending Requests</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-success">@Model.Leaves.Count(l => l.ApprovalStatus == "Approved")</div>
            <div class="text-muted small">Approved</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-danger">@Model.Leaves.Count(l => l.ApprovalStatus == "Rejected")</div>
            <div class="text-muted small">Rejected</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center p-3">
            <div class="fs-2 fw-bold text-primary">@Model.Leaves.Where(l => l.ApprovalStatus == "Approved").Sum(l => l.NumberOfDays)</div>
            <div class="text-muted small">Total Days Taken</div>
        </div>
    </div>
</div>

<!-- Leave Table -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between">
        <h6 class="fw-bold mb-0">All Leave Requests</h6>
        <form method="get" class="d-flex gap-2">
            <select name="status" class="form-select form-select-sm" style="width:150px" onchange="this.form.submit()">
                <option value="">All Status</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            </select>
            <select name="leaveType" class="form-select form-select-sm" style="width:150px" onchange="this.form.submit()">
                <option value="">All Types</option>
                <option value="Annual" selected="@(Model.TypeFilter == "Annual")">Annual</option>
                <option value="Sick" selected="@(Model.TypeFilter == "Sick")">Sick</option>
                <option value="Maternity" selected="@(Model.TypeFilter == "Maternity")">Maternity</option>
                <option value="Emergency" selected="@(Model.TypeFilter == "Emergency")">Emergency</option>
                <option value="Unpaid" selected="@(Model.TypeFilter == "Unpaid")">Unpaid</option>
            </select>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr><th>#</th><th>Employee</th><th>Leave Type</th><th>Start Date</th><th>End Date</th><th>Days</th><th>Reason</th><th>Status</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @if (!Model.Leaves.Any())
                    {
                        <tr><td colspan="9" class="text-center py-4 text-muted">No leave requests found.</td></tr>
                    }
                    @foreach (var (lv, i) in Model.Leaves.Select((l, i) => (l, i + 1)))
                    {
                        <tr>
                            <td class="text-muted small">@i</td>
                            <td>
                                <div class="fw-semibold">@lv.EmployeeName</div>
                                <div class="text-muted small">@lv.Department</div>
                            </td>
                            <td><span class="badge bg-info-subtle text-info border border-info">@lv.LeaveType</span></td>
                            <td class="small">@lv.StartDate.ToString("MMM dd, yyyy")</td>
                            <td class="small">@lv.EndDate.ToString("MMM dd, yyyy")</td>
                            <td><span class="fw-bold">@lv.NumberOfDays</span> days</td>
                            <td class="small text-muted" style="max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@lv.Reason</td>
                            <td>
                                @{
                                    var sc = lv.ApprovalStatus switch {
                                        "Approved" => "bg-success-subtle text-success border border-success",
                                        "Rejected" => "bg-danger-subtle text-danger border border-danger",
                                        _ => "bg-warning-subtle text-warning border border-warning"
                                    };
                                }
                                <span class="badge @sc">@lv.ApprovalStatus</span>
                            </td>
                            <td>
                                @if (lv.ApprovalStatus == "Pending")
                                {
                                    <form method="post" asp-page-handler="Approve" style="display:inline">
                                        <input type="hidden" name="id" value="@lv.Id" />
                                        <button type="submit" class="btn btn-sm btn-success me-1" title="Approve">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form method="post" asp-page-handler="Reject" style="display:inline">
                                        <input type="hidden" name="id" value="@lv.Id" />
                                        <button type="submit" class="btn btn-sm btn-danger" title="Reject">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">@lv.ApproverName</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Leave Modal -->
<div class="modal fade" id="addLeaveModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>New Leave Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Add">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Employee *</label>
                        <select name="EmployeeId" class="form-select" required>
                            <option value="">Select Employee</option>
                            @foreach (var e in Model.AllEmployees)
                            {
                                <option value="@e.Id">@e.FirstName @e.LastName — @e.Department</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Leave Type *</label>
                        <select name="LeaveType" class="form-select" required>
                            <option value="Annual">Annual Leave</option>
                            <option value="Sick">Sick Leave</option>
                            <option value="Maternity">Maternity Leave</option>
                            <option value="Paternity">Paternity Leave</option>
                            <option value="Emergency">Emergency Leave</option>
                            <option value="Unpaid">Unpaid Leave</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6"><label class="form-label">Start Date *</label><input type="date" name="StartDate" id="leaveStart" class="form-control" required onchange="calcDays()"></div>
                        <div class="col-6"><label class="form-label">End Date *</label><input type="date" name="EndDate" id="leaveEnd" class="form-control" required onchange="calcDays()"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Number of Days</label>
                        <input type="number" name="NumberOfDays" id="leaveDays" class="form-control" readonly>
                    </div>
                    <div class="mb-3"><label class="form-label">Reason / Notes</label><textarea name="Reason" class="form-control" rows="3" placeholder="Reason for leave request..."></textarea></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-send me-1"></i>Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function calcDays() {
    var s = document.getElementById('leaveStart').value;
    var e = document.getElementById('leaveEnd').value;
    if (s && e) {
        var diff = (new Date(e) - new Date(s)) / (1000 * 60 * 60 * 24) + 1;
        document.getElementById('leaveDays').value = diff > 0 ? diff : 0;
    }
}
</script>
}
