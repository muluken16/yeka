@page
@model CleaningManagmentSystem.Pages.Dashboard.HR.EmployeesModel
@{
    Layout = "_HRLayout";
    ViewData["Title"] = "Employee Management";
}
@section Styles {
<style>
.emp-avatar{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;color:#fff;flex-shrink:0}
.emp-card{transition:box-shadow .2s,transform .2s}
.emp-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.10)!important;transform:translateY(-2px)}
.badge-grade{font-size:.7rem;padding:3px 8px;border-radius:20px;background:#e8f4fd;color:#0d6efd;font-weight:600}
.tab-pill .nav-link{border:none;border-radius:30px;padding:.45rem 1.1rem;font-weight:600;color:#6c757d;font-size:.875rem}
.tab-pill .nav-link.active{background:#0d6efd;color:#fff}
.field-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6c757d;margin-bottom:.3rem}
.input-modern{border-radius:.6rem;border:1.5px solid #dee2e6;padding:.55rem .9rem;font-size:.9rem;transition:.2s}
.input-modern:focus{border-color:#86b7fe;box-shadow:0 0 0 3px rgba(13,110,253,.15)}
.section-divider{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#adb5bd;border-bottom:1px solid #f0f0f0;padding-bottom:.4rem;margin-bottom:.8rem}
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-people-fill text-primary me-2"></i>Employee Management</h4>
        <p class="text-muted mb-0 small">Register, view and manage all employees.</p>
    </div>
    <button class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addEmpModal">
        <i class="bi bi-person-plus me-1"></i> Add Employee
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3">
            <div class="fs-2 fw-bold text-primary">@Model.Employees.Count</div>
            <div class="text-muted small">Total</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3">
            <div class="fs-2 fw-bold text-success">@Model.Employees.Count(e => e.employment_status == "Active")</div>
            <div class="text-muted small">Active</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3">
            <div class="fs-2 fw-bold text-warning">@Model.Employees.Select(e => e.department).Where(d => !string.IsNullOrEmpty(d)).Distinct().Count()</div>
            <div class="text-muted small">Departments</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3">
            <div class="fs-2 fw-bold text-danger">@Model.Employees.Count(e => e.employment_status == "Inactive")</div>
            <div class="text-muted small">Inactive</div>
        </div>
    </div>
</div>

<!-- Search / Filter -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="field-label">Search</label>
                <input type="text" name="search" value="@Model.Search" class="form-control input-modern" placeholder="Name, email, department...">
            </div>
            <div class="col-md-3">
                <label class="field-label">Department</label>
                <select name="dept" class="form-select input-modern">
                    <option value="">All Departments</option>
                    @foreach (var d in Model.Employees.Select(e => e.department).Where(d => !string.IsNullOrEmpty(d)).Distinct().OrderBy(d => d))
                    {
                        <option value="@d" selected="@(Model.DeptFilter == d ? true : (bool?)null)">@d</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="field-label">Status</label>
                <select name="status" class="form-select input-modern">
                    <option value="">All</option>
                    <option value="Active"   selected="@(Model.StatusFilter == "Active"   ? true : (bool?)null)">Active</option>
                    <option value="Inactive" selected="@(Model.StatusFilter == "Inactive" ? true : (bool?)null)">Inactive</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary rounded-pill px-3"><i class="bi bi-search me-1"></i>Filter</button>
                <a href="/Dashboard/HR/Employees" class="btn btn-outline-secondary rounded-pill px-3">Reset</a>
            </div>
        </form>
    </div>
</div>

<!-- Employee Table -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.875rem">
                <thead style="background:#f8f9fa;">
                    <tr>
                        <th class="ps-4 py-3 text-muted fw-semibold" style="width:46px">#</th>
                        <th class="py-3 text-muted fw-semibold">Employee</th>
                        <th class="py-3 text-muted fw-semibold">Code / Grade</th>
                        <th class="py-3 text-muted fw-semibold">Contact</th>
                        <th class="py-3 text-muted fw-semibold">Department / Position</th>
                        <th class="py-3 text-muted fw-semibold">Type</th>
                        <th class="py-3 text-muted fw-semibold">Status</th>
                        <th class="py-3 text-muted fw-semibold text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Employees.Any())
                {
                    <tr><td colspan="8" class="text-center py-5 text-muted">
                        <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>No employees found.
                    </td></tr>
                }
                @foreach (var (e, i) in Model.Employees.Select((e, i) => (e, i + 1)))
                {
                    var colors = new[]{"#4361ee","#3a86ff","#06d6a0","#f72585","#7209b7","#fb8500"};
                    var bg = colors[(i - 1) % colors.Length];
                    <tr>
                        <td class="ps-4 text-muted">@i</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(e.photo_url)) {
                                    <img src="@e.photo_url" alt="@e.FullName" class="emp-avatar" style="object-fit:cover;">
                                } else {
                                    <div class="emp-avatar" style="background:@bg">@e.Initials</div>
                                }
                                <div>
                                    <div class="fw-semibold">@e.FullName</div>
                                    <div class="text-muted" style="font-size:.78rem">@e.email_address</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="fw-semibold text-primary" style="font-size:.82rem">@(string.IsNullOrEmpty(e.employee_code) ? "—" : e.employee_code)</div>
                            <span class="badge-grade">@(string.IsNullOrEmpty(e.job_grade) ? "No Grade" : e.job_grade)</span>
                        </td>
                        <td>
                            <div><i class="bi bi-telephone-fill text-muted me-1" style="font-size:.78rem"></i>@(string.IsNullOrEmpty(e.phone_number) ? "—" : e.phone_number)</div>
                            <div class="text-muted" style="font-size:.78rem"><i class="bi bi-geo-alt-fill me-1"></i>@(string.IsNullOrEmpty(e.city) ? "—" : e.city)</div>
                        </td>
                        <td>
                            <div class="fw-semibold">@e.department</div>
                            <div class="text-muted" style="font-size:.78rem">@e.position</div>
                        </td>
                        <td><span class="badge bg-light text-dark border" style="font-size:.75rem">@e.employment_type</span></td>
                        <td>
                            @if (e.employment_status == "Active")
                            { <span class="badge bg-success-subtle text-success border border-success rounded-pill">Active</span> }
                            else
                            { <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill">Inactive</span> }
                        </td>
                        <td class="text-end pe-3">
                            <a href="/Dashboard/HR/EmployeeProfile?id=@e.Id" class="btn btn-sm btn-info text-white me-1" title="View HR Profile"><i class="bi bi-person-lines-fill"></i></a>
                            @if (e.user_id.HasValue && e.user_id > 0) {
                                <a href="/Dashboard/Profile?userId=@e.user_id" class="btn btn-sm btn-outline-info me-1" title="View User Account Profile"><i class="bi bi-person-circle"></i></a>
                            }
                            <button class="btn btn-sm btn-outline-primary me-1" title="Edit"
                                    data-bs-toggle="modal" data-bs-target="#editEmpModal"
                                    data-id="@e.Id"
                                    data-code="@e.employee_code"
                                    data-fn="@e.first_name" data-ln="@e.last_name" data-mn="@e.middle_name"
                                    data-gender="@e.gender"
                                    data-dob="@(e.date_of_birth?.ToString("yyyy-MM-dd") ?? "")"
                                    data-nationality="@e.nationality" data-religion="@e.religion"
                                    data-marital="@e.marital_status"
                                    data-phone="@e.phone_number" data-email="@e.email_address"
                                    data-region="@e.region" data-city="@e.city"
                                    data-subcity="@e.subcity" data-address="@e.address"
                                    data-ec="@e.emergency_contact"
                                    data-ecp="@e.emergency_contact_phone"
                                    data-ecr="@e.emergency_contact_relation"
                                    data-dept="@e.department" data-pos="@e.position"
                                    data-role="@e.role" data-grade="@e.job_grade"
                                    data-emptype="@e.employment_type"
                                    data-hiredate="@e.hire_date.ToString("yyyy-MM-dd")"
                                    data-ced="@(e.contract_end_date?.ToString("yyyy-MM-dd") ?? "")"
                                    data-status="@e.employment_status"
                                    data-edu="@e.highest_education"
                                    data-fos="@e.field_of_study"
                                    data-inst="@e.institution"
                                    data-gradyr="@e.graduation_year"
                                    data-skills="@e.skills"
                                    data-salary="@e.salary"
                                    data-bank="@e.bank_account"
                                    data-bankname="@e.bank_name"
                                    data-taxid="@e.tax_id"
                                    data-pension="@e.pension_id"
                                    data-nationalid="@e.national_id"
                                    data-bloodtype="@e.blood_type"
                                    data-disability="@e.disability_status"
                                    data-workloc="@e.work_location"
                                    data-ec2="@e.second_emergency_contact"
                                    data-ecp2="@e.second_emergency_phone"
                                    data-ecr2="@e.second_emergency_relation"
                                    data-photourl="@e.photo_url"
                                    data-notes="@e.notes">
                                <i class="bi bi-pencil-fill"></i>
                            </button>
                            <form method="post" asp-page-handler="ToggleStatus" class="d-inline">
                                <input type="hidden" name="id" value="@e.Id"/>
                                <input type="hidden" name="status" value="@e.employment_status"/>
                                <button type="submit" class="btn btn-sm @(e.employment_status=="Active"?"btn-outline-warning":"btn-outline-success")" title="@(e.employment_status=="Active"?"Deactivate":"Activate")">
                                    <i class="bi @(e.employment_status=="Active"?"bi-pause-circle":"bi-play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ════ ADD EMPLOYEE MODAL ════ -->
<div class="modal fade" id="addEmpModal" tabindex="-1">
<div class="modal-dialog modal-xl modal-dialog-scrollable">
<div class="modal-content rounded-4 border-0 shadow">
    <div class="modal-header rounded-top-4" style="background:linear-gradient(135deg,#0d6efd,#0b5ed7)">
        <h5 class="modal-title text-white fw-bold"><i class="bi bi-person-plus me-2"></i>Register New Employee</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
    </div>
    <form method="post" asp-page-handler="Add" enctype="multipart/form-data">
    <div class="modal-body p-4">
        <ul class="nav tab-pill gap-1 mb-4" id="addTabs" role="tablist">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#at-personal" type="button"><i class="bi bi-person me-1"></i>Personal</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#at-employ" type="button"><i class="bi bi-briefcase me-1"></i>Employment</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#at-edu" type="button"><i class="bi bi-mortarboard me-1"></i>Education</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#at-fin" type="button"><i class="bi bi-cash-coin me-1"></i>Financial</button></li>
        </ul>
        <div class="tab-content">

            <!-- ── PERSONAL TAB ── -->
            <div class="tab-pane fade show active" id="at-personal">

                <!-- Photo Upload -->
                <div class="section-divider">Profile Photo</div>
                <div class="row g-3 mb-3 align-items-center">
                    <div class="col-auto">
                        <div id="aPhotoPreviewWrap" class="rounded-circle border border-2 border-primary d-flex align-items-center justify-content-center overflow-hidden bg-light"
                             style="width:90px;height:90px;font-size:2rem;color:#adb5bd;">
                            <i class="bi bi-person-circle"></i>
                        </div>
                    </div>
                    <div class="col">
                        <label class="field-label">Upload Photo (JPG / PNG, max 2 MB)</label>
                        <input type="file" name="PhotoFile" id="aPhotoFile" accept="image/*" class="form-control input-modern">
                    </div>
                </div>

                <div class="section-divider">Basic Info</div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4"><label class="field-label">First Name *</label><input type="text" name="FirstName" class="form-control input-modern" required></div>
                    <div class="col-md-4"><label class="field-label">Last Name *</label><input type="text" name="LastName" class="form-control input-modern" required></div>
                    <div class="col-md-4"><label class="field-label">Middle Name</label><input type="text" name="MiddleName" class="form-control input-modern"></div>
                    <div class="col-md-3"><label class="field-label">Gender</label>
                        <select name="Gender" class="form-select input-modern"><option value="">—</option><option>Male</option><option>Female</option></select></div>
                    <div class="col-md-3"><label class="field-label">Date of Birth</label><input type="date" name="DateOfBirth" class="form-control input-modern"></div>
                    <div class="col-md-3"><label class="field-label">Nationality</label><input type="text" name="Nationality" class="form-control input-modern" value="Ethiopian"></div>
                    <div class="col-md-3"><label class="field-label">Marital Status</label>
                        <select name="MaritalStatus" class="form-select input-modern"><option value="">—</option><option>Single</option><option>Married</option><option>Divorced</option><option>Widowed</option></select></div>
                    <div class="col-md-3"><label class="field-label">Religion</label><input type="text" name="Religion" class="form-control input-modern"></div>
                    <div class="col-md-3"><label class="field-label">Blood Type</label>
                        <select name="BloodType" class="form-select input-modern"><option value="">—</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>AB+</option><option>AB-</option><option>O+</option><option>O-</option></select></div>
                    <div class="col-md-3"><label class="field-label">National ID</label><input type="text" name="NationalId" class="form-control input-modern" placeholder="Kebele / National ID"></div>
                    <div class="col-md-3"><label class="field-label">Disability Status</label>
                        <select name="DisabilityStatus" class="form-select input-modern"><option value="None">None</option><option>Visual</option><option>Hearing</option><option>Physical</option><option>Cognitive</option><option>Other</option></select></div>
                    <div class="col-md-6"><label class="field-label">Phone Number</label><input type="text" name="PhoneNumber" class="form-control input-modern"></div>
                    <div class="col-md-6"><label class="field-label">Email Address</label><input type="email" name="EmailAddress" class="form-control input-modern"></div>
                </div>

                <div class="section-divider">Address</div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4"><label class="field-label">Region</label><input type="text" name="Region" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">City</label><input type="text" name="City" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Subcity</label><input type="text" name="Subcity" class="form-control input-modern"></div>
                    <div class="col-12"><label class="field-label">Detailed Address</label><input type="text" name="Address" class="form-control input-modern"></div>
                </div>

                <div class="section-divider">Emergency Contact #1</div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4"><label class="field-label">Contact Name</label><input type="text" name="EmergencyContact" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Phone</label><input type="text" name="EmergencyContactPhone" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Relation</label><input type="text" name="EmergencyContactRelation" class="form-control input-modern" placeholder="e.g. Spouse, Parent"></div>
                </div>

                <div class="section-divider">Emergency Contact #2</div>
                <div class="row g-3">
                    <div class="col-md-4"><label class="field-label">Contact Name</label><input type="text" name="SecondEmergencyContact" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Phone</label><input type="text" name="SecondEmergencyPhone" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Relation</label><input type="text" name="SecondEmergencyRelation" class="form-control input-modern" placeholder="e.g. Sibling, Friend"></div>
                </div>
            </div>

            <!-- ── EMPLOYMENT TAB ── -->
            <div class="tab-pane fade" id="at-employ">
                <div class="row g-3">
                    <div class="col-md-4"><label class="field-label">Department *</label>
                        <input type="text" name="Department" class="form-control input-modern" list="deptList" required>
                        <datalist id="deptList"><option>Operations</option><option>Finance</option><option>HR</option><option>Logistics</option><option>IT</option><option>Administration</option></datalist></div>
                    <div class="col-md-4"><label class="field-label">Position / Title *</label><input type="text" name="Position" class="form-control input-modern" required></div>
                    <div class="col-md-4"><label class="field-label">System Role</label>
                        <select name="Role" class="form-select input-modern"><option value="">Standard</option><option>HR</option><option>Manager</option><option>Finance</option><option>Logistics</option></select></div>
                    <div class="col-md-4"><label class="field-label">Job Grade</label><input type="text" name="JobGrade" class="form-control input-modern" placeholder="e.g. G5, Senior"></div>
                    <div class="col-md-4"><label class="field-label">Employment Type</label>
                        <select name="EmploymentType" class="form-select input-modern"><option>Full-Time</option><option>Part-Time</option><option>Contract</option><option>Intern</option></select></div>
                    <div class="col-md-4"><label class="field-label">Hire Date *</label>
                        <input type="date" name="HireDate" class="form-control input-modern" required value="@DateTime.Today.ToString("yyyy-MM-dd")"></div>
                    <div class="col-md-4"><label class="field-label">Contract End Date</label><input type="date" name="ContractEndDate" class="form-control input-modern"></div>
                    <div class="col-md-8"><label class="field-label">Work Location / Branch</label><input type="text" name="WorkLocation" class="form-control input-modern" placeholder="e.g. Head Office, Bole Branch"></div>
                    <div class="col-12"><label class="field-label">Notes / Remarks</label><textarea name="Notes" class="form-control input-modern" rows="2" placeholder="Any additional notes about this employee..."></textarea></div>
                </div>
            </div>

            <!-- ── EDUCATION TAB ── -->
            <div class="tab-pane fade" id="at-edu">
                <div class="row g-3">
                    <div class="col-md-6"><label class="field-label">Highest Education</label>
                        <select name="HighestEducation" class="form-select input-modern"><option value="">—</option><option>High School</option><option>Diploma</option><option>Bachelor's Degree</option><option>Master's Degree</option><option>PhD</option></select></div>
                    <div class="col-md-6"><label class="field-label">Field of Study</label><input type="text" name="FieldOfStudy" class="form-control input-modern"></div>
                    <div class="col-md-8"><label class="field-label">Institution / University</label><input type="text" name="Institution" class="form-control input-modern"></div>
                    <div class="col-md-4"><label class="field-label">Graduation Year</label><input type="number" name="GraduationYear" class="form-control input-modern" min="1950" max="@DateTime.Now.Year"></div>
                    <div class="col-12"><label class="field-label">Skills / Certifications</label><textarea name="Skills" class="form-control input-modern" rows="3" placeholder="List key skills, certificates, or languages..."></textarea></div>
                </div>

                <!-- Education Documents -->
                <div class="section-divider mt-4">Education Documents</div>
                <p class="text-muted small mb-3">Attach degree, diploma, certificate or any supporting documents (PDF, Word, JPG, PNG — max 5 MB each).</p>
                <div id="aEduFilesContainer">
                    <div class="edu-file-row d-flex gap-2 align-items-center mb-2">
                        <input type="text"   name="EduFileLabels" class="form-control input-modern" placeholder="Label (e.g. Degree Certificate)" style="max-width:220px">
                        <input type="file"   name="EduFiles"      class="form-control input-modern" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png">
                        <button type="button" class="btn btn-outline-danger btn-sm rounded-pill edu-remove-btn" style="display:none" title="Remove"><i class="bi bi-x-lg"></i></button>
                    </div>
                </div>
                <button type="button" id="aAddEduFile" class="btn btn-outline-primary btn-sm rounded-pill mt-1">
                    <i class="bi bi-plus-circle me-1"></i>Add Another File
                </button>
            </div>

            <!-- ── FINANCIAL TAB ── -->
            <div class="tab-pane fade" id="at-fin">
                <div class="row g-3">
                    <div class="col-md-6"><label class="field-label">Basic Salary (ETB)</label><input type="number" name="Salary" class="form-control input-modern" step="0.01" min="0" value="0"></div>
                    <div class="col-md-6"><label class="field-label">Bank Name</label><input type="text" name="BankName" class="form-control input-modern" placeholder="e.g. CBE, Awash, Dashen"></div>
                    <div class="col-md-6"><label class="field-label">Bank Account Number</label><input type="text" name="BankAccount" class="form-control input-modern"></div>
                    <div class="col-md-6"><label class="field-label">Tax ID (TIN)</label><input type="text" name="TaxId" class="form-control input-modern"></div>
                    <div class="col-md-6"><label class="field-label">Pension ID</label><input type="text" name="PensionId" class="form-control input-modern"></div>
