@page
@model CleaningManagmentSystem.Pages.Dashboard.HR.IndexModel
@{
    Layout = "_HRLayout";
    ViewData["Title"] = "HR Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h3 class="fw-bold mb-1"><i class="bi bi-person-hearts text-warning me-2"></i>Human Resources Dashboard</h3>
        <p class="text-muted mb-0">Live overview of workforce, attendance, payroll and performance.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Dashboard/HR/Employees" class="btn btn-primary btn-sm rounded-pill px-3">
            <i class="bi bi-person-plus me-1"></i>New Employee
        </a>
        <a href="/Dashboard/HR/Attendance" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="bi bi-clock-history me-1"></i>Record Attendance
        </a>
    </div>
</div>

<!-- KPI Row 1 -->
<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-people-fill"></i>
            </div>
            <div class="fs-2 fw-bold">@Model.TotalEmployees</div>
            <div class="text-muted small fw-semibold">Total Employees</div>
            <div class="small mt-1"><span class="text-success fw-semibold">@Model.ActiveEmployees Active</span></div>
            <a href="/Dashboard/HR/Employees" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-warning-subtle text-warning rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-calendar-event"></i>
            </div>
            <div class="fs-2 fw-bold text-warning">@Model.PendingLeaves</div>
            <div class="text-muted small fw-semibold">Pending Leaves</div>
            <div class="small mt-1 text-muted">Awaiting approval</div>
            <a href="/Dashboard/HR/LeaveManagement?status=Pending" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-person-check-fill"></i>
            </div>
            <div class="fs-2 fw-bold text-success">@Model.PresentToday</div>
            <div class="text-muted small fw-semibold">Present Today</div>
            <div class="small mt-1 text-danger fw-semibold">@Model.AbsentToday Absent</div>
            <a href="/Dashboard/HR/Attendance" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="fs-4 fw-bold text-success">@Model.TotalNetPayroll.ToString("N0")</div>
            <div class="text-muted small fw-semibold">Net Payroll (This Month)</div>
            <div class="small mt-1 text-muted">ETB</div>
            <a href="/Dashboard/HR/PayrollManagement" class="stretched-link"></a>
        </div>
    </div>
</div>

<!-- KPI Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-warning-subtle text-warning rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-star-fill"></i>
            </div>
            <div class="fs-2 fw-bold text-warning">@Model.HighPerformers</div>
            <div class="text-muted small fw-semibold">High Performers (4★+)</div>
            <a href="/Dashboard/HR/PerformanceReview" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100 kpi-card text-center p-3">
            <div class="d-inline-flex align-items-center justify-content-center bg-info-subtle text-info rounded-circle mx-auto mb-2" style="width:52px;height:52px;font-size:1.5rem">
                <i class="bi bi-arrow-up-circle-fill"></i>
            </div>
            <div class="fs-2 fw-bold text-info">@Model.PromoRecommended</div>
            <div class="text-muted small fw-semibold">Promo Recommended</div>
            <a href="/Dashboard/HR/PerformanceReview" class="stretched-link"></a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm rounded-4 h-100 p-3 d-flex flex-row align-items-center gap-3" style="background:linear-gradient(135deg,#0d6efd15,#0dcaf015)">
            <div class="flex-shrink-0">
                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center" style="width:60px;height:60px">
                    <i class="bi bi-person-workspace text-white fs-4"></i>
                </div>
            </div>
            <div>
                <div class="fw-bold fs-6 mb-1">Quick Actions</div>
                <div class="d-flex flex-wrap gap-2">
                    <a href="/Dashboard/HR/Employees" class="btn btn-sm btn-outline-primary rounded-pill"><i class="bi bi-person-badge me-1"></i>Employees</a>
                    <a href="/Dashboard/HR/Attendance" class="btn btn-sm btn-outline-success rounded-pill"><i class="bi bi-clock me-1"></i>Attendance</a>
                    <a href="/Dashboard/HR/LeaveManagement" class="btn btn-sm btn-outline-warning rounded-pill"><i class="bi bi-calendar-check me-1"></i>Leaves</a>
                    <a href="/Dashboard/HR/PayrollManagement" class="btn btn-sm btn-outline-success rounded-pill"><i class="bi bi-cash me-1"></i>Payroll</a>
                    <a href="/Dashboard/HR/PerformanceReview" class="btn btn-sm btn-outline-info rounded-pill"><i class="bi bi-star me-1"></i>Reviews</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Employees + Pending Leaves -->
<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between pt-3 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Recently Added Employees</h6>
                <a href="/Dashboard/HR/Employees" class="btn btn-sm btn-outline-primary rounded-pill">View All</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr><th>Employee</th><th>Department</th><th>Hire Date</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @if (!Model.RecentEmployees.Any())
                            {
                                <tr><td colspan="4" class="text-center text-muted py-4">No employees yet. <a href="/Dashboard/HR/Employees">Add one now.</a></td></tr>
                            }
                            @foreach (var e in Model.RecentEmployees)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold flex-shrink-0" style="width:34px;height:34px;font-size:.75rem">
                                                @(((string)e.first_name)[0])@(((string)e.last_name)[0])
                                            </div>
                                            <div>
                                                <div class="fw-semibold small">@e.first_name @e.last_name</div>
                                                <div class="text-muted" style="font-size:.75rem">@e.position</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="small">@e.department</td>
                                    <td class="small text-muted">@(((DateTime)e.hire_date).ToString("MMM dd, yyyy"))</td>
                                    <td>
                                        @if ((string)e.employment_status == "Active")
                                        { <span class="badge bg-success-subtle text-success border border-success">Active</span> }
                                        else
                                        { <span class="badge bg-danger-subtle text-danger border border-danger">Inactive</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between pt-3 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-hourglass-split me-2 text-warning"></i>Pending Leave Requests</h6>
                <a href="/Dashboard/HR/LeaveManagement?status=Pending" class="btn btn-sm btn-outline-warning rounded-pill">Manage</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.PendingLeaveList.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-check2-all text-success fs-2"></i>
                        <div class="mt-2 small fw-semibold">All leave requests have been processed!</div>
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var lv in Model.PendingLeaveList)
                        {
                            <li class="list-group-item d-flex align-items-center justify-content-between px-4 py-3">
                                <div>
                                    <div class="fw-semibold small">@lv.employee_name</div>
                                    <div class="text-muted" style="font-size:.75rem">
                                        <span class="badge bg-info-subtle text-info border me-1">@lv.leave_type</span>
                                        @(((DateTime)lv.start_date).ToString("MMM dd")) – @(((DateTime)lv.end_date).ToString("MMM dd"))
                                        • @lv.number_of_days days
                                    </div>
                                </div>
                                <div class="d-flex gap-1">
                                    <form method="post" action="/Dashboard/HR/LeaveManagement?handler=Approve">
                                        <input type="hidden" name="id" value="@lv.id" />
                                        <button class="btn btn-sm btn-success" title="Approve"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                    <form method="post" action="/Dashboard/HR/LeaveManagement?handler=Reject">
                                        <input type="hidden" name="id" value="@lv.id" />
                                        <button class="btn btn-sm btn-danger" title="Reject"><i class="bi bi-x-lg"></i></button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<style>
.kpi-card { transition: transform .2s, box-shadow .2s; cursor: pointer; position: relative; }
.kpi-card:hover { transform: translateY(-4px); box-shadow: 0 10px 24px rgba(0,0,0,.08) !important; }
</style>
