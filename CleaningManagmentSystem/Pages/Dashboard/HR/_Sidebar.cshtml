@{
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path, bool exact = false)
    {
        if (exact) return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}
<button class="sidebar-toggle-btn d-none d-md-flex" id="sidebarToggleBtn" onclick="toggleSidebarCollapse()" title="Expand / Collapse">
    <i class="bi bi-chevron-left" id="sidebarToggleIcon"></i>
</button>
<div class="sidebar-scroll pt-3" style="height:100%">
    <div class="sidebar-logo-area pb-3 mb-3 border-bottom d-flex align-items-center gap-2 px-3" style="min-height:54px">
        <i class="bi bi-person-hearts text-warning fs-5 flex-shrink-0"></i>
        <div class="sidebar-brand-text">
            <div class="text-white fw-bold" style="font-size:.95rem;line-height:1.2">Yeka Cleaning</div>
            <div class="text-white-50" style="font-size:.68rem">Human Resources</div>
        </div>
    </div>
    <ul class="nav flex-column">
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR",true)?"active":"")" href="/Dashboard/HR" title="Dashboard"><i class="bi bi-speedometer2 flex-shrink-0"></i><span class="nav-label ms-2">Dashboard</span></a></li>
        
        <li class="nav-item px-3 py-2 mt-2">
            <small class="text-uppercase text-white-50 fw-bold nav-label">Employee Management</small>
        </li>
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR/Employees")?"active":"")" href="/Dashboard/HR/Employees" title="Employees"><i class="bi bi-person-badge flex-shrink-0"></i><span class="nav-label ms-2">Employees</span></a></li>
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR/Attendance")?"active":"")" href="/Dashboard/HR/Attendance" title="Attendance"><i class="bi bi-clock-history flex-shrink-0"></i><span class="nav-label ms-2">Attendance</span></a></li>
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR/LeaveManagement")?"active":"")" href="/Dashboard/HR/LeaveManagement" title="Leave Management"><i class="bi bi-calendar-check flex-shrink-0"></i><span class="nav-label ms-2">Leave Management</span></a></li>
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR/PayrollManagement")?"active":"")" href="/Dashboard/HR/PayrollManagement" title="Payroll"><i class="bi bi-cash-stack flex-shrink-0"></i><span class="nav-label ms-2">Payroll</span></a></li>
        <li class="nav-item"><a class="nav-link @(IsActive("/Dashboard/HR/PerformanceReview")?"active":"")" href="/Dashboard/HR/PerformanceReview" title="Performance Reviews"><i class="bi bi-star-fill flex-shrink-0"></i><span class="nav-label ms-2">Performance Reviews</span></a></li>
        
        <li class="nav-item mt-3 border-top pt-2"><a class="nav-link @(IsActive("/Dashboard/Profile")?"active":"")" href="/Dashboard/Profile" title="My Profile"><i class="bi bi-person-circle flex-shrink-0"></i><span class="nav-label ms-2">My Profile</span></a></li>
        <li class="nav-item"><a class="nav-link text-warning fw-semibold" href="/Login?logout=1" title="Logout"><i class="bi bi-box-arrow-left flex-shrink-0"></i><span class="nav-label ms-2">Logout</span></a></li>
    </ul>
</div>
<script>
(function(){
    var collapsed = localStorage.getItem('sidebarCollapsed')==='1';
    if(collapsed) _applyCollapse(true);
    function _applyCollapse(c){
        var b=document.body, ic=document.getElementById('sidebarToggleIcon');
        c ? b.classList.add('sidebar-collapsed') : b.classList.remove('sidebar-collapsed');
        if(ic){ ic.className = c ? 'bi bi-chevron-right' : 'bi bi-chevron-left'; }
    }
    window.toggleSidebarCollapse=function(){
        var c=!document.body.classList.contains('sidebar-collapsed');
        _applyCollapse(c); localStorage.setItem('sidebarCollapsed',c?'1':'0');
    };
})();
</script>
