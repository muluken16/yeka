@page
@model CleaningManagmentSystem.Pages.Dashboard.SuperAdmin.UsersModel
@using CleaningManagmentSystem.Controllers
@{
    var sessionUser = HttpContext.Session.GetString("UserName");
    if (sessionUser == null) { Response.Redirect("/Login"); return; }

    string Badge(string r) => (r ?? "").ToLower() switch {
        "superadmin"        => "danger",
        "manager"           => "primary",
        "driver"            => "success",
        "outsource"         => "warning text-dark",
        "privatecompanyrep" => "info text-dark",
        "staff"             => "secondary",
        "wereda_mahberat"   => "warning text-dark",
        "dispatchofficer"   => "primary",
        var x when string.IsNullOrWhiteSpace(x) => "dark",
        _                   => "secondary"
    };
    string Label(string r) => (r ?? "").ToLower() switch {
        "superadmin"        => "Super Admin",
        "manager"           => "Manager 📱",
        "driver"            => "Driver 📱",
        "outsource"         => "Outsource 📱",
        "privatecompanyrep" => "Private Rep 📱",
        "staff"             => "Staff",
        "wereda_mahberat"   => "Wereda Mahberat",
        "dispatchofficer"   => "Dispatch Officer",
        var x when string.IsNullOrWhiteSpace(x) => "⚠ No role — edit to fix",
        _                   => r ?? "—"
    };
    bool IsMobile(string r) => UsersModel.MobileRoles.Contains(r ?? "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Manage Users – Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/dashboard.css"/>
</head>
<body>
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

<nav class="navbar navbar-dark dashboard-navbar fixed-top d-none d-lg-flex">
    <div class="container-fluid">
        <a class="navbar-brand" href="/Dashboard/SuperAdmin">
            <i class="bi bi-droplet-fill"></i> Yeka Cleaning
        </a>
        <div class="nav-user">
            <span>@sessionUser</span>
            <a class="btn-logout" href="/Login?logout=1">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </div>
</nav>
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
    <div class="container-fluid">
        <button class="navbar-toggler" onclick="toggleSidebar()">
            <span class="navbar-toggler-icon"></span>
        </button>
        <a class="navbar-brand" href="/Dashboard/SuperAdmin">
            <i class="bi bi-droplet-fill"></i> Yeka
        </a>
        <a class="btn-logout" href="/Login?logout=1">
            <i class="bi bi-box-arrow-left"></i>
        </a>
    </div>
</nav>
<nav id="sidebarMenu" class="sidebar d-lg-none">
    @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
</nav>
<nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform:none;padding-top:56px">
    @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
</nav>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5" style="margin-top:56px">

    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom flex-wrap gap-2">
        <h1 class="h2 mb-0"><i class="bi bi-people me-2"></i>Manage Users</h1>
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm"
                    data-bs-toggle="modal" data-bs-target="#modalPrivate">
                <i class="bi bi-building-add me-1"></i>Register Private Rep
            </button>
            <button class="btn btn-primary btn-sm"
                    data-bs-toggle="modal" data-bs-target="#modalAdd">
                <i class="bi bi-person-plus-fill me-1"></i>Add User
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show py-2">
            <i class="bi bi-check-circle-fill me-1"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @{
        // Warn about PrivateCompanyRep users who have no linked company
        var unlinkedPrivateReps = Model.UsersList
            .Where(u => u.Role?.ToLower() == "privatecompanyrep" && u.IsActive)
            .ToList();
    }
    @if (unlinkedPrivateReps.Any())
    {
        <div class="alert alert-warning alert-dismissible fade show py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>
            <strong>@unlinkedPrivateReps.Count Private Company Rep user(s)</strong>
            may not have a company linked.
            Go to
            <a href="/Dashboard/SuperAdmin/PrivateCleaningCompany" class="alert-link fw-bold">
                Private Cleaning Companies
            </a>
            and use the <i class="bi bi-person-plus"></i> button to link each rep to their company.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Search + stats -->
    <div class="d-flex flex-wrap gap-3 align-items-center mb-3">
        <form method="get" class="d-flex gap-2">
            <input class="form-control form-control-sm" name="searchQuery"
                   value="@Model.SearchQuery" placeholder="Search name / email / role…"
                   style="width:240px"/>
            <button class="btn btn-outline-secondary btn-sm" type="submit">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a class="btn btn-outline-danger btn-sm"
                   href="/Dashboard/SuperAdmin/Users">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>
        <div class="d-flex gap-2 flex-wrap">
            <span class="badge bg-primary   px-3 py-2">Total: @Model.UsersList.Count</span>
            <span class="badge bg-success   px-3 py-2">Active: @Model.UsersList.Count(u => u.IsActive)</span>
            <span class="badge bg-danger    px-3 py-2">Inactive: @Model.UsersList.Count(u => !u.IsActive)</span>
            <span class="badge bg-info text-dark px-3 py-2">
                📱 Mobile: @Model.UsersList.Count(u => IsMobile(u.Role))
            </span>
        </div>
    </div>

    <!-- Users table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Mobile</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.UsersList.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                No users found.
                            </td>
                        </tr>
                    }
                    @foreach (var u in Model.UsersList)
                    {
                        var rowCss = string.IsNullOrWhiteSpace(u.Role) ? "table-warning" : "";
                        <tr class="@rowCss">
                            <td class="text-muted small">@u.Id</td>
                            <td class="fw-semibold">@u.Name</td>
                            <td><code class="small">@u.Email</code></td>
                            <td>
                                <span class="badge bg-@Badge(u.Role ?? "") px-2 py-1">
                                    @Label(u.Role ?? "")
                                </span>
                            </td>
                            <td class="small">
                                @(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)
                            </td>
                            <td>
                                <!-- POST to /admin/users/toggle -->
                                <form method="post" action="/admin/users/toggle"
                                      style="display:inline">
                                    <input type="hidden" name="UserId" value="@u.Id"/>
                                    <button type="submit"
                                            class="badge border-0 bg-@(u.IsActive ? "success" : "danger") px-2 py-1"
                                            style="cursor:pointer">
                                        @(u.IsActive ? "Active" : "Inactive")
                                    </button>
                                </form>
                            </td>
                            <td class="text-center">
                                @if (IsMobile(u.Role))
                                {
                                    <span title="Mobile app user">📱</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <!-- Edit -->
                                    <button class="btn btn-sm btn-outline-warning"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalEdit"
                                            onclick="fillEdit(
                                                @u.Id,
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Name)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Email)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Role ?? "")),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Phone ?? "")),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Address ?? "")),
                                                @(u.IsActive ? "true" : "false")
                                            )"
                                            title="Edit user">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <!-- Reset password -->
                                    <button class="btn btn-sm btn-outline-secondary"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalReset"
                                            onclick="fillReset(
                                                @u.Id,
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(u.Name))
                                            )"
                                            title="Reset password">
                                        <i class="bi bi-key"></i>
                                    </button>
                                    <!-- Deactivate -->
                                    <form method="post" action="/admin/users/deactivate"
                                          style="display:inline"
                                          onsubmit="return confirm('Deactivate this user?')">
                                        <input type="hidden" name="UserId" value="@u.Id"/>
                                        <button type="submit"
                                                class="btn btn-sm btn-outline-danger"
                                                title="Deactivate">
                                            <i class="bi bi-person-dash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</main>

<!-- ════ ADD USER MODAL — posts to /admin/users/create ══════════════════════ -->
<div class="modal fade" id="modalAdd" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="/admin/users/create" id="formAdd">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-person-plus-fill me-1"></i> Add User
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12 mb-2">
                        <label class="form-label fw-semibold text-info">Link to Registered Employee</label>
                        <select class="form-select border-info bg-info-subtle" id="employeeSelect" onchange="fillFromEmployee()">
                            <option value="">— Select an Employee (Optional) —</option>
                            @foreach(var e in Model.AvailableEmployees) {
                                <option value="@e.Id" data-name="@e.Name" data-lastname="@e.LastName" data-email="@e.Email" data-phone="@e.Phone">@e.Name (@e.Email)</option>
                            }
                        </select>
                        <div class="form-text">Select an employee registered by HR to automatically fill their details.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Full Name *</label>
                        <input class="form-control" name="Name" required/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email *</label>
                        <input type="email" class="form-control" name="Email" required/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Password *</label>
                        <input type="password" class="form-control" name="Password"
                               required minlength="6"/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Role *</label>
                        <select class="form-select" name="Role" id="addRole" required>
                            <option value="">— Select Role —</option>
                            <option value="driver">Driver  (Mobile App)</option>
                            <option value="outsource">Outsource  (Mobile App)</option>
                            <option value="manager">Manager  (Mobile App)</option>
                            <option value="hr">Human Resources  (Web)</option>
                            <option value="superadmin">Super Admin  (Web)</option>
                            <option value="staff">Staff  (Web)</option>
                            <option value="wereda_mahberat">Wereda Mahberat  (Web)</option>
                            <option value="DispatchOfficer">Dispatch Officer  (Web)</option>
                        </select>
                        <div class="form-text mt-1">
                            For <strong>Private Company Rep</strong> use the
                            <em>Register Private Rep</em> button.
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <input type="tel" class="form-control" name="Phone"
                               placeholder="+251 9xx xxx xxx"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Address</label>
                        <input class="form-control" name="Address"/>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input"
                                   name="IsActive" value="true" checked id="addActive"/>
                            <label class="form-check-label" for="addActive">
                                Active (can log in immediately)
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"
                            onclick="return validateAddRole()">
                        <i class="bi bi-check-lg me-1"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════ REGISTER PRIVATE REP — posts to /admin/users/create-private ════════ -->
<div class="modal fade" id="modalPrivate" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" action="/admin/users/create-private">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-building-add me-1"></i> Register Private Company Rep
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small py-2 mb-3">
                        Creates a <strong>PrivateCompanyRep</strong> mobile login
                        <em>and</em> a linked company profile in one step.
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name *</label>
                            <input class="form-control" name="Name" required/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email *</label>
                            <input type="email" class="form-control" name="Email" required/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Password *</label>
                            <input type="password" class="form-control" name="Password"
                                   required minlength="6"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone</label>
                            <input type="tel" class="form-control" name="Phone"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Company Name *</label>
                            <input class="form-control" name="CompanyName" required/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">License Number</label>
                            <input class="form-control" name="LicenseNumber"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Company Address</label>
                            <input class="form-control" name="CompanyAddress"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Services Offered</label>
                            <input class="form-control" name="ServicesOffered"
                                   placeholder="Waste collection, Street cleaning…"/>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-person-check-fill me-1"></i>Register
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════ EDIT USER — posts to /admin/users/update ═══════════════════════════ -->
<div class="modal fade" id="modalEdit" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="/admin/users/update">
                <input type="hidden" name="UserId" id="eId"/>
                <div class="modal-header bg-warning">
                    <h5 class="modal-title">
                        <i class="bi bi-pencil-square me-1"></i> Edit User
                    </h5>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Full Name *</label>
                        <input class="form-control" name="Name" id="eName" required/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Email *</label>
                        <input type="email" class="form-control" name="Email"
                               id="eEmail" required/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Role *</label>
                        <select class="form-select" name="Role" id="eRole" required>
                            <option value="">— Select Role —</option>
                            <option value="driver">Driver  (Mobile App)</option>
                            <option value="outsource">Outsource  (Mobile App)</option>
                            <option value="PrivateCompanyRep">Private Company Rep  (Mobile App)</option>
                            <option value="manager">Manager  (Mobile App)</option>
                            <option value="hr">Human Resources  (Web)</option>
                            <option value="superadmin">Super Admin  (Web)</option>
                            <option value="staff">Staff  (Web)</option>
                            <option value="wereda_mahberat">Wereda Mahberat  (Web)</option>
                            <option value="DispatchOfficer">Dispatch Officer  (Web)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <input type="tel" class="form-control" name="Phone" id="ePhone"/>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Address</label>
                        <input class="form-control" name="Address" id="eAddress"/>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            New Password
                            <small class="text-muted">(leave blank to keep current)</small>
                        </label>
                        <input type="password" class="form-control" name="Password"
                               minlength="6" placeholder="Leave blank to keep current"/>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input"
                                   name="IsActive" id="eActive" value="true"/>
                            <label class="form-check-label fw-semibold" for="eActive">
                                Active
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════ RESET PASSWORD — posts to /admin/users/reset-password ══════════════ -->
<div class="modal fade" id="modalReset" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" action="/admin/users/reset-password">
                <input type="hidden" name="UserId" id="rId"/>
                <div class="modal-header">
                    <h6 class="modal-title">
                        <i class="bi bi-key me-1"></i> Reset Password
                    </h6>
                    <button type="button" class="btn-close"
                            data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-2">
                        User: <strong id="rName"></strong>
                    </p>
                    <label class="form-label fw-semibold">New Password *</label>
                    <input type="password" class="form-control" name="Password"
                           required minlength="6" placeholder="Min. 6 characters"/>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-sm btn-warning">
                        Reset
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
function toggleSidebar() {
    document.getElementById('sidebarMenu').classList.toggle('show');
    document.getElementById('sidebarBackdrop').classList.toggle('show');
}

function validateAddRole() {
    var v = document.getElementById('addRole').value;
    if (!v) { alert('Please select a Role before creating the user.'); return false; }
    return true;
}

function fillFromEmployee() {
    var sel = document.getElementById('employeeSelect');
    if(sel.selectedIndex > 0) {
        var opt = sel.options[sel.selectedIndex];
        document.querySelector('#formAdd input[name="Name"]').value = opt.getAttribute('data-name');
        document.querySelector('#formAdd input[name="Email"]').value = opt.getAttribute('data-email');
        document.querySelector('#formAdd input[name="Phone"]').value = opt.getAttribute('data-phone');
        
        var lastName = opt.getAttribute('data-lastname');
        if(lastName) {
            document.querySelector('#formAdd input[name="Password"]').value = lastName + '@@123';
        }
    }
}

function fillEdit(id, name, email, role, phone, address, isActive) {
    document.getElementById('eId').value      = id;
    document.getElementById('eName').value    = name;
    document.getElementById('eEmail').value   = email;
    document.getElementById('ePhone').value   = phone;
    document.getElementById('eAddress').value = address;
    document.getElementById('eActive').checked = (isActive === true || isActive === 'true');

    // Match role case-insensitively
    var sel = document.getElementById('eRole');
    var matched = false;
    for (var i = 0; i < sel.options.length; i++) {
        if (sel.options[i].value.toLowerCase() === (role || '').toLowerCase()) {
            sel.selectedIndex = i;
            matched = true;
            break;
        }
    }
    if (!matched) sel.selectedIndex = 0;
}

function fillReset(id, name) {
    document.getElementById('rId').value          = id;
    document.getElementById('rName').textContent  = name;
}
</script>
</body>
</html>
