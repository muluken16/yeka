@{
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path, bool exact = false)
    {
        if (exact) return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}
<button class="sidebar-toggle-btn d-none d-md-flex" id="sidebarToggleBtn" onclick="toggleSidebarCollapse()" title="Expand / Collapse">
    <i class="bi bi-chevron-left" id="sidebarToggleIcon"></i>
</button>

<div class="sidebar-scroll pt-3" style="height:100%">

    <!-- Logo -->
    <div class="sidebar-logo-area pb-3 mb-2 border-bottom d-flex align-items-center gap-2 px-3" style="min-height:54px">
        <i class="bi bi-droplet-fill text-info fs-5 flex-shrink-0"></i>
        <div class="sidebar-brand-text">
            <div class="text-white fw-bold" style="font-size:.95rem;line-height:1.2">Yeka Cleaning</div>
            <div class="text-white-50" style="font-size:.68rem">Super Admin</div>
        </div>
    </div>

    <ul class="nav flex-column px-1">

        <!-- ── MAIN ──────────────────────────────────────────────────────── -->
        <li class="nav-item mt-1">
            <span class="nav-section-label px-3">Main</span>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/SuperAdmin",true)?"active":"")"
               href="/Dashboard/SuperAdmin" title="Home">
                <i class="bi bi-speedometer2 flex-shrink-0"></i>
                <span class="nav-label ms-2">Home</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/SuperAdmin/Users")?"active":"")"
               href="/Dashboard/SuperAdmin/Users" title="Users">
                <i class="bi bi-people flex-shrink-0"></i>
                <span class="nav-label ms-2">Users</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/SuperAdmin/RoleUsage")?"active":"")"
               href="/Dashboard/SuperAdmin/RoleUsage" title="Role Usage">
                <i class="bi bi-shield-lock flex-shrink-0"></i>
                <span class="nav-label ms-2">Role Usage</span>
            </a>
        </li>

        <!-- ── CONFIGURATION ─────────────────────────────────────────────── -->
        <li class="nav-item mt-3">
            <span class="nav-section-label px-3">Configuration</span>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/SuperAdmin/Settings")?"active":"")"
               href="/Dashboard/SuperAdmin/Settings" title="Settings">
                <i class="bi bi-gear flex-shrink-0"></i>
                <span class="nav-label ms-2">Settings</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/Profile")?"active":"")"
               href="/Dashboard/Profile" title="My Profile">
                <i class="bi bi-person-circle flex-shrink-0"></i>
                <span class="nav-label ms-2">My Profile</span>
            </a>
        </li>

        <!-- ── BOTTOM ────────────────────────────────────────────────────── -->
        <li class="nav-item border-top mt-3 pt-2">
            <a class="nav-link text-warning fw-semibold" href="/Login?logout=1" title="Logout">
                <i class="bi bi-box-arrow-left flex-shrink-0"></i>
                <span class="nav-label ms-2">Logout</span>
            </a>
        </li>

    </ul>
</div>

<style>
    .nav-section-label {
        display: block;
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(255,255,255,.35);
        margin-bottom: .2rem;
        white-space: nowrap;
        overflow: hidden;
    }
    .sidebar-collapsed .nav-section-label {
        visibility: hidden;
    }
</style>

<script>
(function(){
    var collapsed = localStorage.getItem('sidebarCollapsed')==='1';
    if(collapsed) _applyCollapse(true);
    function _applyCollapse(c){
        var b=document.body, ic=document.getElementById('sidebarToggleIcon');
        c ? b.classList.add('sidebar-collapsed') : b.classList.remove('sidebar-collapsed');
        if(ic){ ic.className = c ? 'bi bi-chevron-right' : 'bi bi-chevron-left'; }
    }
    window.toggleSidebarCollapse=function(){
        var c=!document.body.classList.contains('sidebar-collapsed');
        _applyCollapse(c); localStorage.setItem('sidebarCollapsed',c?'1':'0');
    };
})();
</script>
