@page
@model CleaningManagmentSystem.Pages.Dashboard.SuperAdmin.RoleUsageModel
@using CleaningManagmentSystem.Pages.Dashboard.SuperAdmin
@{
    var sessionUser = HttpContext.Session.GetString("UserName");
    if (sessionUser == null) { Response.Redirect("/Login"); return; }

    // Helper: permission checkmark
    string Chk(bool v) => v ? "✔" : "—";
    string ChkCss(bool v) => v ? "text-success fw-bold" : "text-muted";

    string LevelLabel(int lv) => lv switch {
        4 => "Level 4 – Admin",
        3 => "Level 3 – Manager",
        2 => "Level 2 – Standard",
        _ => "Level 1 – Basic"
    };

    // Badge colours (Bootstrap doesn't have purple/indigo natively, we inline)
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Role Usage &amp; Permissions – Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="stylesheet" href="~/css/dashboard.css"/>
    <style>
        .role-stat-card        { transition: box-shadow .2s; cursor: pointer; }
        .role-stat-card:hover  { box-shadow: 0 0 0 3px rgba(13,110,253,.4) !important; }
        .role-stat-card.active-filter { box-shadow: 0 0 0 3px #0d6efd !important; }
        .perm-table th, .perm-table td { font-size:.82rem; vertical-align:middle; }
        .perm-table thead th  { background:#212529; color:#fff; white-space:nowrap; }
        .badge-pill-lg        { font-size:.85rem; padding:.45em .9em; border-radius:50rem; }
        .user-table td, .user-table th { font-size:.84rem; }
        pre.resp              { white-space:pre-wrap; font-family:inherit; font-size:.82rem; margin:0; }
    </style>
</head>
<body>
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

<!-- Desktop Navbar -->
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-none d-lg-flex">
    <div class="container-fluid">
        <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
        <div class="nav-user">
            <span>@sessionUser</span>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </div>
</nav>
<!-- Mobile Navbar -->
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
    <div class="container-fluid">
        <button class="navbar-toggler" onclick="toggleSidebar()"><span class="navbar-toggler-icon"></span></button>
        <a class="navbar-brand" href="/Dashboard/SuperAdmin"><i class="bi bi-droplet-fill"></i> Yeka</a>
        <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-left"></i></a>
    </div>
</nav>
<nav id="sidebarMenu" class="sidebar d-lg-none">
    @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
</nav>
<nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform:none;padding-top:56px">
    @await Html.PartialAsync("~/Pages/Dashboard/SuperAdmin/_Sidebar.cshtml")
</nav>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5" style="margin-top:56px">

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom flex-wrap gap-2">
        <h1 class="h2 mb-0"><i class="bi bi-shield-lock me-2"></i>Role Usage &amp; Permissions</h1>
        <span class="badge bg-danger px-3 py-2">Super Admin</span>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show py-2">
            <i class="bi bi-check-circle-fill me-1"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ════ TABS ═══════════════════════════════════════════════════════════ -->
    <ul class="nav nav-tabs mb-4" id="roleTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabOverview">
            <i class="bi bi-grid-3x3-gap me-1"></i>Overview</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabUsers">
            <i class="bi bi-people me-1"></i>Users by Role
            <span class="badge bg-secondary ms-1">@Model.AllUsers.Count</span></button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabPermissions">
            <i class="bi bi-table me-1"></i>Permission Matrix</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabRecent">
            <i class="bi bi-clock-history me-1"></i>Recent Accounts</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabDefinitions">
            <i class="bi bi-card-list me-1"></i>Role Definitions</button></li>
    </ul>

    <div class="tab-content">

    <!-- ══════════════════════════════════════════════════════════════════════
         TAB 1 – OVERVIEW  (role stat cards + totals)
    ═══════════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade show active" id="tabOverview">

        <!-- Total summary row -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-1 fw-bold text-primary">@Model.AllUsers.Count</div>
                    <div class="text-muted small">Total Users</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-1 fw-bold text-success">@Model.AllUsers.Count(u => u.IsActive)</div>
                    <div class="text-muted small">Active</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-1 fw-bold text-danger">@Model.AllUsers.Count(u => !u.IsActive)</div>
                    <div class="text-muted small">Inactive</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="fs-1 fw-bold text-info">@Model.RoleUserStats.Count</div>
                    <div class="text-muted small">Distinct Roles</div>
                </div>
            </div>
        </div>

        <!-- Per-role stat cards — click to filter Users tab -->
        <div class="row g-3">
            @foreach (var stat in Model.RoleUserStats)
            {
                var pct = stat.Total > 0 ? (int)Math.Round((double)stat.Active / stat.Total * 100) : 0;
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="card border-0 shadow-sm role-stat-card h-100"
                         onclick="filterByRole('@stat.Role')" title="Click to filter users by this role">
                        <div class="card-body pb-2">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-bold">@stat.DisplayName</div>
                                    <code class="small text-muted">@stat.Role</code>
                                </div>
                                <span class="badge badge-pill-lg bg-@stat.BadgeColor">@stat.Total</span>
                            </div>
                            <div class="progress mb-1" style="height:6px">
                                <div class="progress-bar bg-success" style="width:@pct%"></div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="text-success"><i class="bi bi-circle-fill" style="font-size:.5rem"></i> @stat.Active active</small>
                                <small class="text-danger"><i class="bi bi-circle-fill" style="font-size:.5rem"></i> @stat.Inactive inactive</small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

    </div><!-- /tabOverview -->

    <!-- ══════════════════════════════════════════════════════════════════════
         TAB 2 – USERS BY ROLE
    ═══════════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tabUsers">

        <!-- Role filter pills -->
        <div class="d-flex flex-wrap gap-2 mb-3">
            <a class="btn btn-sm @(string.IsNullOrEmpty(Model.FilterRole) ? "btn-dark" : "btn-outline-dark")"
               href="/Dashboard/SuperAdmin/RoleUsage" onclick="switchToTab('tabUsers')">
                All (@Model.AllUsers.Count)
            </a>
            @foreach (var stat in Model.RoleUserStats)
            {
                <a class="btn btn-sm @(Model.FilterRole.Equals(stat.Role,StringComparison.OrdinalIgnoreCase) ? "btn-" + stat.BadgeColor : "btn-outline-secondary")"
                   href="/Dashboard/SuperAdmin/RoleUsage?filterRole=@Uri.EscapeDataString(stat.Role)"
                   onclick="switchToTab('tabUsers')">
                    @stat.DisplayName <span class="ms-1">(@stat.Total)</span>
                </a>
            }
        </div>

        <!-- Search -->
        <div class="mb-3">
            <input type="text" class="form-control form-control-sm" id="userTableSearch"
                   placeholder="Search name, email, phone…" style="max-width:300px"
                   oninput="filterUserTable(this.value)"/>
        </div>

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 user-table" id="userTable">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Phone</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.AllUsers.Any())
                        {
                            <tr><td colspan="8" class="text-center py-5 text-muted">No users found.</td></tr>
                        }
                        @foreach (var u in Model.AllUsers)
                        {
                            var badge = RoleUsageModel.RoleBadge(u.Role);
                            var disp  = RoleUsageModel.FallbackDisplay(u.Role);
                            <tr>
                                <td class="text-muted small">@u.Id</td>
                                <td class="fw-semibold">@u.Name</td>
                                <td><code class="small">@u.Email</code></td>
                                <td><span class="badge bg-@badge">@disp</span></td>
                                <td class="small">@(string.IsNullOrEmpty(u.Phone) ? "—" : u.Phone)</td>
                                <td>
                                    <span class="badge bg-@(u.IsActive ? "success" : "danger")">
                                        @(u.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="small text-muted">@u.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/Dashboard/SuperAdmin/Users">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div><!-- /tabUsers -->

    <!-- ══════════════════════════════════════════════════════════════════════
         TAB 3 – PERMISSION MATRIX
    ═══════════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tabPermissions">
        <p class="text-muted small mb-3">
            Each row is a role definition. Columns show what that role is allowed to do.
            Click <i class="bi bi-pencil"></i> to edit any row.
        </p>
        @if (!Model.RoleDefinitions.Any())
        {
            <div class="alert alert-info">No role definitions found. Seed the database to populate them.</div>
        }
        else
        {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle mb-0 perm-table">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Access Level</th>
                            <th class="text-center">Create Users</th>
                            <th class="text-center">View Financials</th>
                            <th class="text-center">Manage Dispatch</th>
                            <th class="text-center">View Payroll</th>
                            <th class="text-center">Manage Staff</th>
                            <th class="text-center">Users</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.RoleDefinitions)
                        {
                            var stat = Model.RoleUserStats.FirstOrDefault(
                                s => s.Role.Equals(r.RoleName, StringComparison.OrdinalIgnoreCase));
                            <tr>
                                <td>
                                    <span class="fw-semibold">@r.DisplayName</span><br/>
                                    <code class="small text-muted">@r.RoleName</code>
                                </td>
                                <td>
                                    <span class="badge bg-@(r.AccessLevel==4?"danger":r.AccessLevel==3?"primary":r.AccessLevel==2?"warning text-dark":"secondary")">
                                        @LevelLabel(r.AccessLevel)
                                    </span>
                                </td>
                                <td class="text-center @ChkCss(r.CanCreateUsers)">@Chk(r.CanCreateUsers)</td>
                                <td class="text-center @ChkCss(r.CanViewFinancials)">@Chk(r.CanViewFinancials)</td>
                                <td class="text-center @ChkCss(r.CanManageDispatch)">@Chk(r.CanManageDispatch)</td>
                                <td class="text-center @ChkCss(r.CanViewPayroll)">@Chk(r.CanViewPayroll)</td>
                                <td class="text-center @ChkCss(r.CanManageStaff)">@Chk(r.CanManageStaff)</td>
                                <td class="text-center">
                                    @if (stat != null)
                                    {
                                        <span class="badge bg-primary">@stat.Total</span>
                                        <small class="text-muted ms-1">(@stat.Active active)</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-warning"
                                            onclick="openEditModal(@r.Id,
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.RoleName)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.DisplayName)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.Description)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.UsageContext)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.PrimaryResponsibilities)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.DailyActivities)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.ReportsAccess)),
                                                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.ModulesAccess)),
                                                @r.AccessLevel,
                                                @r.CanCreateUsers.ToString().ToLower(),
                                                @r.CanViewFinancials.ToString().ToLower(),
                                                @r.CanManageDispatch.ToString().ToLower(),
                                                @r.CanViewPayroll.ToString().ToLower(),
                                                @r.CanManageStaff.ToString().ToLower())"
                                            title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        }
    </div><!-- /tabPermissions -->

    <!-- ══════════════════════════════════════════════════════════════════════
         TAB 4 – RECENT ACCOUNTS
    ═══════════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tabRecent">
        <p class="text-muted small mb-3">Last 10 user accounts created in the system.</p>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 user-table">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.RecentUsers.Any())
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted">No users yet.</td></tr>
                        }
                        @foreach (var u in Model.RecentUsers)
                        {
                            var badge = RoleUsageModel.RoleBadge(u.Role);
                            var disp  = RoleUsageModel.FallbackDisplay(u.Role);
                            <tr>
                                <td class="text-muted small">@u.Id</td>
                                <td class="fw-semibold">@u.Name</td>
                                <td><code class="small">@u.Email</code></td>
                                <td><span class="badge bg-@badge">@disp</span></td>
                                <td>
                                    <span class="badge bg-@(u.IsActive?"success":"danger")">
                                        @(u.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="small text-muted">@u.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div><!-- /tabRecent -->

    <!-- ══════════════════════════════════════════════════════════════════════
         TAB 5 – ROLE DEFINITIONS (detail cards)
    ═══════════════════════════════════════════════════════════════════════ -->
    <div class="tab-pane fade" id="tabDefinitions">
        @if (!Model.RoleDefinitions.Any())
        {
            <div class="alert alert-info">No role definitions found in the database.</div>
        }
        <div class="row g-4">
            @foreach (var r in Model.RoleDefinitions)
            {
                var hdrCss = r.AccessLevel == 4 ? "bg-danger" : r.AccessLevel == 3 ? "bg-primary" :
                             r.AccessLevel == 2 ? "bg-warning text-dark" : "bg-secondary";
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header @hdrCss text-white d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-bold fs-6">@r.DisplayName</div>
                                <small class="opacity-75">@r.RoleName</small>
                            </div>
                            <span class="badge bg-white text-dark">@LevelLabel(r.AccessLevel)</span>
                        </div>
                        <div class="card-body small">
                            @if (!string.IsNullOrWhiteSpace(r.Description))
                            {
                                <p class="text-muted mb-2">@r.Description</p>
                            }
                            @if (!string.IsNullOrWhiteSpace(r.UsageContext))
                            {
                                <div class="mb-2"><strong>Context:</strong> @r.UsageContext</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(r.PrimaryResponsibilities))
                            {
                                <div class="mb-2">
                                    <strong>Responsibilities:</strong>
                                    <pre class="resp text-muted mt-1">@r.PrimaryResponsibilities</pre>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(r.DailyActivities))
                            {
                                <div class="mb-2">
                                    <strong>Daily Activities:</strong>
                                    <pre class="resp text-muted mt-1">@r.DailyActivities</pre>
                                </div>
                            }
                            <!-- permission pills -->
                            <div class="d-flex flex-wrap gap-1 mt-2">
                                @if (r.CanCreateUsers)    { <span class="badge bg-success">Create Users</span> }
                                @if (r.CanViewFinancials) { <span class="badge bg-info text-dark">Financials</span> }
                                @if (r.CanManageDispatch) { <span class="badge bg-primary">Dispatch</span> }
                                @if (r.CanViewPayroll)    { <span class="badge bg-warning text-dark">Payroll</span> }
                                @if (r.CanManageStaff)    { <span class="badge bg-secondary">Staff</span> }
                            </div>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
                            @{
                                var s2 = Model.RoleUserStats.FirstOrDefault(
                                    x => x.Role.Equals(r.RoleName, StringComparison.OrdinalIgnoreCase));
                            }
                            <small class="text-muted">
                                <i class="bi bi-people me-1"></i>
                                @(s2 != null ? $"{s2.Total} user(s)" : "0 users")
                            </small>
                            <button class="btn btn-sm btn-outline-warning"
                                    onclick="openEditModal(@r.Id,
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.RoleName)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.DisplayName)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.Description)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.UsageContext)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.PrimaryResponsibilities)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.DailyActivities)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.ReportsAccess)),
                                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(r.ModulesAccess)),
                                        @r.AccessLevel,
                                        @r.CanCreateUsers.ToString().ToLower(),
                                        @r.CanViewFinancials.ToString().ToLower(),
                                        @r.CanManageDispatch.ToString().ToLower(),
                                        @r.CanViewPayroll.ToString().ToLower(),
                                        @r.CanManageStaff.ToString().ToLower())"
                                    title="Edit definition">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div><!-- /tabDefinitions -->

    </div><!-- /tab-content -->
</main>

<!-- ════ EDIT ROLE MODAL ════════════════════════════════════════════════════ -->
<div class="modal fade" id="editRoleModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <input type="hidden" name="EditId" id="mEditId"/>
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-1"></i>Edit Role Definition</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Role Name (internal, read-only)</label>
                            <input class="form-control bg-light" name="RoleName" id="mRoleName" readonly/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Display Name *</label>
                            <input class="form-control" name="DisplayName" id="mDisplayName" required/>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" name="Description" id="mDescription" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Usage Context</label>
                            <textarea class="form-control" name="UsageContext" id="mUsageContext" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Primary Responsibilities</label>
                            <textarea class="form-control" name="PrimaryResponsibilities" id="mPrimaryResp" rows="4" placeholder="One per line"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Daily Activities</label>
                            <textarea class="form-control" name="DailyActivities" id="mDailyAct" rows="4" placeholder="One per line"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Reports Access</label>
                            <input class="form-control" name="ReportsAccess" id="mReports" placeholder="e.g. All Reports, Payroll"/>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Modules Access</label>
                            <input class="form-control" name="ModulesAccess" id="mModules" placeholder="e.g. Dashboard, Users"/>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Access Level</label>
                            <select class="form-select" name="AccessLevel" id="mAccessLevel">
                                <option value="1">Level 1 – Basic</option>
                                <option value="2">Level 2 – Standard</option>
                                <option value="3">Level 3 – Manager</option>
                                <option value="4">Level 4 – Admin</option>
                            </select>
                        </div>
                        <div class="col-md-8 d-flex flex-wrap gap-3 align-items-center pt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="CanCreateUsers"   id="mCanCreate"   value="true"/>
                                <label class="form-check-label" for="mCanCreate">Create Users</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="CanViewFinancials" id="mCanFinancial" value="true"/>
                                <label class="form-check-label" for="mCanFinancial">View Financials</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="CanManageDispatch" id="mCanDispatch"  value="true"/>
                                <label class="form-check-label" for="mCanDispatch">Manage Dispatch</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="CanViewPayroll"    id="mCanPayroll"  value="true"/>
                                <label class="form-check-label" for="mCanPayroll">View Payroll</label>
                            </div>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="CanManageStaff"    id="mCanStaff"    value="true"/>
                                <label class="form-check-label" for="mCanStaff">Manage Staff</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── Sidebar ──────────────────────────────────────────────────────────────────
function toggleSidebar() {
    document.getElementById('sidebarMenu').classList.toggle('show');
    document.getElementById('sidebarBackdrop').classList.toggle('show');
}

// ── Remember active tab across page reloads ───────────────────────────────────
(function () {
    var saved = sessionStorage.getItem('roleUsageTab');
    // If URL has filterRole, force Users tab
    if (window.location.search.includes('filterRole')) saved = 'tabUsers';
    if (saved) {
        var btn = document.querySelector('[data-bs-target="#' + saved + '"]');
        if (btn) { var t = new bootstrap.Tab(btn); t.show(); }
    }
    document.querySelectorAll('#roleTabs button').forEach(function (b) {
        b.addEventListener('shown.bs.tab', function (e) {
            sessionStorage.setItem('roleUsageTab', e.target.getAttribute('data-bs-target').replace('#',''));
        });
    });
})();

// ── Switch to a named tab programmatically ────────────────────────────────────
function switchToTab(tabId) {
    sessionStorage.setItem('roleUsageTab', tabId);
}

// ── Click role card on Overview → go to Users tab filtered ───────────────────
function filterByRole(role) {
    switchToTab('tabUsers');
    window.location.href = '/Dashboard/SuperAdmin/RoleUsage?filterRole=' + encodeURIComponent(role);
}

// ── Live search inside Users table ───────────────────────────────────────────
function filterUserTable(q) {
    var lower = q.toLowerCase();
    document.querySelectorAll('#userTable tbody tr').forEach(function (tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(lower) ? '' : 'none';
    });
}

// ── Fill & open Edit Role modal ───────────────────────────────────────────────
function openEditModal(id, roleName, displayName, description, usageContext,
                       primaryResp, dailyAct, reports, modules, accessLevel,
                       canCreate, canFinancial, canDispatch, canPayroll, canStaff) {
    document.getElementById('mEditId').value       = id;
    document.getElementById('mRoleName').value     = roleName;
    document.getElementById('mDisplayName').value  = displayName;
    document.getElementById('mDescription').value  = description;
    document.getElementById('mUsageContext').value = usageContext;
    document.getElementById('mPrimaryResp').value  = primaryResp;
    document.getElementById('mDailyAct').value     = dailyAct;
    document.getElementById('mReports').value      = reports;
    document.getElementById('mModules').value      = modules;
    document.getElementById('mAccessLevel').value  = accessLevel;
    document.getElementById('mCanCreate').checked    = canCreate    === true || canCreate    === 'true';
    document.getElementById('mCanFinancial').checked = canFinancial === true || canFinancial === 'true';
    document.getElementById('mCanDispatch').checked  = canDispatch  === true || canDispatch  === 'true';
    document.getElementById('mCanPayroll').checked   = canPayroll   === true || canPayroll   === 'true';
    document.getElementById('mCanStaff').checked     = canStaff     === true || canStaff     === 'true';
    new bootstrap.Modal(document.getElementById('editRoleModal')).show();
}
</script>
</body>
</html>
