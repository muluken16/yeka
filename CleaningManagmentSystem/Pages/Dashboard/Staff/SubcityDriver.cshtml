                    <div class="btn-group btn-group-sm">
                        <button class="btn btn-outline-secondary active">All</button>
                        <button class="btn btn-outline-secondary">Available</button>
                        <button class="btn btn-outline-secondary">On Duty</button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Driver</th>
                                    <th>License</th>
                                    <th>Vehicle</th>
                                    <th>Subcity</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                                <span class="text-white">TG</span>
                                            </div>
                                            <strong>Tigist Girma</strong>
                                        </div>
                                    </td>
                                    <td>DL-2024-1234</td>
                                    <td>Van 001</td>
                                    <td>Bole</td>
                                    <td><span class="badge bg-success">Available</span></td>
                                    <td>
