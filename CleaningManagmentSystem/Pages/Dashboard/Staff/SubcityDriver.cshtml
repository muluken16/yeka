                                        <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-whatsapp"></i></button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar bg-secondary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                                <span class="text-white">TM</span>
                                            </div>
                                            <strong>Tadesse Mengistu</strong>
                                        </div>
                                    </td>
                                    <td>DL-2024-3456</td>
                                    <td>Van 003</td>
                                    <td>Lideta</td>
                                    <td><span class="badge bg-success">Available</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></button>
                                        <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-whatsapp"></i></button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body text-center">
                    <i class="bi bi-truck display-4 text-primary"></i>
                    <h4 class="mt-2">4</h4>
                    <p class="text-muted mb-0">Active Vehicles</p>
                </div>
