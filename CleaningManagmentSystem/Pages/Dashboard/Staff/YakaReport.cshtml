@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.YakaReportModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Yaka General Report";

    string TBadge(string t) => t switch {
        "Outsource" => "bg-purple",
        "Private"   => "bg-info text-dark",
        _           => "bg-primary"
    };
    string SBadge(string s) => s switch {
        "Approved" or "Billed" => "bg-success",
        "Paid"                 => "bg-primary",
        "Pending"              => "bg-warning text-dark",
        "Registered"           => "bg-info text-dark",
        "Rejected"             => "bg-danger",
        _                      => "bg-secondary"
    };
}

<style>
    .bg-purple { background-color:#6f42c1!important; color:#fff!important; }
    .chart-box  { height:195px; position:relative; }
    .filter-card { border-radius:14px; border:none; }
    /* print sheet */
    .sheet { background:#fff; border:1px solid #dee2e6; border-radius:8px; padding:32px 36px; }
    .sheet table { width:100%; border-collapse:collapse; font-size:.82rem; }
    .sheet thead tr { background:#1a1a2e; color:#fff; }
    .sheet thead th { padding:8px 10px; font-weight:600; }
    .sheet tbody tr:nth-child(even) { background:#f8f9fa; }
    .sheet tbody td { padding:6px 10px; border-bottom:1px solid #f1f1f1; vertical-align:middle; }
    .sheet tfoot td { padding:8px 10px; font-weight:700; background:#e9ecef; }
    .grp-hdr { background:#e8edf5!important; font-weight:700; font-size:.78rem;
               letter-spacing:.04em; text-transform:uppercase; color:#1a1a2e; }
    @@media print {
        .no-print { display:none!important; }
        .sheet { border:none; padding:0; }
        body { background:#fff!important; }
    }
</style>

<div class="main-content p-3 p-md-4">
<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2 no-print">
        <div>
            <h2 class="h4 mb-1 fw-bold">
                <i class="bi bi-file-earmark me-2 text-primary"></i>Yaka General Report
            </h2>
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/Dashboard/Staff/Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Yaka Report</li>
            </ol>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Print
            </button>
            <form method="post" asp-page-handler="ExportCsv" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="FilterType"       value="@Model.FilterType" />
                <input type="hidden" name="FilterStatus"     value="@Model.FilterStatus" />
                <input type="hidden" name="FilterStartDate"  value="@Model.FilterStartDate" />
                <input type="hidden" name="FilterEndDate"    value="@Model.FilterEndDate" />
                <input type="hidden" name="FilterWeredaId"   value="@(Model.FilterWeredaId ?? 0)" />
                <input type="hidden" name="FilterMahberatId" value="@(Model.FilterMahberatId ?? 0)" />
                <input type="hidden" name="FilterDriverId"   value="@(Model.FilterDriverId ?? 0)" />
                <input type="hidden" name="GroupBy"          value="@Model.GroupBy" />
                <input type="hidden" name="ReportView"       value="@Model.ReportView" />
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="bi bi-download me-1"></i>Export CSV
                </button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
        </div>
    }

    <!-- ════ FILTER BAR ════════════════════════════════════════════════════ -->
    <div class="card filter-card shadow-sm mb-4 no-print">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">

                <!-- Receipt Type -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Receipt Type</label>
                    <select name="FilterType" class="form-select form-select-sm">
                        <option value="All"      >@(Model.FilterType=="All"       ? "✓ " : "")All Types</option>
                        <option value="Mahberat" >@(Model.FilterType=="Mahberat"  ? "✓ " : "")Mahberat</option>
                        <option value="Outsource">@(Model.FilterType=="Outsource" ? "✓ " : "")Outsource</option>
                        <option value="Private"  >@(Model.FilterType=="Private"   ? "✓ " : "")Private</option>
                    </select>
                </div>

                <!-- Status -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Status</label>
                    <select name="FilterStatus" class="form-select form-select-sm">
                        <option value=""          >@(string.IsNullOrEmpty(Model.FilterStatus) ? "✓ " : "")All Statuses</option>
                        <option value="Pending"   >@(Model.FilterStatus=="Pending"    ? "✓ " : "")Pending</option>
                        <option value="Registered">@(Model.FilterStatus=="Registered" ? "✓ " : "")Registered</option>
                        <option value="Approved"  >@(Model.FilterStatus=="Approved"   ? "✓ " : "")Approved</option>
                        <option value="Billed"    >@(Model.FilterStatus=="Billed"     ? "✓ " : "")Billed</option>
                        <option value="Paid"      >@(Model.FilterStatus=="Paid"       ? "✓ " : "")Paid</option>
                        <option value="Rejected"  >@(Model.FilterStatus=="Rejected"   ? "✓ " : "")Rejected</option>
                    </select>
                </div>

                <!-- Wereda -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Wereda</label>
                    <select name="FilterWeredaId" class="form-select form-select-sm">
                        <option value="">All Weredas</option>
                        @foreach (var w in Model.Weredas)
                        {
                            var wid = (int)w.id;
                            <option value="@wid">@(Model.FilterWeredaId == wid ? "✓ " : "")@w.name</option>
                        }
                    </select>
                </div>

                <!-- Mahberat -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Mahberat</label>
                    <select name="FilterMahberatId" class="form-select form-select-sm">
                        <option value="">All Mahberats</option>
                        @foreach (var m in Model.Mahberats)
                        {
                            var mid = (int)m.id;
                            <option value="@mid">@(Model.FilterMahberatId == mid ? "✓ " : "")@m.name</option>
                        }
                    </select>
                </div>

                <!-- Driver -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Driver</label>
                    <select name="FilterDriverId" class="form-select form-select-sm">
                        <option value="">All Drivers</option>
                        @foreach (var d in Model.Drivers)
                        {
                            var did = (int)d.id;
                            <option value="@did">@(Model.FilterDriverId == did ? "✓ " : "")@d.name</option>
                        }
                    </select>
                </div>

                <!-- From Date -->
                <div class="col-6 col-sm-4 col-md-1">
                    <label class="form-label small fw-semibold mb-1">From</label>
                    <input type="date" name="FilterStartDate" class="form-control form-control-sm"
                           value="@Model.FilterStartDate" />
                </div>

                <!-- To Date -->
                <div class="col-6 col-sm-4 col-md-1">
                    <label class="form-label small fw-semibold mb-1">To</label>
                    <input type="date" name="FilterEndDate" class="form-control form-control-sm"
                           value="@Model.FilterEndDate" />
                </div>

                <!-- Group By -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Group By</label>
                    <select name="GroupBy" class="form-select form-select-sm">
                        <option value="wereda"  >@(Model.GroupBy=="wereda"   ? "✓ " : "")Wereda</option>
                        <option value="mahberat">@(Model.GroupBy=="mahberat" ? "✓ " : "")Mahberat</option>
                        <option value="type"    >@(Model.GroupBy=="type"     ? "✓ " : "")Type</option>
                        <option value="status"  >@(Model.GroupBy=="status"   ? "✓ " : "")Status</option>
                        <option value="driver"  >@(Model.GroupBy=="driver"   ? "✓ " : "")Driver</option>
                    </select>
                </div>

                <!-- Report View -->
                <div class="col-6 col-sm-4 col-md-2">
                    <label class="form-label small fw-semibold mb-1">View</label>
                    <select name="ReportView" class="form-select form-select-sm">
                        <option value="summary" >@(Model.ReportView=="summary"  ? "✓ " : "")Summary</option>
                        <option value="detailed">@(Model.ReportView=="detailed" ? "✓ " : "")Detailed</option>
                    </select>
                </div>

                <!-- Buttons -->
                <div class="col-12 col-md-2 d-flex gap-1 mt-1">
                    <button type="submit" class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-search me-1"></i>Show Report
                    </button>
                    <a href="/Dashboard/Staff/YakaReport" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x"></i>
                    </a>
                </div>

            </form>
        </div>
    </div>

    <!-- ════ STAT CARDS ════════════════════════════════════════════════════ -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalCount</div>
                <div class="small text-muted">Total Receipts</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-3 fw-bold text-info">@Model.TotalKg.ToString("N1")</div>
                <div class="small text-muted">Total KG</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-3 fw-bold text-success">@Model.TotalAmount.ToString("N0")</div>
                <div class="small text-muted">Total ETB</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-warning">@Model.TotalPending</div>
                <div class="small text-muted">Pending</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-success" style="opacity:.85">@(Model.TotalApproved + Model.TotalPaid)</div>
                <div class="small text-muted">Approved/Paid</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-danger">@Model.TotalRejected</div>
                <div class="small text-muted">Rejected</div>
            </div>
        </div>
    </div>

    <!-- ════ CHARTS ════════════════════════════════════════════════════════ -->
    @if (Model.ChartLabels.Any())
    {
        <div class="row g-3 mb-4 no-print">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0 small">
                        <i class="bi bi-bar-chart-line me-1 text-info"></i>Daily KG — @Model.FilterStartDate to @Model.FilterEndDate
                    </div>
                    <div class="card-body"><div class="chart-box"><canvas id="chartKg"></canvas></div></div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0 small">
                        <i class="bi bi-cash-stack me-1 text-success"></i>Daily Amount ETB — @Model.FilterStartDate to @Model.FilterEndDate
                    </div>
                    <div class="card-body"><div class="chart-box"><canvas id="chartAmt"></canvas></div></div>
                </div>
            </div>
        </div>
    }

    <!-- ════ PRINTABLE SHEET ════════════════════════════════════════════════ -->
    <div class="sheet shadow-sm">

        <!-- Sheet header -->
        <div class="d-flex justify-content-between align-items-start pb-3 mb-3 border-bottom flex-wrap gap-2">
            <div>
                <div class="fw-bold text-uppercase" style="font-size:1rem;letter-spacing:.05em">
                    YEKA CLEANING MANAGEMENT SYSTEM
                </div>
                <div class="text-muted small mt-1">
                    Yaka General Report ·
                    Type: <strong>@Model.FilterType</strong> ·
                    Status: <strong>@(string.IsNullOrEmpty(Model.FilterStatus) ? "All" : Model.FilterStatus)</strong> ·
                    @Model.FilterStartDate to @Model.FilterEndDate ·
                    Grouped by: <strong>@Model.GroupBy.ToUpper()</strong> ·
                    View: <strong>@Model.ReportView.ToUpper()</strong>
                </div>
            </div>
            <div class="text-end small text-muted">
                <div>Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")</div>
                <div>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
            </div>
        </div>

        @if (!Model.Receipts.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                No receipts found. Adjust filters and click <strong>Show Report</strong>.
            </div>
        }
        else if (Model.ReportView == "summary")
        {
            <!-- ── SUMMARY VIEW: grouped breakdown table ────────────────── -->
            <table>
                <thead>
                    <tr>
                        <th>@Model.GroupBy.ToUpper()</th>
                        <th style="text-align:center">Receipts</th>
                        <th style="text-align:right">Total KG</th>
                        <th style="text-align:right">Total ETB</th>
                        <th style="text-align:center">Approved</th>
                        <th style="text-align:center">Pending</th>
                        <th style="text-align:center">Paid</th>
                        <th style="text-align:center">Rejected</th>
                        <th style="text-align:right">Avg KG/Receipt</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var g in Model.GroupedData)
                {
                    <tr>
                        <td class="fw-semibold">@(string.IsNullOrEmpty(g.GroupKey) ? "— Unknown —" : g.GroupKey)</td>
                        <td style="text-align:center">
                            <span class="badge bg-primary">@g.Count</span>
                        </td>
                        <td style="text-align:right;font-weight:600">@g.TotalKg.ToString("N1")</td>
                        <td style="text-align:right;font-weight:700;color:#198754">@g.TotalAmt.ToString("N2")</td>
                        <td style="text-align:center">
                            @if (g.Approved > 0) { <span class="badge bg-success">@g.Approved</span> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td style="text-align:center">
                            @if (g.Pending > 0) { <span class="badge bg-warning text-dark">@g.Pending</span> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td style="text-align:center">
                            @if (g.Paid > 0) { <span class="badge bg-primary">@g.Paid</span> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td style="text-align:center">
                            @if (g.Rejected > 0) { <span class="badge bg-danger">@g.Rejected</span> }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td style="text-align:right">
                            @(g.Count > 0 ? (g.TotalKg / g.Count).ToString("N1") : "—")
                        </td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr>
                        <td>GRAND TOTAL</td>
                        <td style="text-align:center">@Model.TotalCount</td>
                        <td style="text-align:right">@Model.TotalKg.ToString("N1") kg</td>
                        <td style="text-align:right;color:#198754">@Model.TotalAmount.ToString("N2") ETB</td>
                        <td style="text-align:center">@Model.TotalApproved</td>
                        <td style="text-align:center">@Model.TotalPending</td>
                        <td style="text-align:center">@Model.TotalPaid</td>
                        <td style="text-align:center">@Model.TotalRejected</td>
                        <td style="text-align:right">
                            @(Model.TotalCount > 0 ? (Model.TotalKg / Model.TotalCount).ToString("N1") : "—")
                        </td>
                    </tr>
                </tfoot>
            </table>
        }
        else
        {
            <!-- ── DETAILED VIEW: every receipt row ─────────────────────── -->
            @foreach (var grp in Model.GroupedData)
            {
                var gbk = Model.GroupBy;
                var grpRows = Model.Receipts.Where(r =>
                    (gbk == "type"     ? r.ReceiptType :
                     gbk == "status"   ? r.Status      :
                     gbk == "mahberat" ? r.EntityName  :
                     gbk == "driver"   ? r.DriverName  :
                     r.WeredaName) == grp.GroupKey).ToList();

                <!-- Group header -->
                <table style="margin-bottom:0">
                    <tbody>
                        <tr class="grp-hdr">
                            <td colspan="11" style="padding:7px 10px">
                                <i class="bi bi-folder2-open me-1"></i>@grp.GroupKey
                                <span style="font-weight:400;opacity:.65;margin-left:8px">
                                    @grp.Count receipts · @grp.TotalKg.ToString("N1") kg · @grp.TotalAmt.ToString("N2") ETB
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <table style="margin-bottom:16px">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Type</th>
                            <th>Wereda</th>
                            <th>Mahberat / Company</th>
                            <th>Driver</th>
                            <th>Plate</th>
                            <th>Date</th>
                            <th style="text-align:right">KG</th>
                            <th style="text-align:right">Rate</th>
                            <th style="text-align:right">Total ETB</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var r in grpRows)
                    {
                        <tr>
                            <td class="text-muted">@(grpRows.IndexOf(r) + 1)</td>
                            <td><span class="badge @TBadge(r.ReceiptType)" style="font-size:.7rem">@r.ReceiptType</span></td>
                            <td>@(string.IsNullOrEmpty(r.WeredaName) ? "—" : r.WeredaName)</td>
                            <td style="font-weight:600">@(string.IsNullOrEmpty(r.EntityName) ? "—" : r.EntityName)</td>
                            <td>@(string.IsNullOrEmpty(r.DriverName) ? "—" : r.DriverName)</td>
                            <td><code style="font-size:.75rem">@(string.IsNullOrEmpty(r.PlateName) ? "—" : r.PlateName)</code></td>
                            <td>@r.ReceiptDate <span style="color:#aaa;font-size:.72rem">@r.ReceiptTime</span></td>
                            <td style="text-align:right;font-weight:600">@r.Kilogram.ToString("N1")</td>
                            <td style="text-align:right;color:#666">@r.Price.ToString("N2")</td>
                            <td style="text-align:right;font-weight:700;color:#198754">@r.Total.ToString("N2")</td>
                            <td><span class="badge @SBadge(r.Status)" style="font-size:.7rem">@r.Status</span></td>
                        </tr>
                    }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="7" style="text-align:right">Subtotal (@grp.GroupKey):</td>
                            <td style="text-align:right">@grp.TotalKg.ToString("N1") kg</td>
                            <td></td>
                            <td style="text-align:right;color:#198754">@grp.TotalAmt.ToString("N2")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            }

            <!-- Grand total row -->
            <table style="margin-top:8px">
                <tfoot>
                    <tr>
                        <td style="width:60%;text-align:right">GRAND TOTAL (@Model.TotalCount receipts):</td>
                        <td style="width:15%;text-align:right">@Model.TotalKg.ToString("N1") kg</td>
                        <td style="width:5%"></td>
                        <td style="width:15%;text-align:right;color:#198754">@Model.TotalAmount.ToString("N2") ETB</td>
                        <td style="width:5%"></td>
                    </tr>
                </tfoot>
            </table>
        }
    </div>

</div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var labels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
var kgVals  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartKg));
var amtVals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartAmount));

function mkChart(id, lbl, color, data) {
    var ctx = document.getElementById(id);
    if (!ctx || !data.length) return;
    new Chart(ctx, {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: lbl, data: data,
            backgroundColor: color + '88', borderColor: color,
            borderWidth: 1.5, borderRadius: 4 }] },
        options: { responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { x: { ticks: { font: { size: 9 }, maxRotation: 50 } },
                      y: { beginAtZero: true, ticks: { font: { size: 9 } } } } }
    });
}
mkChart('chartKg',  'KG',  '#0dcaf0', kgVals);
mkChart('chartAmt', 'ETB', '#198754', amtVals);
</script>
}
