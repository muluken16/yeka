@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.ApprovalsModel
@{
    ViewData["Title"] = "Approvals & History";
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    var activeTab = string.IsNullOrEmpty(Model.SearchQuery) && string.IsNullOrEmpty(Request.Query["tab"])
        ? "pending" : Request.Query["tab"].ToString();
    if (activeTab != "history") activeTab = "pending";

    // ── 5-step receipt progress tracker (Staff = Level 2) ───────
    string rcpTrack(string status, object mahberatApproved)
    {
        int ma = mahberatApproved == null ? -1 : Convert.ToInt32(mahberatApproved);

        if (status == "MahberatRejected")
            return @"<div class=""d-flex align-items-center gap-2 py-1"">
                <span class=""badge bg-danger px-3 py-2"">
                  <i class=""bi bi-x-circle me-1""></i>Rejected by Mahberat (Level 1)
                </span>
                <small class=""text-muted"">Closed — will not be billed.</small>
              </div>";

        if (status == "Rejected")
            return @"<div class=""d-flex align-items-center gap-2 py-1"">
                <span class=""badge bg-danger px-3 py-2"">
                  <i class=""bi bi-x-circle me-1""></i>Rejected by Staff (Level 2)
                </span>
                <small class=""text-muted"">Closed — will not be billed.</small>
              </div>";

        var steps = new[] {
            ("Submitted",        "Driver / Staff"),
            ("Mahberat Review",  "Mahberat ✓"),
            ("Staff Review",     "You"),
            ("Billed",           "You"),
            ("Paid",             "Finance"),
        };
        int cur = status switch {
            "Pending"  => ma == 1 ? 2 : 1,
            "Approved" => 2,
            "Billed"   => 3,
            "Paid"     => 4,
            _          => 1
        };
        var sb = new System.Text.StringBuilder();
        sb.Append(@"<div class=""rcp-flow"">");
        for (int i = 0; i < steps.Length; i++)
        {
            string cls  = i < cur ? "rcp-done" : (i == cur ? "rcp-active" : "");
            string icon = i < cur ? "✓" : (i + 1).ToString();
            sb.Append($@"<div class=""rcp-item {cls}"">
              <div class=""rcp-circle"">{icon}</div>
              <div class=""rcp-label"">Step {i+1}: {steps[i].Item1}</div>
              <div class=""rcp-actor"">{steps[i].Item2}</div>
            </div>");
        }
        sb.Append("</div>");
        return sb.ToString();
    }
}

<style>
    .tab-pill{border-radius:50px!important;padding:.45rem 1.3rem;font-weight:600}
    .tab-pill.active{background:linear-gradient(90deg,#0d6efd,#0a58ca);color:#fff}
    .badge-count{font-size:.7em;vertical-align:middle}
    .price-calc-box{background:linear-gradient(135deg,#f0fff4,#dcfce7);border-radius:12px;border:1px solid #bbf7d0}
    .total-display{background:linear-gradient(135deg,#1a7a4a,#15803d);color:#fff;border-radius:10px}

    /* ── 5-Step Receipt Progress Tracker ── */
    .rcp-flow{display:flex;align-items:flex-start;padding:8px 0;gap:0}
    .rcp-item{display:flex;flex-direction:column;align-items:center;min-width:90px;position:relative;flex:1}
    .rcp-item:not(:last-child)::after{content:'';position:absolute;top:14px;left:calc(50% + 15px);right:calc(-50% + 15px);height:3px;background:#dee2e6;z-index:0}
    .rcp-item:not(:last-child).rcp-done::after{background:#198754}
    .rcp-item:not(:last-child).rcp-active::after{background:linear-gradient(90deg,#198754 50%,#dee2e6 50%)}
    .rcp-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;z-index:1;position:relative;border:3px solid #dee2e6;background:#fff;color:#adb5bd}
    .rcp-done  .rcp-circle{background:#198754;border-color:#198754;color:#fff}
    .rcp-active .rcp-circle{background:#fff;border-color:#198754;color:#198754;box-shadow:0 0 0 4px rgba(25,135,84,.15);animation:rcpPulse 1.5s infinite}
    @@keyframes rcpPulse{0%,100%{box-shadow:0 0 0 4px rgba(25,135,84,.15)}50%{box-shadow:0 0 0 7px rgba(25,135,84,.05)}}
    .rcp-label{font-size:10px;text-align:center;margin-top:4px;line-height:1.3;color:#6c757d;max-width:88px}
    .rcp-done  .rcp-label,.rcp-active .rcp-label{color:#198754;font-weight:600}
    .rcp-actor{font-size:9px;text-align:center;color:#adb5bd;max-width:88px;margin-top:1px}
    .rcp-active .rcp-actor{color:#198754;font-weight:600}
</style>

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-check2-square text-primary me-2"></i>Approvals &amp; History</h4>
    <span class="badge bg-primary px-3 py-2">Level 2 — Staff</span>
</div>

<!-- ── Tabs ── -->
<ul class="nav gap-2 mb-4" role="tablist">
    <li class="nav-item">
        <button class="btn tab-pill @(activeTab=="pending" ? "active btn-primary" : "btn-outline-primary")"
                onclick="switchTab('pending')" id="tab-pending">
            <i class="bi bi-hourglass-split me-1"></i>Pending
            <span class="badge bg-danger rounded-pill badge-count ms-1">@Model.PendingSubmissions.Count</span>
        </button>
    </li>
    <li class="nav-item">
        <button class="btn tab-pill @(activeTab=="history" ? "active btn-secondary" : "btn-outline-secondary")"
                onclick="switchTab('history')" id="tab-history">
            <i class="bi bi-clock-history me-1"></i>History
            <span class="badge bg-light text-dark rounded-pill badge-count ms-1">@Model.HistorySubmissions.Count</span>
        </button>
    </li>
</ul>

<!-- ══════════════ PENDING TAB ══════════════ -->
<div id="pane-pending" style="display:@(activeTab=="pending"?"block":"none")">
    <div class="row mb-3">
        <div class="col-md-7">
            <form method="get" class="d-flex">
                <input type="hidden" name="tab" value="pending" />
                <div class="input-group">
                    <input type="text" class="form-control" name="SearchQuery"
                           placeholder="Search wereda, driver, plate..." value="@Model.SearchQuery" />
                    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <a href="/Dashboard/Staff/Approvals?tab=pending" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (Model.PendingSubmissions.Count == 0)
    {
        <div class="alert alert-success text-center py-5 shadow-sm rounded-4">
            <i class="bi bi-check-circle-fill display-4 text-success mb-3 d-block"></i>
            <h4>All Caught Up!</h4>
            <p class="mb-0">No receipts awaiting your approval right now.</p>
        </div>
    }
    else
    {
        <!-- Level-2 info banner -->
        <div class="alert alert-info border-0 shadow-sm mb-3 d-flex align-items-center gap-3">
            <i class="bi bi-shield-check fs-4 text-success"></i>
            <div>
                <strong>These receipts have been pre-approved by Mahberat (Level 1).</strong>
                Set the price per KG and confirm to approve &amp; bill.
            </div>
        </div>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Date &amp; Time</th>
                                <th>Wereda &amp; Entity</th>
                                <th>Vehicle &amp; Driver</th>
                                <th>KG &amp; Amount</th>
                                <th>Images</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.PendingSubmissions)
                            {
                                <tr>
                                    <td class="fw-bold">#@item.id</td>
                                    <td>
                                        <span class="d-block fw-bold"><i class="bi bi-calendar-event me-1"></i>@item.date</span>
                                        <small class="text-muted"><i class="bi bi-clock me-1"></i>@item.time</small>
                                    </td>
                                    <td>
                                        <span class="d-block fw-bold text-primary">@item.weredaName</span>
                                        <small class="text-muted">@item.mahberatName</small>
                                        @if (item.receiptType == "Outsource")
                                        { <span class="badge bg-info ms-1" style="font-size:.65em">Outsource</span> }
                                        else
                                        { <span class="badge bg-primary ms-1" style="font-size:.65em">Mahberat</span> }
                                    </td>
                                    <td>
                                        <span class="d-block fw-bold">@item.vehicleName</span>
                                        <small class="text-muted"><i class="bi bi-person me-1"></i>@item.driverName</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary me-1">@item.kilogram KG</span>
                                        <span class="badge bg-success">@item.total ETB</span>
                                        @if (!string.IsNullOrEmpty((string?)item.notes))
                                        {
                                            <small class="text-muted d-block fst-italic mt-1">
                                                <i class="bi bi-journal-text me-1"></i>@item.notes
                                            </small>
                                        }
                                        @if (!string.IsNullOrEmpty((string?)item.mahberat_notes))
                                        {
                                            <small class="text-success d-block fst-italic mt-1">
                                                <i class="bi bi-shield-check me-1"></i>Mahberat: @item.mahberat_notes
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty((string?)item.imageUrl))
                                        {
                                            <div class="d-flex gap-1 flex-wrap" style="max-width:130px;">
                                                @{ var imgIdx = 0; }
                                                @foreach (var img in ((string)item.imageUrl).Split(','))
                                                {
                                                    var cleanImg = img.Trim();
                                                    if (!string.IsNullOrEmpty(cleanImg))
                                                    {
                                                        <a href="#" data-bs-toggle="modal" data-bs-target="#imageModal"
                                                           onclick="showImages('@item.imageUrl', @imgIdx)">
                                                            <img src="@cleanImg" class="rounded border shadow-sm"
                                                                 style="width:42px;height:42px;object-fit:cover"
                                                                 onerror="this.onerror=null;this.src='/images/placeholder.png'" />
                                                        </a>
                                                        imgIdx++;
                                                    }
                                                }
                                            </div>
                                        }
                                        else { <span class="text-muted small">No Image</span> }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <button type="button" class="btn btn-sm btn-success px-3 shadow-sm"
                                                    onclick="openApproveModal(@item.id, '@item.receiptType', @item.kilogram, '@item.weredaName', '@item.driverName')">
                                                <i class="bi bi-check-circle me-1"></i>Approve
                                            </button>
                                            <form method="post" asp-page-handler="Reject" class="m-0">
                                                <input type="hidden" name="id" value="@item.id" />
                                                <input type="hidden" name="receiptType" value="@item.receiptType" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-3 shadow-sm"
                                                        onclick="return confirm('Reject this receipt?');">
                                                    <i class="bi bi-x-circle me-1"></i>Reject
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <!-- 5-step tracker -->
                                <tr class="table-light">
                                    <td colspan="7" class="pt-0 pb-2 px-3">
                                        @Html.Raw(rcpTrack(item.status?.ToString() ?? "Pending", item.mahberat_approved))
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- ══════════════ HISTORY TAB ══════════════ -->
<div id="pane-history" style="display:@(activeTab=="history"?"block":"none")">
    <div class="row mb-3">
        <div class="col-md-7">
            <form method="get" class="d-flex">
                <input type="hidden" name="tab" value="history" />
                <div class="input-group">
                    <input type="text" class="form-control" name="SearchQuery"
                           placeholder="Search wereda, driver, plate..." value="@Model.SearchQuery" />
                    <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <a href="/Dashboard/Staff/Approvals?tab=history" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (Model.HistorySubmissions.Count == 0)
    {
        <div class="alert alert-info text-center py-5 shadow-sm rounded-4">
            <i class="bi bi-clock-history display-4 text-secondary mb-3 d-block"></i>
            <h4>No History Found</h4>
            <p class="mb-0">No previous approvals or rejections.</p>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Type</th>
                                <th>Date &amp; Time</th>
                                <th>Wereda &amp; Entity</th>
                                <th>Vehicle &amp; Driver</th>
                                <th>KG &amp; Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.HistorySubmissions)
                            {
                                <tr>
                                    <td class="fw-bold">#@item.id</td>
                                    <td>
                                        @if (item.receiptType == "Outsource")
                                        { <span class="badge bg-info">Outsource</span> }
                                        else
                                        { <span class="badge bg-primary">Mahberat</span> }
                                    </td>
                                    <td>
                                        <span class="d-block fw-bold">@(item.date ?? "-")</span>
                                        <small class="text-muted">@(item.time ?? "-")</small>
                                    </td>
                                    <td>
                                        <span class="d-block fw-bold text-primary">@item.weredaName</span>
                                        <small class="text-muted">@item.mahberatName</small>
                                    </td>
                                    <td>
                                        <span class="d-block fw-bold">@item.vehicleName</span>
                                        <small class="text-muted"><i class="bi bi-person me-1"></i>@item.driverName</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary me-1">@item.kilogram KG</span>
                                        <span class="badge bg-success">@item.total ETB</span>
                                    </td>
                                    <td>
                                        @{
                                            var sc = (item.status?.ToString()) switch {
                                                "Approved"         => "bg-success",
                                                "Rejected"         => "bg-danger",
                                                "MahberatRejected" => "bg-danger",
                                                "Billed"           => "bg-info",
                                                "Paid"             => "bg-primary",
                                                _                  => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @sc px-3 py-2">@item.status</span>
                                    </td>
                                </tr>
                                <!-- 5-step tracker -->
                                <tr class="table-light">
                                    <td colspan="7" class="pt-0 pb-2 px-3">
                                        @Html.Raw(rcpTrack(item.status?.ToString() ?? "Pending", item.mahberat_approved))
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- ══ Approve Modal ══ -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header" style="background:linear-gradient(90deg,#198754,#146c43);color:#fff">
                <h5 class="modal-title"><i class="bi bi-check-circle-fill me-2"></i>Approve Receipt — Level 2</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3 p-3 bg-light rounded-3">
                    <div class="d-flex gap-3 flex-wrap">
                        <div><i class="bi bi-geo-alt text-primary"></i> <span class="fw-semibold" id="infoWereda"></span></div>
                        <div><i class="bi bi-person text-secondary"></i> <span id="infoDriver"></span></div>
                    </div>
                </div>
                <form method="post" asp-page-handler="Approve" id="approveForm">
                    <input type="hidden" name="id" id="approveId" />
                    <input type="hidden" name="receiptType" id="approveType" />
                    <div class="price-calc-box p-3 mb-3">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary small text-uppercase">Total Kilograms</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-boxes"></i></span>
                                <input type="number" class="form-control fw-bold fs-5 bg-white" id="approveKg" readonly />
                                <span class="input-group-text fw-bold">KG</span>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary small text-uppercase">Price Per KG <span class="text-muted">(editable)</span></label>
                            <div class="input-group">
                                <span class="input-group-text text-primary"><i class="bi bi-tag-fill"></i></span>
                                <input type="number" step="0.01" min="0.01"
                                       class="form-control fw-bold fs-5"
                                       id="approvePricePerKg"
                                       name="pricePerKg"
                                       value="@Model.DefaultPricePerKg"
                                       oninput="calculateTotal()" required />
                                <span class="input-group-text">ETB</span>
                            </div>
                            <div class="form-text"><i class="bi bi-info-circle me-1"></i>Default: <strong>@Model.DefaultPricePerKg ETB/KG</strong></div>
                        </div>
                        <div class="total-display p-3 text-center">
                            <div class="small opacity-75 mb-1">TOTAL PRICE</div>
                            <div class="fs-3 fw-bold" id="approveTotalDisplay">0.00 <span class="fs-5">ETB</span></div>
                            <input type="hidden" name="totalPrice" id="approveTotal" />
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 fw-bold">
                            <i class="bi bi-check-circle me-1"></i>Confirm &amp; Approve
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-0">
                <div id="imageCarousel" class="carousel slide">
                    <div class="carousel-inner" id="carouselInner"></div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#imageCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#imageCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var defaultPrice = @Model.DefaultPricePerKg;

        function switchTab(tab) {
            document.getElementById('pane-pending').style.display  = tab === 'pending'  ? 'block' : 'none';
            document.getElementById('pane-history').style.display  = tab === 'history'  ? 'block' : 'none';
            document.getElementById('tab-pending').className = tab === 'pending'
                ? 'btn tab-pill active btn-primary' : 'btn tab-pill btn-outline-primary';
            document.getElementById('tab-history').className = tab === 'history'
                ? 'btn tab-pill active btn-secondary' : 'btn tab-pill btn-outline-secondary';
        }

        function openApproveModal(id, type, kg, wereda, driver) {
            document.getElementById('approveId').value  = id;
            document.getElementById('approveType').value = type;
            document.getElementById('approveKg').value  = kg;
            document.getElementById('approvePricePerKg').value = defaultPrice;
            document.getElementById('infoWereda').textContent  = wereda;
            document.getElementById('infoDriver').textContent  = driver;
            calculateTotal();
            new bootstrap.Modal(document.getElementById('approveModal')).show();
        }

        function calculateTotal() {
            var kg    = parseFloat(document.getElementById('approveKg').value) || 0;
            var price = parseFloat(document.getElementById('approvePricePerKg').value) || 0;
            var total = kg * price;
            document.getElementById('approveTotal').value = total.toFixed(2);
            document.getElementById('approveTotalDisplay').innerHTML =
                total.toFixed(2) + ' <span class="fs-5">ETB</span>';
        }

        function showImages(imageUrls, startIndex) {
            const urls  = imageUrls.split(',').map(u => u.trim()).filter(u => u.length > 0);
            const inner = document.getElementById('carouselInner');
            inner.innerHTML = '';
            urls.forEach((url, index) => {
                inner.innerHTML += `<div class="carousel-item ${index === startIndex ? 'active' : ''}">
                    <img src="${url}" class="d-block w-100 rounded shadow"
                         style="max-height:80vh;object-fit:contain"
                         onerror="this.src='/images/placeholder.png'" />
                </div>`;
            });
            const controls = document.querySelectorAll('.carousel-control-prev, .carousel-control-next');
            controls.forEach(c => c.style.display = urls.length > 1 ? '' : 'none');
        }

        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('tab') === 'history') switchTab('history');
    </script>
}
