                </a>
            </li>
        </ul>
    </nav>
</div>

<!-- Auto-close sidebar dropdowns when clicking other links -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ── Rotate chevron arrows on collapse open/close ─────────────────────
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(btn) {
            var targetId = btn.getAttribute('data-bs-target');
            var collapseEl = document.querySelector(targetId);
            if (!collapseEl) return;
            var arrow = btn.querySelector('.bi-chevron-down');

            collapseEl.addEventListener('show.bs.collapse', function() {
                if (arrow) arrow.style.transform = 'rotate(-180deg)';
            });
            collapseEl.addEventListener('hide.bs.collapse', function() {
                if (arrow) arrow.style.transform = 'rotate(0deg)';
            });
        });

        // ── Auto-close other dropdowns when opening one ───────────────────────
        const navLinks = document.querySelectorAll('.sidebar .nav-link:not([data-bs-toggle="collapse"])');
        navLinks.forEach(link => {
            link.addEventListener('click', function() {
                const collapses = document.querySelectorAll('.sidebar .collapse.show');
                collapses.forEach(c => {
                    if (!c.contains(link)) {
                        var bsCollapse = bootstrap.Collapse.getInstance(c);
                        if (bsCollapse) bsCollapse.hide();
                    }
                });
            });
        });
    });

    // Sidebar collapse/expand
    (function(){
        var collapsed = localStorage.getItem('sidebarCollapsed')==='1';
        if(collapsed) _applyCollapse(true);
        function _applyCollapse(c){
            var b=document.body, ic=document.getElementById('sidebarToggleIcon');
            c ? b.classList.add('sidebar-collapsed') : b.classList.remove('sidebar-collapsed');
            if(ic){ ic.className = c ? 'bi bi-chevron-right' : 'bi bi-chevron-left'; }
        }
        window.toggleSidebarCollapse=function(){
            var c=!document.body.classList.contains('sidebar-collapsed');
            _applyCollapse(c); localStorage.setItem('sidebarCollapsed',c?'1':'0');
        };
    })();
</script>
