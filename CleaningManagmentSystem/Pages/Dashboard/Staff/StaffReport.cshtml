@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.StaffReportModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Staff Report";

    string SBadge(string s) => s switch {
        "Approved" or "Billed" => "bg-success",
        "Paid"                 => "bg-primary",
        "Pending"              => "bg-warning text-dark",
        "Registered"           => "bg-info text-dark",
        "Rejected"             => "bg-danger",
        _                      => "bg-secondary"
    };
}

<style>
    .chart-box  { height:200px; position:relative; }
    .sheet { background:#fff; border:1px solid #dee2e6; border-radius:8px; padding:28px 32px; }
    .sheet table { width:100%; border-collapse:collapse; font-size:.82rem; }
    .sheet thead tr { background:#1a1a2e; color:#fff; }
    .sheet thead th { padding:8px 10px; font-weight:600; }
    .sheet tbody tr:nth-child(even) { background:#f8f9fa; }
    .sheet tbody td { padding:6px 10px; border-bottom:1px solid #f1f1f1; vertical-align:middle; }
    .sheet tfoot td { padding:8px 10px; font-weight:700; background:#e9ecef; }
    .grp-hdr { background:#e8edf5!important; font-weight:700; font-size:.78rem;
               letter-spacing:.04em; text-transform:uppercase; color:#1a1a2e; }
    @@media print {
        .no-print { display:none!important; }
        .sheet { border:none; padding:0; }
    }
</style>

<div class="main-content p-3 p-md-4">
<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2 no-print">
        <div>
            <h2 class="h4 mb-1 fw-bold">
                <i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>Staff Report
            </h2>
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/Dashboard/Staff/Index">Dashboard</a></li>
                <li class="breadcrumb-item active">Staff Report</li>
            </ol>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Print
            </button>
            <form method="post" asp-page-handler="ExportCsv" class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="FilterStatus"    value="@Model.FilterStatus" />
                <input type="hidden" name="FilterStartDate" value="@Model.FilterStartDate" />
                <input type="hidden" name="FilterEndDate"   value="@Model.FilterEndDate" />
                <input type="hidden" name="FilterWeredaId"  value="@(Model.FilterWeredaId ?? 0)" />
                <input type="hidden" name="FilterDriverId"  value="@(Model.FilterDriverId ?? 0)" />
                <input type="hidden" name="GroupBy"         value="@Model.GroupBy" />
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="bi bi-download me-1"></i>Export CSV
                </button>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
        </div>
    }

    <!-- ════ FILTER BAR ════════════════════════════════════════════════════ -->
    <div class="card border-0 shadow-sm rounded-4 mb-4 no-print">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Status</label>
                    <select name="FilterStatus" class="form-select form-select-sm">
                        <option value=""          >@(string.IsNullOrEmpty(Model.FilterStatus) ? "✓ " : "")All Statuses</option>
                        <option value="Pending"   >@(Model.FilterStatus=="Pending"    ? "✓ " : "")Pending</option>
                        <option value="Registered">@(Model.FilterStatus=="Registered" ? "✓ " : "")Registered</option>
                        <option value="Approved"  >@(Model.FilterStatus=="Approved"   ? "✓ " : "")Approved</option>
                        <option value="Billed"    >@(Model.FilterStatus=="Billed"     ? "✓ " : "")Billed</option>
                        <option value="Paid"      >@(Model.FilterStatus=="Paid"       ? "✓ " : "")Paid</option>
                        <option value="Rejected"  >@(Model.FilterStatus=="Rejected"   ? "✓ " : "")Rejected</option>
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Wereda</label>
                    <select name="FilterWeredaId" class="form-select form-select-sm">
                        <option value="">All Weredas</option>
                        @foreach (var w in Model.Weredas)
                        {
                            var wid = (int)w.id;
                            <option value="@wid">@(Model.FilterWeredaId == wid ? "✓ " : "")@w.name</option>
                        }
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold mb-1">Driver</label>
                    <select name="FilterDriverId" class="form-select form-select-sm">
                        <option value="">All Drivers</option>
                        @foreach (var d in Model.Drivers)
                        {
                            var did = (int)d.id;
                            <option value="@did">@(Model.FilterDriverId == did ? "✓ " : "")@d.name</option>
                        }
                    </select>
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small fw-semibold mb-1">From</label>
                    <input type="date" name="FilterStartDate" class="form-control form-control-sm"
                           value="@Model.FilterStartDate" />
                </div>

                <div class="col-6 col-md-1">
                    <label class="form-label small fw-semibold mb-1">To</label>
                    <input type="date" name="FilterEndDate" class="form-control form-control-sm"
                           value="@Model.FilterEndDate" />
                </div>

                <div class="col-12 col-md-3 d-flex gap-1 mt-1">
                    <button type="submit" class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-search me-1"></i>Show Report
                    </button>
                    <a href="/Dashboard/Staff/StaffReport" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- ════ STAT CARDS ════════════════════════════════════════════════════ -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalReceipts</div>
                <div class="small text-muted">Total Receipts</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-3 fw-bold text-info">@Model.TotalKg.ToString("N1")</div>
                <div class="small text-muted">Total KG</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-3 fw-bold text-success">@Model.TotalAmount.ToString("N0")</div>
                <div class="small text-muted">Total ETB</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-warning">@Model.TotalPending</div>
                <div class="small text-muted">Pending</div>
            </div>
        </div>
    </div>

    <!-- ════ CHARTS ════════════════════════════════════════════════════════ -->
    @if (Model.ChartLabels.Any())
    {
        <div class="row g-3 mb-4 no-print">
            <div class="col-md-7">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0 small">
                        <i class="bi bi-bar-chart-line me-1 text-info"></i>Daily KG — @Model.FilterStartDate to @Model.FilterEndDate
                    </div>
                    <div class="card-body"><div class="chart-box"><canvas id="chartKg"></canvas></div></div>
                </div>
            </div>
            <div class="col-md-5">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0 small">
                        <i class="bi bi-people me-1 text-primary"></i>Top Drivers by KG
                    </div>
                    <div class="card-body"><div class="chart-box"><canvas id="chartDrivers"></canvas></div></div>
                </div>
            </div>
        </div>
    }

    <!-- ════ PER-STAFF SUMMARY TABLE ═══════════════════════════════════════ -->
    @if (Model.StaffSummary.Any())
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0">
                <i class="bi bi-people me-1 text-primary"></i>Staff Performance Summary
                <span class="badge bg-secondary ms-1">@Model.StaffSummary.Count drivers</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.83rem">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Driver Name</th>
                            <th>Weredas Covered</th>
                            <th class="text-center">Receipts</th>
                            <th class="text-end">Total KG</th>
                            <th class="text-end">Total ETB</th>
                            <th class="text-center">Approved</th>
                            <th class="text-center">Pending</th>
                            <th class="text-center">Rejected</th>
                            <th>Last Receipt</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{ int sn = 0; }
                    @foreach (var s in Model.StaffSummary)
                    {
                        sn++;
                        <tr>
                            <td class="text-muted">@sn</td>
                            <td class="fw-semibold">@s.DriverName</td>
                            <td class="small text-muted">@(string.IsNullOrEmpty(s.Weredas) ? "—" : s.Weredas)</td>
                            <td class="text-center"><span class="badge bg-primary">@s.TotalReceipts</span></td>
                            <td class="text-end fw-semibold">@s.TotalKg.ToString("N1")</td>
                            <td class="text-end text-success fw-bold">@s.TotalAmount.ToString("N0")</td>
                            <td class="text-center">
                                @if (s.Approved > 0) { <span class="badge bg-success">@s.Approved</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                @if (s.Pending > 0) { <span class="badge bg-warning text-dark">@s.Pending</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                @if (s.Rejected > 0) { <span class="badge bg-danger">@s.Rejected</span> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="small text-muted">@s.LastDate</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="4" class="text-end">Totals:</td>
                            <td class="text-end">@Model.TotalKg.ToString("N1") kg</td>
                            <td class="text-end text-success">@Model.TotalAmount.ToString("N0")</td>
                            <td class="text-center">@Model.TotalApproved</td>
                            <td class="text-center">@Model.TotalPending</td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    <!-- ════ DETAILED RECEIPTS ══════════════════════════════════════════════ -->
    <div class="sheet shadow-sm">

        <!-- Sheet header -->
        <div class="d-flex justify-content-between align-items-start pb-3 mb-3 border-bottom flex-wrap gap-2">
            <div>
                <div class="fw-bold text-uppercase" style="font-size:.95rem;letter-spacing:.05em">
                    YEKA CLEANING — STAFF RECEIPTS REPORT
                </div>
                <div class="text-muted small mt-1">
                    Status: <strong>@(string.IsNullOrEmpty(Model.FilterStatus) ? "All" : Model.FilterStatus)</strong> ·
                    Period: <strong>@Model.FilterStartDate to @Model.FilterEndDate</strong> ·
                    Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")
                </div>
            </div>
            <div class="text-end small text-muted">
                <div>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
                <div>Total: <strong>@Model.TotalReceipts receipts</strong></div>
            </div>
        </div>

        @if (!Model.Receipts.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                No receipts found. Adjust filters and click <strong>Show Report</strong>.
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Driver</th>
                        <th>Wereda</th>
                        <th>Mahberat</th>
                        <th>Plate</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th style="text-align:right">KG</th>
                        <th style="text-align:right">Rate</th>
                        <th style="text-align:right">Total ETB</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Receipts)
                {
                    <tr>
                        <td class="text-muted">@(Model.Receipts.IndexOf(r) + 1)</td>
                        <td class="fw-semibold">@(string.IsNullOrEmpty(r.DriverName) ? "—" : r.DriverName)</td>
                        <td>@(string.IsNullOrEmpty(r.WeredaName)  ? "—" : r.WeredaName)</td>
                        <td>@(string.IsNullOrEmpty(r.EntityName)  ? "—" : r.EntityName)</td>
                        <td><code style="font-size:.75rem">@(string.IsNullOrEmpty(r.PlateName) ? "—" : r.PlateName)</code></td>
                        <td>@r.ReceiptDate</td>
                        <td style="color:#999;font-size:.75rem">@r.ReceiptTime</td>
                        <td style="text-align:right;font-weight:600">@r.Kilogram.ToString("N1")</td>
                        <td style="text-align:right;color:#666">@r.Price.ToString("N2")</td>
                        <td style="text-align:right;font-weight:700;color:#198754">@r.Total.ToString("N2")</td>
                        <td><span class="badge @SBadge(r.Status)" style="font-size:.7rem">@r.Status</span></td>
                    </tr>
                }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="7" style="text-align:right">GRAND TOTAL (@Model.TotalReceipts receipts):</td>
                        <td style="text-align:right">@Model.TotalKg.ToString("N1") kg</td>
                        <td></td>
                        <td style="text-align:right;color:#198754">@Model.TotalAmount.ToString("N2") ETB</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        }
    </div>

</div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var labels     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
var kgVals     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartKg));
var driverNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDriverNames));
var driverKg   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopDriverKg));

function mkBar(id, lbl, color, lbs, data) {
    var ctx = document.getElementById(id);
    if (!ctx || !data.length) return;
    new Chart(ctx, {
        type: 'bar',
        data: { labels: lbs, datasets: [{ label: lbl, data: data,
            backgroundColor: color + '88', borderColor: color,
            borderWidth: 1.5, borderRadius: 4 }] },
        options: { responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { x: { ticks: { font: { size: 9 }, maxRotation: 45 } },
                      y: { beginAtZero: true, ticks: { font: { size: 9 } } } } }
    });
}

mkBar('chartKg',      'KG', '#0dcaf0', labels,      kgVals);
mkBar('chartDrivers', 'KG', '#0d6efd', driverNames, driverKg);
</script>
}
