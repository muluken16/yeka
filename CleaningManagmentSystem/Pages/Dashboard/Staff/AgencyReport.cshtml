@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.AgencyReportModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Receipts Report";

    string TypeBadge(string t) => t switch {
        "Outsource" => "bg-purple",
        "Private"   => "bg-info text-dark",
        _           => "bg-primary"
    };
    string StatusBadge(string s) => s switch {
        "Approved" or "Billed" => "bg-success",
        "Paid"                 => "bg-primary",
        "Pending"              => "bg-warning text-dark",
        "Registered"           => "bg-info text-dark",
        "Rejected"             => "bg-danger",
        _                      => "bg-secondary"
    };

    // Group data for the printable view
    var grouped = Model.Receipts
        .GroupBy(r => Model.GroupBy == "type"     ? r.ReceiptType
                    : Model.GroupBy == "status"   ? r.Status
                    : Model.GroupBy == "mahberat" ? r.EntityName
                    : r.WeredaName)
        .OrderBy(g => g.Key)
        .ToList();
}

<style>
    .bg-purple { background-color:#6f42c1!important; color:#fff!important; }
    .chart-box { height:200px; position:relative; }
    .stat-card  { border-radius:14px; border:none; }
    .print-sheet { background:#fff; border:1px solid #dee2e6; border-radius:8px; padding:32px 36px; }
    .print-sheet table { width:100%; border-collapse:collapse; font-size:.82rem; }
    .print-sheet thead tr { background:#1a1a2e; color:#fff; }
    .print-sheet thead th { padding:8px 10px; font-weight:600; }
    .print-sheet tbody tr:nth-child(even) { background:#f8f9fa; }
    .print-sheet tbody td { padding:6px 10px; border-bottom:1px solid #f0f0f0; }
    .print-sheet tfoot td { padding:8px 10px; font-weight:700; background:#e9ecef; }
    .group-header { background:#e8edf5!important; font-weight:700; font-size:.8rem;
                    letter-spacing:.04em; text-transform:uppercase; color:#1a1a2e; }
    @@media print {
        .no-print { display:none!important; }
        .print-sheet { border:none; padding:0; }
        body { background:#fff!important; }
    }
</style>

<div class="main-content p-3 p-md-4">
    <div class="container-fluid">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2 no-print">
            <div>
                <h2 class="h4 mb-1 fw-bold">
                    <i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>Receipts Report
                </h2>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0 small">
                        <li class="breadcrumb-item"><a href="/Dashboard/Staff/Index">Dashboard</a></li>
                        <li class="breadcrumb-item active">Receipts Report</li>
                    </ol>
                </nav>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                    <i class="bi bi-printer me-1"></i>Print
                </button>
                <form method="post" asp-page-handler="ExportCsv" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="FilterType"       value="@Model.FilterType" />
                    <input type="hidden" name="FilterStatus"     value="@Model.FilterStatus" />
                    <input type="hidden" name="FilterStartDate"  value="@Model.FilterStartDate" />
                    <input type="hidden" name="FilterEndDate"    value="@Model.FilterEndDate" />
                    <input type="hidden" name="FilterWeredaId"   value="@(Model.FilterWeredaId ?? 0)" />
                    <input type="hidden" name="FilterMahberatId" value="@(Model.FilterMahberatId ?? 0)" />
                    <input type="hidden" name="GroupBy"          value="@Model.GroupBy" />
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="bi bi-download me-1"></i>Export CSV
                    </button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger py-2">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
            </div>
        }

        <!-- ════ FILTER BAR ════════════════════════════════════════════════ -->
        <div class="card border-0 shadow-sm rounded-4 mb-4 no-print">
            <div class="card-body py-3">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-6 col-sm-4 col-md-2">
                        <label class="form-label small fw-semibold mb-1">Type</label>
                        <select name="FilterType" class="form-select form-select-sm">
                            <option value="All">All Types</option>
                            <option value="Mahberat" >@(Model.FilterType=="Mahberat"  ? "✓ " : "")Mahberat</option>
                            <option value="Outsource">@(Model.FilterType=="Outsource" ? "✓ " : "")Outsource</option>
                            <option value="Private"  >@(Model.FilterType=="Private"   ? "✓ " : "")Private</option>
                        </select>
                    </div>
                    <div class="col-6 col-sm-4 col-md-2">
                        <label class="form-label small fw-semibold mb-1">Status</label>
                        <select name="FilterStatus" class="form-select form-select-sm">
                            <option value="">All Statuses</option>
                            <option value="Pending"   >@(Model.FilterStatus=="Pending"    ? "✓ " : "")Pending</option>
                            <option value="Registered">@(Model.FilterStatus=="Registered" ? "✓ " : "")Registered</option>
                            <option value="Approved"  >@(Model.FilterStatus=="Approved"   ? "✓ " : "")Approved</option>
                            <option value="Billed"    >@(Model.FilterStatus=="Billed"     ? "✓ " : "")Billed</option>
                            <option value="Paid"      >@(Model.FilterStatus=="Paid"       ? "✓ " : "")Paid</option>
                            <option value="Rejected"  >@(Model.FilterStatus=="Rejected"   ? "✓ " : "")Rejected</option>
                        </select>
                    </div>
                    <div class="col-6 col-sm-4 col-md-2">
                        <label class="form-label small fw-semibold mb-1">Wereda</label>
                        <select name="FilterWeredaId" class="form-select form-select-sm">
                            <option value="">All Weredas</option>
                            @foreach (var w in Model.Weredas)
                            {
                                var wid = (int)w.id;
                                <option value="@wid">@(Model.FilterWeredaId == wid ? "✓ " : "")@w.name</option>
                            }
                        </select>
                    </div>
                    <div class="col-6 col-sm-4 col-md-2">
                        <label class="form-label small fw-semibold mb-1">Mahberat</label>
                        <select name="FilterMahberatId" class="form-select form-select-sm">
                            <option value="">All Mahberats</option>
                            @foreach (var m in Model.Mahberats)
                            {
                                var mid = (int)m.id;
                                <option value="@mid">@(Model.FilterMahberatId == mid ? "✓ " : "")@m.name</option>
                            }
                        </select>
                    </div>
                    <div class="col-6 col-sm-4 col-md-1">
                        <label class="form-label small fw-semibold mb-1">From</label>
                        <input type="date" name="FilterStartDate" class="form-control form-control-sm"
                               value="@Model.FilterStartDate" />
                    </div>
                    <div class="col-6 col-sm-4 col-md-1">
                        <label class="form-label small fw-semibold mb-1">To</label>
                        <input type="date" name="FilterEndDate" class="form-control form-control-sm"
                               value="@Model.FilterEndDate" />
                    </div>
                    <div class="col-6 col-sm-4 col-md-1">
                        <label class="form-label small fw-semibold mb-1">Group By</label>
                        <select name="GroupBy" class="form-select form-select-sm">
                            <option value="wereda"   >@(Model.GroupBy=="wereda"   ? "✓ " : "")Wereda</option>
                            <option value="mahberat" >@(Model.GroupBy=="mahberat" ? "✓ " : "")Mahberat</option>
                            <option value="type"     >@(Model.GroupBy=="type"     ? "✓ " : "")Type</option>
                            <option value="status"   >@(Model.GroupBy=="status"   ? "✓ " : "")Status</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-1 d-flex gap-1">
                        <button type="submit" class="btn btn-primary btn-sm flex-fill">
                            <i class="bi bi-funnel"></i>
                        </button>
                        <a href="/Dashboard/Staff/AgencyReport" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-x"></i>
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- ════ STAT CARDS ════════════════════════════════════════════════ -->
        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-primary text-white shadow-sm text-center py-3">
                    <div class="fs-2 fw-bold">@Model.TotalCount</div>
                    <div class="small opacity-75">Total Receipts</div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-info text-dark shadow-sm text-center py-3">
                    <div class="fs-3 fw-bold">@Model.TotalKg.ToString("N1")</div>
                    <div class="small opacity-75">Total KG</div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-success text-white shadow-sm text-center py-3">
                    <div class="fs-3 fw-bold">@Model.TotalAmount.ToString("N0")</div>
                    <div class="small opacity-75">Total ETB</div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-warning text-dark shadow-sm text-center py-3">
                    <div class="fs-2 fw-bold">@Model.TotalPending</div>
                    <div class="small opacity-75">Pending</div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-success text-white shadow-sm text-center py-3" style="opacity:.8">
                    <div class="fs-2 fw-bold">@(Model.TotalApproved + Model.TotalPaid)</div>
                    <div class="small opacity-75">Approved/Paid</div>
                </div>
            </div>
            <div class="col-6 col-lg-2">
                <div class="card stat-card bg-danger text-white shadow-sm text-center py-3">
                    <div class="fs-2 fw-bold">@Model.TotalRejected</div>
                    <div class="small opacity-75">Rejected</div>
                </div>
            </div>
        </div>

        <!-- ════ CHARTS ════════════════════════════════════════════════════ -->
        @if (Model.ChartLabels.Any())
        {
            <div class="row g-3 mb-4 no-print">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0">
                            <i class="bi bi-bar-chart-line me-1 text-info"></i>Daily KG Collected
                        </div>
                        <div class="card-body"><div class="chart-box"><canvas id="chartKg"></canvas></div></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4">
                        <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0">
                            <i class="bi bi-cash-stack me-1 text-success"></i>Daily Amount (ETB)
                        </div>
                        <div class="card-body"><div class="chart-box"><canvas id="chartAmt"></canvas></div></div>
                    </div>
                </div>
            </div>
        }

        <!-- ════ PRINTABLE REPORT SHEET ════════════════════════════════════ -->
        <div class="print-sheet shadow-sm">

            <!-- Report Header (print-friendly) -->
            <div class="d-flex justify-content-between align-items-start mb-3 pb-3 border-bottom">
                <div>
                    <div class="fw-bold fs-5 text-uppercase">YEKA CLEANING MANAGEMENT SYSTEM</div>
                    <div class="small text-muted mt-1">
                        Receipts Report · @Model.FilterType ·
                        @Model.FilterStartDate to @Model.FilterEndDate ·
                        Generated: @DateTime.Now.ToString("dd MMM yyyy HH:mm")
                    </div>
                </div>
                <div class="text-end">
                    <div class="small text-muted">Grouped by: <strong>@Model.GroupBy.ToUpper()</strong></div>
                    <div class="small text-muted">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
                </div>
            </div>

            @if (!Model.Receipts.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                    No receipts found for the selected filters.
                </div>
            }
            else
            {
                <!-- Grouped table -->
                <table>
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Type</th>
                            <th>Wereda</th>
                            <th>Mahberat / Company</th>
                            <th>Driver</th>
                            <th>Plate</th>
                            <th>Date</th>
                            <th style="text-align:right">KG</th>
                            <th style="text-align:right">Rate</th>
                            <th style="text-align:right">Total (ETB)</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @{ int globalRow = 0; }
                    @foreach (var grp in grouped)
                    {
                        var grpKg  = grp.Sum(r => r.Kilogram);
                        var grpAmt = grp.Sum(r => r.Total);

                        <!-- Group header row -->
                        <tr class="group-header">
                            <td colspan="7">
                                <i class="bi bi-folder2-open me-1"></i>@grp.Key
                                <span style="font-weight:400;margin-left:8px;opacity:.65">@grp.Count() receipts</span>
                            </td>
                            <td style="text-align:right">@grpKg.ToString("N1") kg</td>
                            <td></td>
                            <td style="text-align:right">@grpAmt.ToString("N2")</td>
                            <td></td>
                        </tr>

                        @foreach (var r in grp)
                        {
                            globalRow++;
                            <tr>
                                <td class="text-muted">@globalRow</td>
                                <td>
                                    <span class="badge @TypeBadge(r.ReceiptType)" style="font-size:.7rem">@r.ReceiptType</span>
                                </td>
                                <td>@(string.IsNullOrEmpty(r.WeredaName) ? "—" : r.WeredaName)</td>
                                <td style="font-weight:600">@(string.IsNullOrEmpty(r.EntityName) ? "—" : r.EntityName)</td>
                                <td>@(string.IsNullOrEmpty(r.DriverName) ? "—" : r.DriverName)</td>
                                <td><code style="font-size:.75rem">@(string.IsNullOrEmpty(r.PlateName) ? "—" : r.PlateName)</code></td>
                                <td>@r.ReceiptDate <span style="color:#999;font-size:.75rem">@r.ReceiptTime</span></td>
                                <td style="text-align:right;font-weight:600">@r.Kilogram.ToString("N1")</td>
                                <td style="text-align:right;color:#666">@r.Price.ToString("N2")</td>
                                <td style="text-align:right;font-weight:700;color:#198754">@r.Total.ToString("N2")</td>
                                <td>
                                    <span class="badge @StatusBadge(r.Status)" style="font-size:.7rem">@r.Status</span>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="7" style="text-align:right">GRAND TOTAL (@Model.TotalCount receipts):</td>
                            <td style="text-align:right">@Model.TotalKg.ToString("N1") kg</td>
                            <td></td>
                            <td style="text-align:right;color:#198754">@Model.TotalAmount.ToString("N2") ETB</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>

                <!-- Summary breakdown below the table -->
                <div class="row g-3 mt-4 no-print">
                    <div class="col-md-6">
                        <table style="width:100%;font-size:.82rem;border-collapse:collapse">
                            <thead><tr style="background:#1a1a2e;color:#fff">
                                <th style="padding:7px 10px">Group (@Model.GroupBy)</th>
                                <th style="padding:7px 10px;text-align:center">Count</th>
                                <th style="padding:7px 10px;text-align:right">KG</th>
                                <th style="padding:7px 10px;text-align:right">ETB</th>
                            </tr></thead>
                            <tbody>
                            @foreach (var grp in grouped)
                            {
                                <tr style="border-bottom:1px solid #f0f0f0">
                                    <td style="padding:5px 10px;font-weight:600">@grp.Key</td>
                                    <td style="padding:5px 10px;text-align:center">@grp.Count()</td>
                                    <td style="padding:5px 10px;text-align:right">@grp.Sum(r => r.Kilogram).ToString("N1")</td>
                                    <td style="padding:5px 10px;text-align:right;font-weight:600;color:#198754">@grp.Sum(r => r.Total).ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table style="width:100%;font-size:.82rem;border-collapse:collapse">
                            <thead><tr style="background:#1a1a2e;color:#fff">
                                <th style="padding:7px 10px">Status</th>
                                <th style="padding:7px 10px;text-align:center">Count</th>
                                <th style="padding:7px 10px;text-align:right">KG</th>
                                <th style="padding:7px 10px;text-align:right">ETB</th>
                            </tr></thead>
                            <tbody>
                            @foreach (var sg in Model.Receipts.GroupBy(r => r.Status).OrderByDescending(g => g.Count()))
                            {
                                <tr style="border-bottom:1px solid #f0f0f0">
                                    <td style="padding:5px 10px">
                                        <span class="badge @StatusBadge(sg.Key)" style="font-size:.7rem">@sg.Key</span>
                                    </td>
                                    <td style="padding:5px 10px;text-align:center">@sg.Count()</td>
                                    <td style="padding:5px 10px;text-align:right">@sg.Sum(r => r.Kilogram).ToString("N1")</td>
                                    <td style="padding:5px 10px;text-align:right;font-weight:600">@sg.Sum(r => r.Total).ToString("N2")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var labels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
var kgVals  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartKg));
var amtVals = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartAmount));

function mkChart(id, label, color, data) {
    var ctx = document.getElementById(id);
    if (!ctx || data.length === 0) return;
    new Chart(ctx, {
        type: 'bar',
        data: { labels: labels, datasets: [{ label: label, data: data,
            backgroundColor: color + '88', borderColor: color,
            borderWidth:1.5, borderRadius:4 }] },
        options: { responsive:true, maintainAspectRatio:false,
            plugins:{ legend:{display:false} },
            scales:{ x:{ticks:{font:{size:9},maxRotation:50}},
                     y:{beginAtZero:true,ticks:{font:{size:9}}} } }
    });
}
mkChart('chartKg',  'KG',  '#0dcaf0', kgVals);
mkChart('chartAmt', 'ETB', '#198754', amtVals);
</script>
}
