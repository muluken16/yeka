@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.PostModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Posts & Announcements";
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }
}
@section Styles {
<style>
.post-card { transition: transform .2s, box-shadow .2s; }
.post-card:hover { transform: translateY(-3px); box-shadow: 0 .75rem 1.5rem rgba(0,0,0,.1) !important; }
.pinned-card { border-left: 4px solid #ef4444 !important; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-postcard text-primary me-2"></i>Announcements &amp; Posts</h4>
        <p class="text-muted small mb-0">@Model.Posts?.Count post@(Model.Posts?.Count == 1 ? "" : "s") available</p>
    </div>
</div>

<div class="row g-4">
    @if (Model.Posts != null && Model.Posts.Any())
    {
        @foreach (var post in Model.Posts)
        {
            var catClass = post.Category switch {
                "Notice"       => "bg-primary text-white",
                "Blog"         => "bg-success text-white",
                "Training"     => "bg-info text-dark",
                "Announcement" => "bg-warning text-dark",
                "Policy"       => "bg-dark text-white",
                _              => "bg-secondary text-white"
            };
            var prClass = post.Priority switch {
                "High"   => "bg-danger text-white",
                "Medium" => "bg-warning text-dark",
                _        => "bg-info text-dark"
            };
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0 position-relative post-card @(post.IsPinned ? "pinned-card" : "")">
                    @if (post.IsPinned) {
                        <div class="position-absolute top-0 end-0 p-2">
                            <span class="badge bg-danger"><i class="bi bi-pin-angle-fill me-1"></i>Pinned</span>
                        </div>
                    }
                    <div class="card-body pb-0">
                        <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                            <span class="badge @catClass" style="font-size:.73rem">@post.Category</span>
                            <span class="badge @prClass" style="font-size:.73rem">@post.Priority</span>
                            @if (post.TrainingId.HasValue) {
                                <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:.7rem">
                                    <i class="bi bi-mortarboard me-1"></i>Training
                                </span>
                            }
                        </div>
                        <h5 class="card-title fw-bold mb-2 @(post.IsPinned ? "pe-5" : "")">@post.Title</h5>
                        <p class="card-text text-muted" style="font-size:.88rem;line-height:1.6">
                            @(post.Content.Length > 120 ? post.Content[..117] + "…" : post.Content)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                            <small class="text-muted"><i class="bi bi-calendar-event me-1"></i>@post.CreatedAt?.ToString("MMM dd, yyyy")</small>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-2 pb-3">
                        <button class="btn btn-sm btn-outline-primary w-100 fw-semibold btn-view-post"
                                data-title="@post.Title" data-category="@post.Category"
                                data-priority="@post.Priority" data-content="@post.Content"
                                data-date="@post.CreatedAt?.ToString("MMM dd, yyyy")"
                                data-trainingid="@(post.TrainingId?.ToString() ?? "")">
                            <i class="bi bi-book-half me-1"></i>Read More
                        </button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-inbox display-4 d-block mb-3 opacity-25"></i>
            <h5>No announcements yet</h5>
            <p class="small">Check back later for updates.</p>
        </div>
    }
</div>

<!-- View Post Modal -->
<div class="modal fade" id="viewPostModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalPostTitle"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex gap-2 mb-3 align-items-center">
                    <span class="badge bg-primary" id="modalPostCategory"></span>
                    <span class="badge" id="modalPostPriority"></span>
                    <small class="text-muted ms-auto"><i class="bi bi-calendar-event me-1"></i><span id="modalPostDate"></span></small>
                </div>
                <div class="card border-info bg-info bg-opacity-10 mb-3 d-none" id="modalTrainingCard">
                    <div class="card-body py-2 d-flex align-items-center justify-content-between">
                        <div>
                            <h6 class="fw-bold text-info mb-0"><i class="bi bi-mortarboard-fill me-2"></i>Linked Training Program</h6>
                            <small class="text-muted">This post is linked to a training course.</small>
                        </div>
                        <a href="/Dashboard/Staff/Training" class="btn btn-info btn-sm text-white fw-bold">View</a>
                    </div>
                </div>
                <div class="text-dark" style="font-size:1rem;white-space:pre-line" id="modalPostContent"></div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.btn-view-post').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.getElementById('modalPostTitle').textContent    = this.dataset.title;
        document.getElementById('modalPostCategory').textContent = this.dataset.category;
        document.getElementById('modalPostContent').textContent  = this.dataset.content;
        document.getElementById('modalPostDate').textContent     = this.dataset.date;
        var pb = document.getElementById('modalPostPriority');
        pb.textContent = this.dataset.priority;
        pb.className = 'badge ' + (this.dataset.priority === 'High' ? 'bg-danger text-white' :
                                    this.dataset.priority === 'Medium' ? 'bg-warning text-dark' : 'bg-info text-dark');
        document.getElementById('modalTrainingCard').classList.toggle('d-none', !this.dataset.trainingid);
        new bootstrap.Modal(document.getElementById('viewPostModal')).show();
    });
});
</script>
}
