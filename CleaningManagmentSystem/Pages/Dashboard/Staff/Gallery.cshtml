@page
@model CleaningManagmentSystem.Pages.Dashboard.Staff.GalleryModel
@{
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
    ViewData["Title"] = "Photo Gallery";
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }
}

<style>
    .gal-card { border-radius:14px; border:1px solid #e8ecf0; overflow:hidden;
                transition:all .2s; background:#fff; }
    .gal-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.1); transform:translateY(-2px); }
    .gal-img { height:180px; overflow:hidden; position:relative; background:#f0f4f8; }
    .gal-img img { width:100%; height:100%; object-fit:cover; transition:transform .3s; display:block; }
    .gal-card:hover .gal-img img { transform:scale(1.05); }
    .gal-img .no-img { width:100%; height:100%; display:flex; align-items:center;
                       justify-content:center; color:#adb5bd; font-size:2.5rem; }
    .published-badge { position:absolute; top:8px; right:8px; }
    .gal-body { padding:12px 14px 14px; }
</style>

<div class="main-content p-3 p-md-4">
<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start pt-2 pb-3 mb-4 border-bottom flex-wrap gap-2">
        <div>
            <h2 class="h4 fw-bold mb-0"><i class="bi bi-images me-2 text-primary"></i>Photo Gallery</h2>
            <small class="text-muted">Manage photos · publish to public home page</small>
        </div>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAdd">
            <i class="bi bi-plus-circle me-1"></i>Add Photo
        </button>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show py-2">
            <i class="bi bi-check-circle-fill me-1"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-4 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalPhotos</div>
                <div class="small text-muted">Total Photos</div>
            </div>
        </div>
        <div class="col-4 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-success">@Model.PublishedPhotos</div>
                <div class="small text-muted">
                    <i class="bi bi-globe me-1"></i>Published
                </div>
            </div>
        </div>
        <div class="col-4 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3">
                <div class="fs-2 fw-bold text-info">@(Model.TotalPhotos - Model.PublishedPhotos)</div>
                <div class="small text-muted">Unpublished</div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 p-3 d-flex align-items-center gap-2">
                <i class="bi bi-eye text-warning fs-4"></i>
                <div>
                    <div class="fw-bold">@Model.TotalViews.ToString("N0")</div>
                    <div class="small text-muted">Total Views</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Info banner -->
    <div class="alert alert-info py-2 mb-3 d-flex align-items-center gap-2">
        <i class="bi bi-globe fs-5"></i>
        <span>
            Photos marked <span class="badge bg-success ms-1 me-1"><i class="bi bi-globe"></i> Published</span>
            appear on the <strong>public home page</strong> at
            <a href="/" target="_blank" class="alert-link">http://localhost:5000/</a>.
            Use the <strong>Publish</strong> button to toggle visibility.
        </span>
    </div>

    <!-- Filter -->
    @if (Model.Categories.Any())
    {
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/Dashboard/Staff/Gallery"
               class="btn btn-sm @(string.IsNullOrEmpty(Model.FilterCategory) ? "btn-primary" : "btn-outline-secondary")">
                All
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a href="/Dashboard/Staff/Gallery?FilterCategory=@Uri.EscapeDataString(cat)"
                   class="btn btn-sm @(Model.FilterCategory == cat ? "btn-primary" : "btn-outline-secondary")">
                    @cat
                </a>
            }
        </div>
    }

    <!-- Gallery grid -->
    @if (!Model.GalleryItems.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-images display-4 d-block mb-2 opacity-25"></i>
            No photos yet. Click <strong>Add Photo</strong> to upload your first one.
        </div>
    }
    <div class="row g-3">
    @foreach (var item in Model.GalleryItems)
    {
        <div class="col-6 col-md-4 col-lg-3">
            <div class="gal-card">
                <!-- Image -->
                <div class="gal-img">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Title" loading="lazy" />
                    }
                    else
                    {
                        <div class="no-img"><i class="bi bi-image"></i></div>
                    }
                    <!-- Published badge -->
                    <div class="published-badge">
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success shadow-sm">
                                <i class="bi bi-globe me-1"></i>Published
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary shadow-sm">
                                <i class="bi bi-eye-slash me-1"></i>Hidden
                            </span>
                        }
                    </div>
                </div>

                <!-- Body -->
                <div class="gal-body">
                    <div class="fw-semibold text-truncate mb-1" style="font-size:.88rem" title="@item.Title">
                        @item.Title
                    </div>
                    @if (!string.IsNullOrEmpty(item.Category))
                    {
                        <span class="badge bg-light text-dark border small mb-2">@item.Category</span>
                    }
                    <div class="text-muted" style="font-size:.72rem">
                        <i class="bi bi-calendar3 me-1"></i>@item.CreatedAt.ToString("dd MMM yyyy")
                        @if (item.Views > 0) { <span class="ms-2"><i class="bi bi-eye me-1"></i>@item.Views</span> }
                    </div>

                    <!-- Action buttons -->
                    <div class="d-flex gap-1 mt-2">
                        <!-- Publish / Unpublish -->
                        <form method="post" asp-page-handler="TogglePublish" class="m-0 flex-fill">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit"
                                    class="btn btn-sm w-100 @(item.IsActive ? "btn-success" : "btn-outline-success")"
                                    title="@(item.IsActive ? "Remove from home page" : "Publish to home page")">
                                <i class="bi @(item.IsActive ? "bi-globe-americas" : "bi-globe") me-1"></i>
                                @(item.IsActive ? "Published" : "Publish")
                            </button>
                        </form>
                        <!-- Edit -->
                        <button class="btn btn-sm btn-outline-warning"
                                data-bs-toggle="modal" data-bs-target="#modalEdit"
                                onclick="fillEdit(@item.Id,
                                    '@Html.Raw(item.Title.Replace("'","&#39;"))',
                                    '@Html.Raw(item.Description.Replace("'","&#39;"))',
                                    '@Html.Raw(item.Category.Replace("'","&#39;"))',
                                    '@Html.Raw(item.ImageUrl.Replace("'","&#39;"))')"
                                title="Edit">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <!-- Delete -->
                        <form method="post" asp-page-handler="Delete" class="m-0"
                              onsubmit="return confirm('Delete this photo?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    </div>

</div>
</div>

<!-- ════ ADD PHOTO MODAL ══════════════════════════════════════════════════ -->
<div class="modal fade" id="modalAdd" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Add" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-1"></i>Add Photo</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Title *</label>
                        <input class="form-control" name="Title" required placeholder="Photo title" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            Upload Image
                            <span class="text-muted fw-normal">(or paste URL below)</span>
                        </label>
                        <input type="file" class="form-control" name="ImageFile"
                               accept="image/jpeg,image/png,image/webp,image/gif" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Image URL <span class="text-muted fw-normal">(if not uploading a file)</span></label>
                        <input class="form-control" name="ImageUrl" placeholder="https://…" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Category</label>
                        <input class="form-control" name="Category" placeholder="e.g. Cleaning, Events"
                               list="catList" />
                        <datalist id="catList">
                            @foreach (var c in Model.Categories) { <option value="@c" /> }
                        </datalist>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" name="Description" rows="2"
                                  placeholder="Optional description"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Add Photo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════ EDIT PHOTO MODAL ════════════════════════════════════════════════ -->
<div class="modal fade" id="modalEdit" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Update" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="EditId" id="eId" />
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-pencil me-1"></i>Edit Photo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Title *</label>
                        <input class="form-control" name="Title" id="eTitle" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Upload New Image <span class="text-muted fw-normal">(optional)</span></label>
                        <input type="file" class="form-control" name="ImageFile"
                               accept="image/jpeg,image/png,image/webp,image/gif" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Image URL <span class="text-muted fw-normal">(current)</span></label>
                        <input class="form-control" name="ImageUrl" id="eUrl" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Category</label>
                        <input class="form-control" name="Category" id="eCat" list="catList" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" name="Description" id="eDesc" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-semibold">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function fillEdit(id, title, desc, cat, url) {
    document.getElementById('eId').value    = id;
    document.getElementById('eTitle').value = title;
    document.getElementById('eDesc').value  = desc;
    document.getElementById('eCat').value   = cat;
    document.getElementById('eUrl').value   = url;
}
</script>
}
