@page
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userRole = HttpContext.Session.GetString("UserRole");
    
    if (userName == null)
    {
        Response.Redirect("/Login");
        return;
    }
    Layout = "/Pages/Dashboard/Staff/_StaffLayout.cshtml";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h4 class="fw-bold mb-0"><i class="bi bi-calendar-schedule text-primary me-2"></i>Dispatch Schedule</h4>
    <button class="btn btn-primary btn-sm rounded-pill px-3"><i class="bi bi-plus-lg me-1"></i>New Schedule</button>
</div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-list-check display-4 text-primary"></i>
                    <h4 class="mt-2">18</h4>
                    <p class="text-muted mb-0">Today's Dispatches</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-geo-alt display-4 text-success"></i>
                    <h4 class="mt-2">8</h4>
                    <p class="text-muted mb-0">Routes</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-truck display-4 text-info"></i>
                    <h4 class="mt-2">6</h4>
                    <p class="text-muted mb-0">Vehicles</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-check2-circle display-4 text-success"></i>
                    <h4 class="mt-2">95%</h4>
                    <p class="text-muted mb-0">On-time Rate</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
