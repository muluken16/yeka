@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.VehiclesModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Vehicles";
}
@section Styles {
<style>
.page-header { margin-bottom:24px; }
.page-header h4 { font-weight:800; margin:0; }
.tbl-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; }
.tbl-card table th { background:#f8fafc; font-size:.7rem; text-transform:uppercase; letter-spacing:.4px; color:#64748b; font-weight:700; padding:10px 14px !important; }
.tbl-card table td { font-size:.83rem; padding:10px 14px !important; border-color:#f1f5f9 !important; vertical-align:middle; }
.tbl-card table tr:last-child td { border-bottom:none !important; }
.sbadge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:.7rem;font-weight:700; }
.sbadge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.6;}
.s-available { background:#d1fae5;color:#065f46; }
.s-assigned  { background:#dbeafe;color:#1e40af; }
.s-maint     { background:#fef3c7;color:#92400e; }
</style>
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <h4><i class="bi bi-truck text-primary me-2"></i>Vehicles</h4>
        <p class="text-muted small mb-0">
            @Model.Vehicles.Count total ·
            <span class="text-success">@Model.Vehicles.Count(v=>v.Status=="Available") available</span> ·
            <span class="text-primary">@Model.Vehicles.Count(v=>v.Status=="Assigned") assigned</span>
        </p>
    </div>
    <button class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Vehicle
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="tbl-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>#</th><th>Plate</th><th>Type</th><th>Model</th><th>Color</th><th>Driver</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Vehicles.Any()) {
                    <tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-truck fs-2 opacity-25 d-block mb-2"></i>No vehicles found</td></tr>
                }
                @{ int n=0; }
                @foreach (var v in Model.Vehicles) { n++;
                    string sCls = v.Status switch { "Available"=>"s-available","Assigned"=>"s-assigned",_=>"s-maint" };
                    <tr>
                        <td class="text-muted">@n</td>
                        <td><span class="fw-bold" style="font-family:monospace">@v.PlateNumber</span></td>
                        <td class="text-muted">@(string.IsNullOrEmpty(v.VehicleType)?"—":v.VehicleType)</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(v.Model)?"—":v.Model)</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(v.Color)?"—":v.Color)</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(v.DriverName)?"—":v.DriverName)</td>
                        <td><span class="sbadge @sCls">@v.Status</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary rounded-pill me-1" data-bs-toggle="modal" data-bs-target="#editModal"
                                data-id="@v.Id" data-platenumber="@v.PlateNumber" data-vehicletype="@v.VehicleType"
                                data-model="@v.Model" data-color="@v.Color"
                                data-driverid="@v.DriverId" data-status="@v.Status">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger rounded-pill" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                data-id="@v.Id" data-platenumber="@v.PlateNumber">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ADD -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle text-primary me-2"></i>Add Vehicle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Plate Number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="PlateNumber" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Type <span class="text-danger">*</span></label>
                            <select class="form-select rounded-3" name="VehicleType" required>
                                <option value="">— Select —</option>
                                <option>Truck</option><option>Van</option><option>Car</option>
                                <option>Pickup</option><option>Minibus</option><option>Motorcycle</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Model</label>
                            <input type="text" class="form-control rounded-3" name="Model" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Color</label>
                            <input type="text" class="form-control rounded-3" name="Color" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Assign Driver</label>
                            <select class="form-select rounded-3" name="DriverId">
                                <option value="">— No Driver —</option>
                                @foreach (var d in Model.Drivers) {
                                    <option value="@d.Id">@d.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Status</label>
                            <select class="form-select rounded-3" name="Status">
                                <option value="Available">Available</option>
                                <option value="Assigned">Assigned</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Update">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil text-warning me-2"></i>Edit Vehicle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <input type="hidden" name="Id" id="eId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Plate Number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="PlateNumber" id="ePlate" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Type</label>
                            <select class="form-select rounded-3" name="VehicleType" id="eType">
                                <option value="">— Select —</option>
                                <option>Truck</option><option>Van</option><option>Car</option>
                                <option>Pickup</option><option>Minibus</option><option>Motorcycle</option><option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Model</label>
                            <input type="text" class="form-control rounded-3" name="Model" id="eModel" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Color</label>
                            <input type="text" class="form-control rounded-3" name="Color" id="eColor" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Assign Driver</label>
                            <select class="form-select rounded-3" name="DriverId" id="eDriverId">
                                <option value="">— No Driver —</option>
                                @foreach (var d in Model.Drivers) {
                                    <option value="@d.Id">@d.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Status</label>
                            <select class="form-select rounded-3" name="Status" id="eStatus">
                                <option value="Available">Available</option>
                                <option value="Assigned">Assigned</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Delete">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-trash me-2"></i>Delete Vehicle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="dId" />
                    <p class="mb-0">Delete vehicle <strong id="dPlate"></strong>? This cannot be undone.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('editModal').addEventListener('show.bs.modal', function(e) {
    var b = e.relatedTarget;
    document.getElementById('eId').value       = b.dataset.id;
    document.getElementById('ePlate').value    = b.dataset.platenumber;
    document.getElementById('eType').value     = b.dataset.vehicletype;
    document.getElementById('eModel').value    = b.dataset.model;
    document.getElementById('eColor').value    = b.dataset.color;
    document.getElementById('eDriverId').value = b.dataset.driverid || '';
    document.getElementById('eStatus').value   = b.dataset.status;
});
document.getElementById('deleteModal').addEventListener('show.bs.modal', function(e) {
    var b = e.relatedTarget;
    document.getElementById('dId').value = b.dataset.id;
    document.getElementById('dPlate').textContent = b.dataset.platenumber;
});
</script>
}
