@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.StaffModel
@{
    Layout = null;
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }

    // Role display helpers
    string RoleBadge(string r) => (r ?? "").ToLower() switch {
        "driver"            => "bg-success",
        "staff"             => "bg-primary",
        "manager"           => "bg-warning text-dark",
        "outsource"         => "bg-purple",
        "privatecompanyrep" => "bg-info text-dark",
        "dispatchofficer"   => "bg-secondary",
        "wereda_mahberat"   => "bg-orange",
        _                   => "bg-secondary"
    };
    string RoleIcon(string r) => (r ?? "").ToLower() switch {
        "driver"            => "bi-person-badge",
        "staff"             => "bi-person-gear",
        "manager"           => "bi-person-check",
        "outsource"         => "bi-building",
        "privatecompanyrep" => "bi-briefcase",
        "dispatchofficer"   => "bi-headset",
        "wereda_mahberat"   => "bi-geo-alt",
        _                   => "bi-person"
    };
    // Avatar colour by id
    string[] avatarColors = { "#0d6efd","#198754","#dc3545","#6f42c1","#fd7e14","#0dcaf0","#20c997","#e83e8c" };
    string AvatarColor(int id) => avatarColors[Math.Abs(id) % avatarColors.Length];
    string Initials(string n) {
        var parts = (n ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(w => char.ToUpper(w[0]))).PadRight(1, '?');
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>My Staff — Manager — Yeka Cleaning</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <style>
        .bg-purple { background-color:#6f42c1!important; color:#fff!important; }
        .bg-orange  { background-color:#fd7e14!important; color:#000!important; }
        .staff-card { border-radius:16px; border:1px solid #e8ecef; transition:box-shadow .18s,transform .18s; }
        .staff-card:hover { box-shadow:0 8px 28px rgba(0,0,0,.11); transform:translateY(-2px); }
        .avatar { width:50px;height:50px;border-radius:50%;display:flex;align-items:center;
                  justify-content:center;font-size:1.25rem;font-weight:700;flex-shrink:0; color:#fff; }
        .stat-pill { font-size:.73rem;padding:2px 9px;border-radius:20px; }
        .chart-box { height:220px;position:relative; }
        @@media print { .no-print{display:none!important} }
    </style>
</head>
<body>
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

<nav class="navbar navbar-dark dashboard-navbar fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/Dashboard/Manager"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
        <div class="nav-user">
            <span>Welcome, @userName</span>
            <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
    </div>
</nav>
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
    <div class="container-fluid">
        <button class="navbar-toggler" onclick="toggleSidebar()"><span class="navbar-toggler-icon"></span></button>
        <a class="navbar-brand" href="/Dashboard/Manager"><i class="bi bi-droplet-fill"></i> Yeka</a>
        <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-left"></i></a>
    </div>
</nav>
<nav id="sidebarMenu" class="sidebar d-lg-none">
    @await Html.PartialAsync("~/Pages/Dashboard/Manager/_Sidebar.cshtml")
</nav>
<nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform:none;padding-top:56px">
    @await Html.PartialAsync("~/Pages/Dashboard/Manager/_Sidebar.cshtml")
</nav>

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 pt-lg-5" style="margin-top:56px">

    <!-- ── Page Header ── -->
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom flex-wrap gap-2 no-print">
        <div>
            <h1 class="h3 mb-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>My Staff</h1>
            <small class="text-muted">All users · real-time from database · no duplicates</small>
        </div>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAdd">
            <i class="bi bi-person-plus-fill me-1"></i>Add Staff
        </button>
    </div>

    <!-- ── Alerts ── -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show py-2">
            <i class="bi bi-check-circle-fill me-1"></i>@Model.SuccessMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show py-2">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@Model.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ════ STAT CARDS ════════════════════════════════════════════════════ -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-2 fw-bold text-primary">@Model.TotalStaff</div>
                <div class="small text-muted">Total Staff</div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-2 fw-bold text-success">@Model.ActiveStaff</div>
                <div class="small text-muted">Active</div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-2 fw-bold text-danger">@Model.InactiveStaff</div>
                <div class="small text-muted">Inactive</div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-2 fw-bold" style="color:#198754">@Model.DriverCount</div>
                <div class="small text-muted">Drivers</div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-3 fw-bold text-info">@Model.TotalReceipts</div>
                <div class="small text-muted">Total Receipts</div>
            </div>
        </div>
        <div class="col-6 col-sm-4 col-lg-2">
            <div class="card border-0 shadow-sm rounded-4 text-center py-3 h-100">
                <div class="fs-4 fw-bold text-success" style="font-size:1.1rem!important">@Model.TotalKgAll.ToString("N0") kg</div>
                <div class="small text-muted">Total KG</div>
            </div>
        </div>
    </div>

    <!-- ════ CHARTS (only if data) ═════════════════════════════════════════ -->
    @if (Model.ChartRoleLabels.Any())
    {
        <div class="row g-3 mb-4 no-print">
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0">
                        <i class="bi bi-pie-chart me-1 text-primary"></i>Staff by Role
                    </div>
                    <div class="card-body">
                        <div class="chart-box"><canvas id="chartRoles"></canvas></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-header bg-white border-0 fw-semibold pt-3 pb-0">
                        <i class="bi bi-bar-chart me-1 text-success"></i>Top Staff by Receipts
                    </div>
                    <div class="card-body">
                        <div class="chart-box"><canvas id="chartTop"></canvas></div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ════ FILTER BAR ════════════════════════════════════════════════════ -->
    <div class="card border-0 shadow-sm rounded-4 mb-3 no-print">
        <div class="card-body py-2">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-12 col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="search" class="form-control"
                               placeholder="Name, email, phone…" value="@Model.SearchQuery" />
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select name="role" class="form-select form-select-sm">
                        <option value="">All Roles</option>
                        @foreach (var r in Model.Roles)
                        {
                            <option value="@r">@(Model.FilterRole == r ? "✓ " : "")@r</option>
                        }
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <select name="status" class="form-select form-select-sm">
                        <option value="">All Status</option>
                        <option value="active">@(Model.FilterStatus=="active" ? "✓ " : "")Active</option>
                        <option value="inactive">@(Model.FilterStatus=="inactive" ? "✓ " : "")Inactive</option>
                    </select>
                </div>
                <div class="col-12 col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm flex-fill">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                    <a href="/Dashboard/Manager/Staff" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-x"></i> Clear
                    </a>
                    <span class="btn btn-light btn-sm disabled text-muted">
                        @Model.StaffList.Count found
                    </span>
                </div>
            </form>
        </div>
    </div>

    <!-- ── View toggle ── -->
    <div class="d-flex justify-content-end mb-3 gap-2 no-print">
        <div class="btn-group btn-group-sm">
            <button class="btn btn-primary" id="btnCard" onclick="showView('card')">
                <i class="bi bi-grid-3x3-gap"></i> Cards
            </button>
            <button class="btn btn-outline-secondary" id="btnTable" onclick="showView('table')">
                <i class="bi bi-table"></i> Table
            </button>
        </div>
    </div>

    <!-- ════ CARD VIEW ════════════════════════════════════════════════════ -->
    <div id="viewCard">
        @if (!Model.StaffList.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people display-4 d-block mb-2 opacity-25"></i>
                No staff found. Try clearing the filters or add a new staff member.
            </div>
        }
        <div class="row g-3">
        @foreach (var s in Model.StaffList)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card staff-card shadow-sm h-100">
                    <div class="card-body p-3">

                        <!-- Avatar + Name + Status -->
                        <div class="d-flex align-items-start gap-3 mb-2">
                            <div class="avatar" style="background:@AvatarColor(s.id)">
                                @Initials(s.name)
                            </div>
                            <div class="flex-fill overflow-hidden">
                                <div class="d-flex justify-content-between align-items-start gap-1 flex-wrap">
                                    <h6 class="mb-0 fw-bold text-truncate" style="max-width:170px" title="@s.name">
                                        @s.name
                                    </h6>
                                    @if (s.is_active)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle small">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle small">Inactive</span>
                                    }
                                </div>
                                <span class="badge @RoleBadge(s.role) mt-1 small">
                                    <i class="bi @RoleIcon(s.role) me-1"></i>@s.role
                                </span>
                            </div>
                        </div>

                        <!-- Contact & Details -->
                        <div class="mb-2" style="font-size:.82rem">
                            <div class="text-muted d-flex align-items-center gap-1 mb-1 text-truncate">
                                <i class="bi bi-envelope flex-shrink-0"></i>
                                <span class="text-truncate">@(string.IsNullOrEmpty(s.email) ? "—" : s.email)</span>
                            </div>
                            <div class="text-muted d-flex align-items-center gap-1 mb-1">
                                <i class="bi bi-telephone flex-shrink-0"></i>
                                @(string.IsNullOrEmpty(s.phone) ? "—" : s.phone)
                            </div>
                            @if (!string.IsNullOrEmpty(s.address))
                            {
                                <div class="text-muted d-flex align-items-center gap-1 mb-1 text-truncate">
                                    <i class="bi bi-geo-alt flex-shrink-0"></i>
                                    <span class="text-truncate">@s.address</span>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(s.vehiclePlate))
                            {
                                <div class="d-flex align-items-center gap-1 mb-1">
                                    <i class="bi bi-truck text-success flex-shrink-0"></i>
                                    <code class="small">@s.vehiclePlate</code>
                                </div>
                            }
                        </div>

                        <!-- Receipt stats pills -->
                        @if (s.TotalReceipts > 0)
                        {
                            <div class="d-flex flex-wrap gap-1 mb-2">
                                @if (s.mahberatCount > 0)
                                {
                                    <span class="stat-pill badge bg-primary">
                                        <i class="bi bi-receipt me-1"></i>@s.mahberatCount Mahberat
                                    </span>
                                }
                                @if (s.outsourceCount > 0)
                                {
                                    <span class="stat-pill badge bg-purple">
                                        <i class="bi bi-building me-1"></i>@s.outsourceCount Outsource
                                    </span>
                                }
                                @if (s.privateCount > 0)
                                {
                                    <span class="stat-pill badge bg-info text-dark">
                                        <i class="bi bi-briefcase me-1"></i>@s.privateCount Private
                                    </span>
                                }
                            </div>
                            <div class="row g-1 mb-2" style="font-size:.78rem">
                                <div class="col-6 text-muted">
                                    <i class="bi bi-boxes me-1 text-info"></i>
                                    <strong>@s.totalKg.ToString("N1")</strong> kg
                                </div>
                                <div class="col-6 text-success">
                                    <i class="bi bi-cash me-1"></i>
                                    <strong>@s.totalAmount.ToString("N0")</strong> ETB
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="text-muted small mb-2"><i class="bi bi-receipt me-1"></i>No receipts yet</div>
                        }

                        <!-- Dates row -->
                        <div class="d-flex gap-3 mb-2" style="font-size:.72rem;color:#999">
                            <span title="Joined"><i class="bi bi-calendar-event me-1"></i>@s.created_at.ToString("MMM dd, yyyy")</span>
                            @if (s.lastReceiptDate.HasValue)
                            {
                                <span title="Last receipt"><i class="bi bi-clock-history me-1 text-warning"></i>@s.lastReceiptDate.Value.ToString("MMM dd, yyyy")</span>
                            }
                        </div>

                        <!-- Action buttons -->
                        <hr class="my-2" />
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-warning flex-fill"
                                    onclick="openEdit(@s.id,'@Html.Raw(s.name.Replace("'","&#39;"))','@s.email','@s.role','@s.phone','@Html.Raw(s.address.Replace("'","&#39;"))')"
                                    data-bs-toggle="modal" data-bs-target="#modalEdit">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </button>
                            <button class="btn btn-sm btn-outline-secondary"
                                    onclick="openReset(@s.id,'@Html.Raw(s.name.Replace("'","&#39;"))')"
                                    data-bs-toggle="modal" data-bs-target="#modalReset"
                                    title="Reset password">
                                <i class="bi bi-key"></i>
                            </button>
                            <form method="post" asp-page-handler="ToggleStatus" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.id" />
                                <button type="submit"
                                        class="btn btn-sm @(s.is_active ? "btn-outline-danger" : "btn-outline-success")"
                                        title="@(s.is_active ? "Deactivate" : "Activate")">
                                    <i class="bi bi-power"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
    </div>

    <!-- ════ TABLE VIEW ═══════════════════════════════════════════════════ -->
    <div id="viewTable" style="display:none">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size:.82rem">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Role</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Vehicle</th>
                            <th class="text-center">Receipts</th>
                            <th class="text-end">KG</th>
                            <th class="text-end">ETB</th>
                            <th>Last Receipt</th>
                            <th>Joined</th>
                            <th>Status</th>
                            <th class="text-center no-print">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (!Model.StaffList.Any())
                    {
                        <tr><td colspan="13" class="text-center py-4 text-muted">No staff found.</td></tr>
                    }
                    @{ int rn = 0; }
                    @foreach (var s in Model.StaffList)
                    {
                        rn++;
                        <tr class="@(!s.is_active ? "table-secondary opacity-75" : "")">
                            <td class="text-muted">@rn</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar" style="background:@AvatarColor(s.id);width:30px;height:30px;font-size:.8rem">
                                        @Initials(s.name)
                                    </div>
                                    <span class="fw-semibold">@s.name</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge @RoleBadge(s.role)">
                                    <i class="bi @RoleIcon(s.role) me-1"></i>@s.role
                                </span>
                            </td>
                            <td class="text-muted">@s.email</td>
                            <td>@(string.IsNullOrEmpty(s.phone) ? "—" : s.phone)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.vehiclePlate))
                                { <code>@s.vehiclePlate</code> }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-center">
                                @if (s.TotalReceipts > 0)
                                {
                                    <span class="badge bg-primary">@s.TotalReceipts</span>
                                }
                                else { <span class="text-muted">—</span> }
                            </td>
                            <td class="text-end">@(s.totalKg > 0 ? s.totalKg.ToString("N1") + " kg" : "—")</td>
                            <td class="text-end text-success fw-semibold">
                                @(s.totalAmount > 0 ? s.totalAmount.ToString("N0") : "—")
                            </td>
                            <td class="text-muted small">
                                @(s.lastReceiptDate.HasValue ? s.lastReceiptDate.Value.ToString("yyyy-MM-dd") : "—")
                            </td>
                            <td class="text-muted small">@s.created_at.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (s.is_active)
                                { <span class="badge bg-success">Active</span> }
                                else
                                { <span class="badge bg-danger">Inactive</span> }
                            </td>
                            <td class="text-center no-print">
                                <div class="d-flex gap-1 justify-content-center">
                                    <button class="btn btn-sm btn-outline-warning"
                                            onclick="openEdit(@s.id,'@Html.Raw(s.name.Replace("'","&#39;"))','@s.email','@s.role','@s.phone','@Html.Raw(s.address.Replace("'","&#39;"))')"
                                            data-bs-toggle="modal" data-bs-target="#modalEdit">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary"
                                            onclick="openReset(@s.id,'@Html.Raw(s.name.Replace("'","&#39;"))')"
                                            data-bs-toggle="modal" data-bs-target="#modalReset">
                                        <i class="bi bi-key"></i>
                                    </button>
                                    <form method="post" asp-page-handler="ToggleStatus" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.id" />
                                        <button type="submit"
                                                class="btn btn-sm @(s.is_active ? "btn-outline-danger" : "btn-outline-success")">
                                            <i class="bi bi-power"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                    @if (Model.StaffList.Any())
                    {
                        <tfoot class="table-light fw-bold">
                            <tr>
                                <td colspan="7" class="text-end">Totals:</td>
                                <td class="text-end">@Model.TotalKgAll.ToString("N1") kg</td>
                                <td class="text-end text-success">@Model.TotalAmountAll.ToString("N0")</td>
                                <td colspan="4"></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

</main>

<!-- ════ ADD STAFF MODAL ═══════════════════════════════════════════════════ -->
<div class="modal fade" id="modalAdd" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddStaff">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-person-plus-fill me-1"></i>Add New Staff</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Full Name *</label>
                        <input class="form-control" name="name" required placeholder="e.g. Abebe Girma" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email *</label>
                        <input type="email" class="form-control" name="email" required placeholder="email@example.com" />
                        <div class="form-text text-danger small">Must be unique — duplicate emails are rejected.</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Password *</label>
                        <input type="password" class="form-control" name="password" required minlength="6" placeholder="Min 6 characters" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Role *</label>
                        <select class="form-select" name="role" required>
                            <option value="">— Select Role —</option>
                            <option value="staff">Staff (Web)</option>
                            <option value="driver">Driver (Mobile App)</option>
                            <option value="outsource">Outsource (Mobile App)</option>
                            <option value="DispatchOfficer">Dispatch Officer (Web)</option>
                            <option value="wereda_mahberat">Wereda Mahberat (Web)</option>
                            <option value="manager">Manager (Web + Mobile)</option>
                            <option value="PrivateCompanyRep">Private Company Rep (Mobile)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
