</div>

<!-- ════ EDIT STAFF MODAL ══════════════════════════════════════════════════ -->
<div class="modal fade" id="modalEdit" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="UpdateStaff">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="eId" />
                <div class="modal-header bg-warning">
                    <h5 class="modal-title"><i class="bi bi-person-gear me-1"></i>Edit Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Full Name *</label>
                        <input class="form-control" name="name" id="eName" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email (read-only)</label>
                        <input type="email" class="form-control bg-light" id="eEmail" readonly />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Role</label>
                        <select class="form-select" name="role" id="eRole">
                            <option value="staff">Staff (Web)</option>
                            <option value="driver">Driver (Mobile App)</option>
                            <option value="outsource">Outsource (Mobile App)</option>
                            <option value="DispatchOfficer">Dispatch Officer (Web)</option>
                            <option value="wereda_mahberat">Wereda Mahberat (Web)</option>
                            <option value="manager">Manager (Web + Mobile)</option>
                            <option value="PrivateCompanyRep">Private Company Rep (Mobile)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <input type="tel" class="form-control" name="phone" id="ePhone" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Address</label>
                        <input class="form-control" name="address" id="eAddress" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">
                            New Password
                            <small class="text-muted fw-normal">(leave blank = keep current)</small>
                        </label>
                        <input type="password" class="form-control" name="newPassword" minlength="6"
                               placeholder="Leave blank to keep unchanged" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning fw-semibold">
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════ RESET PASSWORD MODAL ══════════════════════════════════════════════ -->
<div class="modal fade" id="modalReset" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" asp-page-handler="ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="resetId" id="rId" />
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-key me-1"></i>Reset Password</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">Staff: <strong id="rName"></strong></p>
                    <label class="form-label fw-semibold">New Password *</label>
                    <input type="password" class="form-control" name="resetPassword"
                           required minlength="6" placeholder="Min 6 characters" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning btn-sm fw-semibold">
                        <i class="bi bi-key me-1"></i>Reset
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ── Sidebar ───────────────────────────────────────────────────────────────────
function toggleSidebar() {
    document.getElementById('sidebarMenu').classList.toggle('show');
    document.getElementById('sidebarBackdrop').classList.toggle('show');
}
document.querySelectorAll('#sidebarMenu .nav-link').forEach(function(l) {
    l.addEventListener('click', function() { if (window.innerWidth < 992) toggleSidebar(); });
});

// ── View toggle (persisted) ───────────────────────────────────────────────────
function showView(v) {
    document.getElementById('viewCard').style.display  = v === 'card'  ? '' : 'none';
    document.getElementById('viewTable').style.display = v === 'table' ? '' : 'none';
    document.getElementById('btnCard').className  = v === 'card'  ? 'btn btn-primary'           : 'btn btn-outline-secondary';
    document.getElementById('btnTable').className = v === 'table' ? 'btn btn-primary'           : 'btn btn-outline-secondary';
    localStorage.setItem('staffView', v);
}
(function() { showView(localStorage.getItem('staffView') || 'card'); })();

// ── Edit modal ────────────────────────────────────────────────────────────────
function openEdit(id, name, email, role, phone, address) {
    document.getElementById('eId').value      = id;
    document.getElementById('eName').value    = name;
    document.getElementById('eEmail').value   = email;
    document.getElementById('ePhone').value   = phone;
    document.getElementById('eAddress').value = address;
    var sel = document.getElementById('eRole');
    for (var i = 0; i < sel.options.length; i++) {
        sel.options[i].selected = sel.options[i].value.toLowerCase() === (role||'').toLowerCase();
    }
}

// ── Reset modal ───────────────────────────────────────────────────────────────
function openReset(id, name) {
    document.getElementById('rId').value          = id;
    document.getElementById('rName').textContent  = name;
}

// ── Charts ────────────────────────────────────────────────────────────────────
var roleLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartRoleLabels));
var roleValues  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartRoleValues));
var topNames    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartTopNames));
var topCounts   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartTopCounts));

var pieColors = ['#0d6efd','#198754','#dc3545','#6f42c1','#fd7e14','#0dcaf0','#20c997','#e83e8c'];

if (roleLabels.length > 0) {
    new Chart(document.getElementById('chartRoles'), {
        type: 'doughnut',
        data: {
            labels: roleLabels,
            datasets: [{ data: roleValues, backgroundColor: pieColors, borderWidth: 2 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 10 } }
            }
        }
    });
}

if (topNames.length > 0) {
    new Chart(document.getElementById('chartTop'), {
        type: 'bar',
        data: {
            labels: topNames,
            datasets: [{
                label: 'Receipts',
                data: topCounts,
                backgroundColor: '#0d6efd99',
                borderColor: '#0d6efd',
                borderWidth: 1.5,
                borderRadius: 5
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { ticks: { font: { size: 10 } } },
                y: { beginAtZero: true, ticks: { font: { size: 10 }, precision: 0 } }
            }
        }
    });
}
</script>
</body>
</html>
