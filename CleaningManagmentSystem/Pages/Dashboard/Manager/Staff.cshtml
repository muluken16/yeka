@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.StaffModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Employees";
    var colors = new[]{"#4361ee","#3a86ff","#06d6a0","#f72585","#7209b7","#fb8500","#e63946","#2a9d8f"};
    string AvatarColor(int id) => colors[Math.Abs(id) % colors.Length];
}
@section Styles {
<style>
.emp-avatar { width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.95rem;color:#fff;flex-shrink:0; }
.emp-card   { border-radius:14px;border:1px solid #e8ecef;transition:box-shadow .18s,transform .18s; }
.emp-card:hover { box-shadow:0 8px 24px rgba(0,0,0,.10);transform:translateY(-2px); }
.field-label { font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#6c757d; }
.badge-grade { font-size:.7rem;padding:2px 8px;border-radius:20px;background:#e8f4fd;color:#0d6efd;font-weight:600; }
.stat-card  { border-radius:16px;border:0; }
</style>
}

<!-- Header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-people-fill text-primary me-2"></i>Employees</h4>
        <p class="text-muted mb-0 small">View all staff from the shared employee database.</p>
    </div>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center p-3 h-100">
            <div class="fs-2 fw-bold text-primary">@Model.TotalCount</div>
            <div class="text-muted small">Total</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center p-3 h-100">
            <div class="fs-2 fw-bold text-success">@Model.ActiveCount</div>
            <div class="text-muted small">Active</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center p-3 h-100">
            <div class="fs-2 fw-bold text-warning">@Model.DeptCount</div>
            <div class="text-muted small">Departments</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card stat-card shadow-sm text-center p-3 h-100">
            <div class="fs-2 fw-bold text-danger">@Model.InactiveCount</div>
            <div class="text-muted small">Inactive</div>
        </div>
    </div>
</div>

<!-- Filter -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="field-label">Search</label>
                <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm rounded-3" placeholder="Name, department, position...">
            </div>
            <div class="col-md-3">
                <label class="field-label">Department</label>
                <select name="dept" class="form-select form-select-sm rounded-3">
                    <option value="">All Departments</option>
                    @foreach (var d in Model.Departments)
                    {
                        <option value="@d" selected="@(Model.DeptFilter == d ? true : (bool?)null)">@d</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="field-label">Status</label>
                <select name="status" class="form-select form-select-sm rounded-3">
                    <option value="">All</option>
                    <option value="Active"   selected="@(Model.StatusFilter=="Active"   ? true:(bool?)null)">Active</option>
                    <option value="Inactive" selected="@(Model.StatusFilter=="Inactive" ? true:(bool?)null)">Inactive</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm rounded-pill px-3"><i class="bi bi-search me-1"></i>Filter</button>
                <a href="/Dashboard/Manager/Staff" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Reset</a>
                <span class="text-muted small align-self-center">@Model.Employees.Count found</span>
            </div>
        </form>
    </div>
</div>

<!-- View toggle -->
<div class="d-flex justify-content-end mb-3 gap-2">
    <div class="btn-group btn-group-sm">
        <button class="btn btn-primary"          id="btnCard"  onclick="setView('card')"><i class="bi bi-grid-3x3-gap"></i> Cards</button>
        <button class="btn btn-outline-secondary" id="btnTable" onclick="setView('table')"><i class="bi bi-table"></i> Table</button>
    </div>
</div>

<!-- ── CARD VIEW ── -->
<div id="viewCard">
    @if (!Model.Employees.Any()) {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-people fs-1 d-block mb-2 opacity-25"></i>No employees found.
        </div>
    }
    <div class="row g-3">
    @foreach (var e in Model.Employees)
    {
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card emp-card shadow-sm h-100">
                <div class="card-body p-3">
                    <!-- Avatar + name -->
                    <div class="d-flex align-items-center gap-3 mb-3">
                        @if (!string.IsNullOrEmpty(e.photo_url)) {
                            <img src="@e.photo_url" alt="@e.FullName"
                                 class="emp-avatar" style="object-fit:cover;">
                        } else {
                            <div class="emp-avatar" style="background:@AvatarColor(e.id)">@e.Initials</div>
                        }
                        <div class="flex-fill overflow-hidden">
                            <div class="fw-bold text-truncate" style="font-size:.95rem">@e.FullName</div>
                            <div class="text-muted small text-truncate">@e.position</div>
                        </div>
                        @if (e.employment_status == "Active") {
                            <span class="badge bg-success-subtle text-success border border-success rounded-pill" style="font-size:.72rem">Active</span>
                        } else {
                            <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill" style="font-size:.72rem">@e.employment_status</span>
                        }
                    </div>

                    <!-- Details grid -->
                    <div class="row g-1 mb-2" style="font-size:.82rem">
                        <div class="col-6">
                            <div class="field-label">Department</div>
                            <div class="fw-semibold text-truncate">@(string.IsNullOrEmpty(e.department) ? "—" : e.department)</div>
                        </div>
                        <div class="col-6">
                            <div class="field-label">Job Grade</div>
                            <div>@if (!string.IsNullOrEmpty(e.job_grade)) {
                                <span class="badge-grade">@e.job_grade</span>
                            } else { <span class="text-muted">—</span> }</div>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="field-label">Type</div>
                            <span class="badge bg-light text-dark border" style="font-size:.72rem">@(string.IsNullOrEmpty(e.employment_type) ? "—" : e.employment_type)</span>
                        </div>
                        <div class="col-6 mt-2">
                            <div class="field-label">Service</div>
                            <div class="fw-semibold">@e.YearsService yr@(e.YearsService != 1 ? "s" : "")</div>
                        </div>
                    </div>

                    <hr class="my-2">

                    <!-- Contact + location -->
                    <div style="font-size:.8rem">
                        @if (!string.IsNullOrEmpty(e.phone_number)) {
                            <div class="text-muted mb-1 text-truncate">
                                <i class="bi bi-telephone me-1"></i>@e.phone_number
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(e.email_address)) {
                            <div class="text-muted mb-1 text-truncate">
                                <i class="bi bi-envelope me-1"></i>@e.email_address
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(e.work_location)) {
                            <div class="text-muted text-truncate">
                                <i class="bi bi-geo-alt me-1"></i>@e.work_location
                            </div>
                        }
                        <div class="text-muted mt-1">
                            <i class="bi bi-calendar-event me-1"></i>Hired @e.hire_date.ToString("MMM dd, yyyy")
                        </div>
                    </div>

                    <!-- Employee code -->
                    <div class="mt-2 pt-2 border-top d-flex align-items-center justify-content-between">
                        <code style="font-size:.75rem;color:#0d6efd">@e.employee_code</code>
                        @if (e.user_id > 0) {
                            <a href="/Dashboard/Profile?userId=@e.user_id" class="btn btn-sm btn-outline-primary rounded-pill" style="font-size:.75rem">
                                <i class="bi bi-person-circle me-1"></i>Profile
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    </div>
</div>

<!-- ── TABLE VIEW ── -->
<div id="viewTable" style="display:none">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size:.84rem">
                <thead style="background:#f8f9fa">
                    <tr>
                        <th class="ps-3 py-3 text-muted">#</th>
                        <th class="py-3 text-muted">Employee</th>
                        <th class="py-3 text-muted">Code</th>
                        <th class="py-3 text-muted">Department</th>
                        <th class="py-3 text-muted">Position</th>
                        <th class="py-3 text-muted">Grade</th>
                        <th class="py-3 text-muted">Type</th>
                        <th class="py-3 text-muted">Hire Date</th>
                        <th class="py-3 text-muted">Location</th>
                        <th class="py-3 text-muted">Phone</th>
                        <th class="py-3 text-muted">Status</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Employees.Any()) {
                    <tr><td colspan="11" class="text-center py-5 text-muted">No employees found.</td></tr>
                }
                @{ int n = 0; }
                @foreach (var e in Model.Employees)
                {
                    n++;
                    <tr>
                        <td class="ps-3 text-muted">@n</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(e.photo_url)) {
                                    <img src="@e.photo_url" class="emp-avatar" style="width:34px;height:34px;object-fit:cover;" alt="">
                                } else {
                                    <div class="emp-avatar" style="width:34px;height:34px;font-size:.8rem;background:@AvatarColor(e.id)">@e.Initials</div>
                                }
                                <div>
                                    <div class="fw-semibold">@e.FullName</div>
                                    @if (!string.IsNullOrEmpty(e.email_address)) {
                                        <div class="text-muted" style="font-size:.75rem">@e.email_address</div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td><code style="font-size:.75rem">@e.employee_code</code></td>
                        <td class="fw-semibold">@(string.IsNullOrEmpty(e.department) ? "—" : e.department)</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(e.position) ? "—" : e.position)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(e.job_grade)) {
                                <span class="badge-grade">@e.job_grade</span>
                            } else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="badge bg-light text-dark border" style="font-size:.72rem">@(string.IsNullOrEmpty(e.employment_type)?"—":e.employment_type)</span></td>
                        <td class="text-muted">@e.hire_date.ToString("MMM dd, yyyy")</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(e.work_location)?"—":e.work_location)</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(e.phone_number)?"—":e.phone_number)</td>
                        <td>
                            @if (e.employment_status == "Active") {
                                <span class="badge bg-success-subtle text-success border border-success rounded-pill">Active</span>
                            } else {
                                <span class="badge bg-danger-subtle text-danger border border-danger rounded-pill">@e.employment_status</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
function setView(v) {
    document.getElementById('viewCard').style.display  = v === 'card'  ? '' : 'none';
    document.getElementById('viewTable').style.display = v === 'table' ? '' : 'none';
    document.getElementById('btnCard').className  = v === 'card'  ? 'btn btn-primary'            : 'btn btn-outline-secondary';
    document.getElementById('btnTable').className = v === 'table' ? 'btn btn-primary'            : 'btn btn-outline-secondary';
    localStorage.setItem('managerStaffView', v);
}
(function(){ setView(localStorage.getItem('managerStaffView') || 'card'); })();
</script>
}
