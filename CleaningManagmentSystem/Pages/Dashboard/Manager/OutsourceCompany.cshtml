@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.OutsourceCompanyModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Outsource Companies";
}
@section Styles {
<style>
.tbl-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; margin-bottom:24px; }
.tbl-card table th { background:#f8fafc; font-size:.7rem; text-transform:uppercase; letter-spacing:.4px; color:#64748b; font-weight:700; padding:10px 14px !important; }
.tbl-card table td { font-size:.83rem; padding:10px 14px !important; border-color:#f1f5f9 !important; vertical-align:middle; }
.tbl-card table tr:last-child td { border-bottom:none !important; }
.sbadge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:.7rem;font-weight:700; }
.sbadge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.6;}
.s-active   { background:#d1fae5;color:#065f46; }
.s-inactive { background:#f1f5f9;color:#64748b; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-building text-primary me-2"></i>Outsource Companies</h4>
        <p class="text-muted small mb-0">@Model.Companies.Count company records</p>
    </div>
    <button class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Company
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-exclamation-triangle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search -->
<div class="d-flex gap-2 mb-3">
    <form method="get" class="d-flex flex-grow-1" style="max-width:400px">
        <div class="input-group">
            <input type="text" class="form-control rounded-start-3" name="searchQuery"
                   placeholder="Search companies…" value="@Model.SearchQuery" />
            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery)) {
                <a href="/Dashboard/Manager/OutsourceCompany" class="btn btn-outline-secondary rounded-end-3">
                    <i class="bi bi-x"></i>
                </a>
            }
        </div>
    </form>
</div>

        <!-- Add Company Modal -->
        <div class="modal fade" id="addModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="action" value="create" />
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Add New Outsource Company</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Company Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="CompanyName" required placeholder="Enter company name" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contact Person <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" name="ContactPerson" required placeholder="Enter contact person" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Phone <span class="text-danger">*</span></label>
                                    <input type="tel" class="form-control" name="Phone" required placeholder="+251911234567" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="email" class="form-control" name="Email" placeholder="company@email.et" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">License Number</label>
                                    <input type="text" class="form-control" name="LicenseNumber" placeholder="Business license number" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract Start Date <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control" name="ContractStartDate" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract End Date</label>
                                    <input type="date" class="form-control" name="ContractEndDate" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Status</label>
                                    <select class="form-select" name="Status">
                                        <option value="Active" selected>Active</option>
                                        <option value="Inactive">Inactive</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold">Services Provided</label>
                                    <textarea class="form-control" name="ServicesProvided" rows="2" placeholder="Describe services provided..."></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle me-2"></i>Save Company</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>



        <!-- Companies Table -->
        <div class="tbl-card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Company Name</th>
                            <th>Contact</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>Contract Start</th>
                            <th>Contract End</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Companies.Any())
                        {
                            int n = 0;
                            foreach (var company in Model.Companies)
                            { n++;
                                <tr>
                                    <td class="text-muted">@n</td>
                                    <td><strong>@company.CompanyName</strong></td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(company.ContactPerson)?"—":company.ContactPerson)</td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(company.Phone)?"—":company.Phone)</td>
                                    <td class="text-muted">@(string.IsNullOrEmpty(company.Email)?"—":company.Email)</td>
                                    <td class="text-muted">@(company.ContractStartDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td class="text-muted">@(company.ContractEndDate?.ToString("MMM dd, yyyy") ?? "—")</td>
                                    <td>
                                        <span class="sbadge @(company.Status=="Active"?"s-active":"s-inactive")">@company.Status</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary rounded-pill me-1" data-bs-toggle="modal" data-bs-target="#viewModal-@company.Id" title="View"><i class="bi bi-eye"></i></button>
                                        <button class="btn btn-sm btn-outline-warning rounded-pill me-1" data-bs-toggle="modal" data-bs-target="#editModal-@company.Id" title="Edit"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger rounded-pill" data-bs-toggle="modal" data-bs-target="#deleteModal-@company.Id" title="Delete"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="9" class="text-center py-5 text-muted">
                                <i class="bi bi-building fs-2 opacity-25 d-block mb-2"></i>No companies found
                            </td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    <!-- Add Company Modal Removed -->

    <!-- View, Edit, Delete Modals for each company -->
    @foreach (var company in Model.Companies)
    {
        <!-- View Modal -->
        <div class="modal fade" id="viewModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-building me-2"></i>Company Details</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <table class="table table-borderless">
                            <tr><th width="40%">Company Name:</th><td><strong>@company.CompanyName</strong></td></tr>
                            <tr><th>Contact Person:</th><td>@company.ContactPerson</td></tr>
                            <tr><th>Phone:</th><td>@company.Phone</td></tr>
                            <tr><th>Email:</th><td>@company.Email</td></tr>
                            <tr><th>License Number:</th><td>@company.LicenseNumber</td></tr>
                            <tr><th>Contract Start:</th><td>@(company.ContractStartDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                            <tr><th>Contract End:</th><td>@(company.ContractEndDate?.ToString("yyyy-MM-dd") ?? "-")</td></tr>
                            <tr><th>Status:</th>
                                <td>
                                    @if (company.Status == "Active")
                                    { <span class="badge bg-success">Active</span> }
                                    else
                                    { <span class="badge bg-secondary">Inactive</span> }
                                </td>
                            </tr>
                            <tr><th>Services:</th><td>@(string.IsNullOrEmpty(company.ServicesProvided) ? "-" : company.ServicesProvided)</td></tr>
                        </table>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="editModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Company</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <input type="hidden" name="action" value="update" />
                            <input type="hidden" name="Id" value="@company.Id" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Company Name *</label>
                                    <input type="text" class="form-control" name="CompanyName" value="@company.CompanyName" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contact Person *</label>
                                    <input type="text" class="form-control" name="ContactPerson" value="@company.ContactPerson" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Phone *</label>
                                    <input type="tel" class="form-control" name="Phone" value="@company.Phone" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="email" class="form-control" name="Email" value="@company.Email" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">License Number</label>
                                    <input type="text" class="form-control" name="LicenseNumber" value="@company.LicenseNumber" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract Start Date *</label>
                                    <input type="date" class="form-control" name="ContractStartDate" value="@(company.ContractStartDate?.ToString("yyyy-MM-dd"))" required />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Contract End Date</label>
                                    <input type="date" class="form-control" name="ContractEndDate" value="@(company.ContractEndDate?.ToString("yyyy-MM-dd"))" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Status</label>
                                    <select class="form-select" name="Status">
                                        <option value="Active" selected="@(company.Status == "Active" ? "selected" : null)">Active</option>
                                        <option value="Inactive" selected="@(company.Status == "Inactive" ? "selected" : null)">Inactive</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-bold">Services Provided</label>
                                    <textarea class="form-control" name="ServicesProvided" rows="3">@company.ServicesProvided</textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Update Company</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="modal fade" id="deleteModal-@company.Id" tabindex="-1">
            <div class="modal-dialog modal-sm">
                <div class="modal-content">
                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title"><i class="bi bi-trash me-2"></i>Delete Company</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <i class="bi bi-exclamation-triangle display-1 text-danger"></i>
                            <p class="mt-3">Are you sure you want to delete <strong>@company.CompanyName</strong>?</p>
                            <p class="text-muted small">This action cannot be undone.</p>
                            <input type="hidden" name="action" value="delete" />
                            <input type="hidden" name="Id" value="@company.Id" />
                        </div>
                        <div class="modal-footer justify-content-center">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

