@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.DriversModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Drivers";
}
@section Styles {
<style>
.page-header { margin-bottom:24px; }
.page-header h4 { font-weight:800; margin:0; }
.tbl-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; }
.tbl-card table th { background:#f8fafc; font-size:.7rem; text-transform:uppercase; letter-spacing:.4px; color:#64748b; font-weight:700; padding:10px 14px !important; }
.tbl-card table td { font-size:.83rem; padding:10px 14px !important; border-color:#f1f5f9 !important; vertical-align:middle; }
.tbl-card table tr:last-child td { border-bottom:none !important; }
.sbadge { display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:.7rem;font-weight:700; }
.sbadge::before{content:'';width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.6;}
.s-active   { background:#d1fae5;color:#065f46; }
.s-inactive { background:#f1f5f9;color:#64748b; }
.s-expiring { background:#fef3c7;color:#92400e; }
</style>
}

<div class="page-header d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
        <h4><i class="bi bi-person-badge text-primary me-2"></i>Drivers</h4>
        <p class="text-muted small mb-0">@Model.Drivers.Count total · @Model.Drivers.Count(d=>d.IsActive) active</p>
    </div>
    <button class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Driver
    </button>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-exclamation-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
    <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm mb-3">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="tbl-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>#</th><th>Name</th><th>Phone</th><th>License #</th><th>Type</th><th>Expiry</th><th>Status</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Drivers.Any()) {
                    <tr><td colspan="8" class="text-center py-5 text-muted"><i class="bi bi-person-badge fs-2 opacity-25 d-block mb-2"></i>No drivers found</td></tr>
                }
                @{ int n=0; }
                @foreach (var d in Model.Drivers) { n++;
                    bool expiringSoon = d.LicenseExpiry > DateTime.MinValue && d.LicenseExpiry < DateTime.Today.AddDays(30);
                    <tr>
                        <td class="text-muted">@n</td>
                        <td>
                            <div class="fw-semibold">@d.FullName</div>
                            @if (!string.IsNullOrEmpty(d.Email)) { <div class="text-muted" style="font-size:.72rem">@d.Email</div> }
                        </td>
                        <td class="text-muted">@(string.IsNullOrEmpty(d.Phone)?"—":d.Phone)</td>
                        <td><code style="font-size:.78rem">@(string.IsNullOrEmpty(d.LicenseNumber)?"—":d.LicenseNumber)</code></td>
                        <td class="text-muted">@(string.IsNullOrEmpty(d.LicenseType)?"—":d.LicenseType)</td>
                        <td>
                            @if (d.LicenseExpiry > DateTime.MinValue) {
                                <span class="sbadge @(expiringSoon?"s-expiring":"")">@d.LicenseExpiry.ToString("MMM dd, yyyy")</span>
                            } else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="sbadge @(d.IsActive?"s-active":"s-inactive")">@(d.IsActive?"Active":"Inactive")</span></td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary rounded-pill me-1" data-bs-toggle="modal" data-bs-target="#editModal"
                                data-id="@d.Id" data-fullname="@d.FullName" data-phone="@d.Phone"
                                data-email="@d.Email" data-licensenumber="@d.LicenseNumber"
                                data-licensetype="@d.LicenseType"
                                data-licenseexpiry="@d.LicenseExpiry.ToString("yyyy-MM-dd")"
                                data-address="@d.Address"
                                data-isactive="@d.IsActive.ToString().ToLower()">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger rounded-pill" data-bs-toggle="modal" data-bs-target="#deleteModal"
                                data-id="@d.Id" data-fullname="@d.FullName">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ADD -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Add">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle text-primary me-2"></i>Add Driver</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="FullName" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Phone <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="Phone" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Email</label>
                            <input type="email" class="form-control rounded-3" name="Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Number</label>
                            <input type="text" class="form-control rounded-3" name="LicenseNumber" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Type</label>
                            <input type="text" class="form-control rounded-3" name="LicenseType" placeholder="e.g. Commercial" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Expiry</label>
                            <input type="date" class="form-control rounded-3" name="LicenseExpiry" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Address</label>
                            <textarea class="form-control rounded-3" name="Address" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" name="IsActive" value="true" id="aIsActive" checked />
                                <label class="form-check-label fw-semibold small" for="aIsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Update">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil text-warning me-2"></i>Edit Driver</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <input type="hidden" name="Id" id="eId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="FullName" id="eFullName" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Phone</label>
                            <input type="text" class="form-control rounded-3" name="Phone" id="ePhone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Email</label>
                            <input type="email" class="form-control rounded-3" name="Email" id="eEmail" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Number</label>
                            <input type="text" class="form-control rounded-3" name="LicenseNumber" id="eLicNum" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Type</label>
                            <input type="text" class="form-control rounded-3" name="LicenseType" id="eLicType" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">License Expiry</label>
                            <input type="date" class="form-control rounded-3" name="LicenseExpiry" id="eLicExp" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Address</label>
                            <textarea class="form-control rounded-3" name="Address" id="eAddress" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" name="IsActive" value="true" id="eIsActive" />
                                <label class="form-check-label fw-semibold small" for="eIsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning rounded-pill px-4">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- DELETE -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Delete">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger"><i class="bi bi-trash me-2"></i>Delete Driver</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="id" id="dId" />
                    <p class="mb-0">Delete driver <strong id="dName"></strong>? This cannot be undone.</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger rounded-pill px-4">Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('editModal').addEventListener('show.bs.modal', function(e) {
    var b = e.relatedTarget;
    document.getElementById('eId').value       = b.dataset.id;
    document.getElementById('eFullName').value = b.dataset.fullname;
    document.getElementById('ePhone').value    = b.dataset.phone;
    document.getElementById('eEmail').value    = b.dataset.email;
    document.getElementById('eLicNum').value   = b.dataset.licensenumber;
    document.getElementById('eLicType').value  = b.dataset.licensetype;
    document.getElementById('eLicExp').value   = b.dataset.licenseexpiry;
    document.getElementById('eAddress').value  = b.dataset.address;
    document.getElementById('eIsActive').checked = b.dataset.isactive === 'true';
});
document.getElementById('deleteModal').addEventListener('show.bs.modal', function(e) {
    var b = e.relatedTarget;
    document.getElementById('dId').value = b.dataset.id;
    document.getElementById('dName').textContent = b.dataset.fullname;
});
</script>
}
