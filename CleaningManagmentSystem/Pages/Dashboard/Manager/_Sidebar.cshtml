<script>
// Keep icon in sync with collapsed state
(function() {
    var ic = document.getElementById('sbToggleIcon');
    if (!ic) return;
    ic.className = document.body.classList.contains('sb-collapsed')
        ? 'bi bi-chevron-right' : 'bi bi-chevron-left';
    // Update icon when collapse toggles
    var obs = new MutationObserver(function() {
        var col = document.body.classList.contains('sb-collapsed');
        ic.className = col ? 'bi bi-chevron-right' : 'bi bi-chevron-left';
    });
    obs.observe(document.body, { attributes: true, attributeFilter: ['class'] });
})();
</script>
