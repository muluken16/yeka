@{
    var currentPath = Context.Request.Path.Value ?? "";
    bool IsActive(string path, bool exact = false)
    {
        if (exact) return currentPath.Equals(path, StringComparison.OrdinalIgnoreCase);
        return currentPath.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }
}

<!-- Collapse toggle button (desktop only) -->
<button onclick="toggleDesktopSidebar()"
        title="Collapse sidebar"
        style="position:absolute;top:50%;right:-13px;transform:translateY(-50%);
               width:26px;height:26px;border-radius:50%;background:#fff;
               border:2px solid rgba(255,255,255,.3);color:#2E86AB;
               display:flex;align-items:center;justify-content:center;
               cursor:pointer;font-size:.75rem;z-index:210;
               box-shadow:0 2px 8px rgba(0,0,0,.18);transition:all .2s;"
        class="d-none d-lg-flex" id="sbToggleBtn">
    <i class="bi bi-chevron-left" id="sbToggleIcon"></i>
</button>

