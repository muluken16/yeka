        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/Manager/OutsourceCompany")?"active":"")"
               href="/Dashboard/Manager/OutsourceCompany" title="Outsource Companies">
                <i class="bi bi-building flex-shrink-0"></i>
                <span class="nav-label ms-2">Outsource Co.</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/Manager/PrivateCleaningCompany")?"active":"")"
