@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.ApprovalsModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Approvals";
    var activeTab = string.IsNullOrEmpty(Model.HistorySearch) && string.IsNullOrEmpty(Request.Query["tab"]) ? "pending" : Request.Query["tab"].ToString();
    if (activeTab != "history" && activeTab != "monthly") activeTab = "pending";
}
@section Styles {
<style>
    .tab-pill { border-radius: 50px !important; padding: 0.45rem 1.3rem; font-weight: 600; }
    .tab-pill.active { background: linear-gradient(90deg,#0d6efd,#0a58ca); color:#fff; }
    .badge-count { font-size: 0.7em; vertical-align: middle; }
    .price-calc-box { background: linear-gradient(135deg,#f0fff4,#dcfce7); border-radius: 12px; border: 1px solid #bbf7d0; }
    .total-display { background: linear-gradient(135deg,#1a7a4a,#15803d); color:#fff; border-radius:10px; }
</style>
}

        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
            <div>
                <h4 class="fw-bold mb-1"><i class="bi bi-check2-square text-primary me-2"></i>Approvals &amp; History</h4>
                <p class="text-muted small mb-0">Review pending receipts and manage approvals</p>
            </div>
        </div>

        <!-- ── Tabs ── -->
        <ul class="nav gap-2 mb-4" id="approvalsTab" role="tablist">
            <li class="nav-item">
                <button class="btn tab-pill @(activeTab == "pending" ? "active btn-primary" : "btn-outline-primary")"
                        onclick="switchTab('pending')" id="tab-pending">
                    <i class="bi bi-hourglass-split me-1"></i> Pending
                    <span class="badge bg-danger rounded-pill badge-count ms-1">@Model.PendingSubmissions.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="btn tab-pill @(activeTab == "history" ? "active btn-secondary" : "btn-outline-secondary")"
                        onclick="switchTab('history')" id="tab-history">
                    <i class="bi bi-clock-history me-1"></i> History
                    <span class="badge bg-light text-dark rounded-pill badge-count ms-1">@Model.HistorySubmissions.Count</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="btn tab-pill @(activeTab == "monthly" ? "active btn-info text-white" : "btn-outline-info")"
                        onclick="switchTab('monthly')" id="tab-monthly">
                    <i class="bi bi-receipt me-1"></i> Monthly Receipts
                    <span class="badge bg-dark rounded-pill badge-count ms-1">@Model.MonthlyReceipts.Count(r => r.status == "Level 1 Approved")</span>
                </button>
            </li>
        </ul>

        <!-- ══════════════════ PENDING TAB ══════════════════ -->
        <div id="pane-pending" style="display: @(activeTab == "pending" ? "block" : "none")">
            <div class="row mb-3">
                <div class="col-md-7">
                    <form method="get" class="d-flex">
                        <input type="hidden" name="tab" value="pending" />
                        <div class="input-group">
                            <input type="text" class="form-control" name="SearchQuery"
                                   placeholder="Search wereda, driver, plate..." value="@Model.SearchQuery" />
                            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                            @if (!string.IsNullOrEmpty(Model.SearchQuery))
                            {
                                <a href="/Dashboard/Manager/Approvals?tab=pending" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
                            }
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.PendingSubmissions.Count == 0)
            {
                <div class="alert alert-success text-center py-5 shadow-sm rounded-4">
                    <i class="bi bi-check-circle-fill display-4 text-success mb-3 d-block"></i>
                    <h4>All Caught Up!</h4>
                    <p class="mb-0">No pending submissions to approve right now.</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Date &amp; Time</th>
                                        <th>Wereda &amp; Mahaber</th>
                                        <th>Vehicle &amp; Driver</th>
                                        <th>KG &amp; Amount</th>
                                        <th>Images</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.PendingSubmissions)
                                    {
                                        <tr>
                                            <td class="fw-bold">#@item.id</td>
                                            <td>
                                                <span class="d-block fw-bold"><i class="bi bi-calendar-event me-1"></i>@item.date</span>
                                                <small class="text-muted"><i class="bi bi-clock me-1"></i>@item.time</small>
                                            </td>
                                            <td>
                                                <span class="d-block fw-bold text-primary">@item.weredaName</span>
                                                <small class="text-muted">@item.mahberatName</small>
                                                @if (item.receiptType == "Outsource")
                                                {
                                                    <span class="badge bg-info ms-1" style="font-size:0.65em;">Outsource</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-primary ms-1" style="font-size:0.65em;">Mahberat</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="d-block fw-bold">@item.vehicleName</span>
                                                <small class="text-muted"><i class="bi bi-person me-1"></i>@item.driverName</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary me-1">@item.kilogram KG</span>
                                                <span class="badge bg-success">@item.total ETB</span>
                                                @if (!string.IsNullOrEmpty((string)item.notes))
                                                {
                                                    <small class="text-muted d-block fst-italic mt-1"><i class="bi bi-journal-text me-1"></i>@item.notes</small>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty((string)item.imageUrl))
                                                {
                                                    <div class="d-flex gap-1 flex-wrap" style="max-width:130px;">
                                                        @{ var imgIdx = 0; }
                                                        @foreach (var img in ((string)item.imageUrl).Split(','))
                                                        {
                                                            var cleanImg = img.Trim();
                                                            if (!string.IsNullOrEmpty(cleanImg))
                                                            {
                                                                <a href="#" data-bs-toggle="modal" data-bs-target="#imageModal"
                                                                   onclick="showImages('@item.imageUrl', @imgIdx)">
                                                                    <img src="@cleanImg" class="rounded border shadow-sm"
                                                                         style="width:42px;height:42px;object-fit:cover;"
                                                                         onerror="this.onerror=null;this.src='/images/placeholder.png';" />
                                                                </a>
                                                                imgIdx++;
                                                            }
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">No Image</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2">
                                                    <button type="button" class="btn btn-sm btn-success px-3 shadow-sm"
                                                            onclick="openApproveModal(@item.id, '@item.receiptType', @item.kilogram, '@item.weredaName', '@item.driverName')">
                                                        <i class="bi bi-check-circle me-1"></i>Approve
                                                    </button>
                                                    <form method="post" asp-page-handler="Reject" class="m-0">
                                                        <input type="hidden" name="id" value="@item.id" />
                                                        <input type="hidden" name="receiptType" value="@item.receiptType" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3 shadow-sm"
                                                                onclick="return confirm('Are you sure you want to REJECT this submission?');">
                                                            <i class="bi bi-x-circle me-1"></i>Reject
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══════════════════ HISTORY TAB ══════════════════ -->
        <div id="pane-history" style="display: @(activeTab == "history" ? "block" : "none")">
            <div class="row mb-3">
                <div class="col-md-7">
                    <form method="get" class="d-flex">
                        <input type="hidden" name="tab" value="history" />
                        <div class="input-group">
                            <input type="text" class="form-control" name="HistorySearch"
                                   placeholder="Search wereda, driver, plate..." value="@Model.HistorySearch" />
                            <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
                            @if (!string.IsNullOrEmpty(Model.HistorySearch))
                            {
                                <a href="/Dashboard/Manager/Approvals?tab=history" class="btn btn-outline-secondary"><i class="bi bi-x"></i></a>
                            }
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.HistorySubmissions.Count == 0)
            {
                <div class="alert alert-info text-center py-5 shadow-sm rounded-4">
                    <i class="bi bi-clock-history display-4 text-secondary mb-3 d-block"></i>
                    <h4>No History Found</h4>
                    <p class="mb-0">There are no previous approvals or rejections to show.</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Type</th>
                                        <th>Date &amp; Time</th>
                                        <th>Wereda &amp; Mahaber</th>
                                        <th>Vehicle &amp; Driver</th>
                                        <th>KG &amp; Total</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.HistorySubmissions)
                                    {
                                        <tr>
                                            <td class="fw-bold">#@item.id</td>
                                            <td>
                                                @if (item.receiptType == "Outsource")
                                                {
                                                    <span class="badge bg-info">Outsource</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-primary">Mahberat</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="d-block fw-bold"><i class="bi bi-calendar-event me-1"></i>@(item.date ?? "-")</span>
                                                <small class="text-muted"><i class="bi bi-clock me-1"></i>@(item.time ?? "-")</small>
                                            </td>
                                            <td>
                                                <span class="d-block fw-bold text-primary">@item.weredaName</span>
                                                <small class="text-muted">@item.mahberatName</small>
                                            </td>
                                            <td>
                                                <span class="d-block fw-bold">@item.vehicleName</span>
                                                <small class="text-muted"><i class="bi bi-person me-1"></i>@item.driverName</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary me-1">@item.kilogram KG</span>
                                                <span class="badge bg-success">@item.total ETB</span>
                                            </td>
                                            <td>
                                                @if (item.status == "Approved")
                                                {
                                                    <span class="badge bg-success px-3 py-2"><i class="bi bi-check-circle me-1"></i>Approved</span>
                                                }
                                                else if (item.status == "Rejected")
                                                {
                                                    <span class="badge bg-danger px-3 py-2"><i class="bi bi-x-circle me-1"></i>Rejected</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@item.status</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- ══════════════════ MONTHLY TAB ══════════════════ -->
        <div id="pane-monthly" style="display: @(activeTab == "monthly" ? "block" : "none")">
            @if (Model.MonthlyReceipts.Count == 0)
            {
                <div class="alert alert-info text-center py-5 shadow-sm rounded-4">
                    <i class="bi bi-receipt display-4 text-secondary mb-3 d-block"></i>
                    <h4>No Monthly Receipts</h4>
                    <p class="mb-0">There are no monthly receipts waiting for manager approval.</p>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Receipt No</th>
                                        <th>Month &amp; Year</th>
                                        <th>Amount</th>
                                        <th>Source</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.MonthlyReceipts)
                                    {
                                        <tr>
                                            <td class="fw-bold">@item.receiptNumber</td>
                                            <td>@item.month @item.year</td>
                                            <td><span class="badge bg-success">@item.totalAmount ETB</span></td>
                                            <td><span class="badge bg-secondary">@item.source</span></td>
                                            <td>
                                                @if(item.status == "Paid") { <span class="badge bg-success">Paid (Fully Approved)</span> }
                                                else { <span class="badge bg-info text-dark">Level 1 Approved</span> }
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" onclick="openMonthlyApprovalForm(@item.id, '@item.receiptNumber', '@item.month @item.year', @item.totalAmount, '@item.status')">
                                                    <i class="bi bi-file-earmark-text me-1"></i> Form
                                                </button>
                                                @if(item.status == "Level 1 Approved") {
                                                    <form method="post" asp-page-handler="ApproveMonthly" class="d-inline">
                                                        <input type="hidden" name="id" value="@item.id" />
                                                        <button type="submit" class="btn btn-sm btn-success">
                                                            <i class="bi bi-check me-1"></i> Approve
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>

    </main>

    <!-- ══ Approve Modal ══ -->
    <div class="modal fade" id="approveModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header" style="background:linear-gradient(90deg,#198754,#146c43); color:#fff;">
                    <h5 class="modal-title"><i class="bi bi-check-circle-fill me-2"></i>Approve Receipt</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <!-- Receipt Info -->
                    <div class="mb-3 p-3 bg-light rounded-3">
                        <div class="d-flex gap-3">
                            <div><i class="bi bi-geo-alt text-primary"></i> <span class="fw-semibold" id="infoWereda"></span></div>
                            <div><i class="bi bi-person text-secondary"></i> <span id="infoDriver"></span></div>
                        </div>
                    </div>

                    <form method="post" asp-page-handler="Approve" id="approveForm">
                        <input type="hidden" name="id" id="approveId" />
                        <input type="hidden" name="receiptType" id="approveType" />

                        <div class="price-calc-box p-3 mb-3">
                            <!-- KG (readonly) -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-secondary small text-uppercase">Total Kilograms</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-boxes"></i></span>
                                    <input type="number" class="form-control fw-bold fs-5 bg-white" id="approveKg" readonly />
                                    <span class="input-group-text fw-bold">KG</span>
                                </div>
                            </div>

                            <!-- Price (editable) -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary small text-uppercase">Price Per KG <span class="text-muted">(editable)</span></label>
                                <div class="input-group">
                                    <span class="input-group-text text-primary"><i class="bi bi-tag-fill"></i></span>
                                    <input type="number" step="0.01" min="0.01"
                                           class="form-control fw-bold fs-5"
                                           id="approvePricePerKg"
                                           value="@Model.DefaultPricePerKg"
                                           oninput="calculateTotal()" required />
                                    <span class="input-group-text">ETB</span>
                                </div>
                                <div class="form-text"><i class="bi bi-info-circle me-1"></i>Default: <strong>@Model.DefaultPricePerKg ETB/KG</strong> (from Settings)</div>
                            </div>

                            <!-- Total (auto-calculated) -->
                            <div class="total-display p-3 text-center">
                                <div class="small opacity-75 mb-1">TOTAL PRICE</div>
                                <div class="fs-3 fw-bold" id="approveTotalDisplay">0.00 <span class="fs-5">ETB</span></div>
                                <input type="hidden" name="totalPrice" id="approveTotal" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-success px-4 fw-bold">
                                <i class="bi bi-check-circle me-1"></i>Confirm &amp; Approve
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- RECEIPT APPROVAL FORM MODAL (Level 2 = Manager) -->
    <div class="modal fade" id="monthlyApprovalFormModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title w-100 text-center text-uppercase fw-bold">
                        <i class="bi bi-file-earmark-check me-2"></i>Receipt Approval Form
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body bg-light p-4">
                    <div class="border border-2 border-dark bg-white p-4" style="font-size:.9rem">
                        <div class="text-center fw-bold fs-5 border-bottom border-dark pb-2 mb-3">RECEIPT APPROVAL FORM</div>
                        
                        <div class="fw-bold bg-dark text-white px-2 py-1 mb-2">SECTION A: RECEIPT INFORMATION</div>
                        <div class="row mb-3 px-2">
                            <div class="col-md-6"><strong>Receipt No:</strong> <span id="mFormRecNo"></span></div>
                            <div class="col-md-6"><strong>Month/Year:</strong> <span id="mFormPeriod"></span></div>
                            <div class="col-md-6 mt-1"><strong>Total Amount:</strong> <span id="mFormAmount"></span></div>
                            <div class="col-md-6 mt-1"><strong>Status:</strong> <span id="mFormStatus"></span></div>
                        </div>

                        <div class="fw-bold bg-dark text-white px-2 py-1 mb-2">SECTION B: APPROVAL TRACKING</div>
                        <table class="table table-sm table-bordered border-dark mb-3">
                            <thead class="table-secondary"><tr><th>Level</th><th>Role</th><th>Status</th></tr></thead>
                            <tbody>
                                <tr>
                                    <td>1</td><td>Mahberat</td>
                                    <td><span class="text-success fw-bold">[✓] Approved</span></td>
                                </tr>
                                <tr>
                                    <td>2</td><td>Manager (You)</td>
                                    <td id="mFormL2Status">[ ] Pending</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer bg-white d-flex justify-content-between align-items-center">
                    <div id="mApprovalFormActions"></div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Image Modal -->
    <div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-transparent border-0">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-0">
                    <div id="imageCarousel" class="carousel slide">
                        <div class="carousel-inner" id="carouselInner"></div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#imageCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#imageCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script>
        var defaultPrice = @Model.DefaultPricePerKg;

        function switchTab(tab) {
            document.getElementById('pane-pending').style.display = tab === 'pending' ? 'block' : 'none';
            document.getElementById('pane-history').style.display = tab === 'history' ? 'block' : 'none';
            document.getElementById('pane-monthly').style.display = tab === 'monthly' ? 'block' : 'none';
            
            document.getElementById('tab-pending').className = tab === 'pending'
                ? 'btn tab-pill active btn-primary'
                : 'btn tab-pill btn-outline-primary';
            document.getElementById('tab-history').className = tab === 'history'
                ? 'btn tab-pill active btn-secondary'
                : 'btn tab-pill btn-outline-secondary';
            document.getElementById('tab-monthly').className = tab === 'monthly'
                ? 'btn tab-pill active btn-info text-white'
                : 'btn tab-pill btn-outline-info';
        }

        function openMonthlyApprovalForm(id, no, period, amount, status) {
            document.getElementById('mFormRecNo').textContent = no;
            document.getElementById('mFormPeriod').textContent = period;
            document.getElementById('mFormAmount').textContent = 'ETB ' + parseFloat(amount).toFixed(2);
            document.getElementById('mFormStatus').textContent = status;
            
            let l2 = status === 'Paid' ? '<span class="text-success fw-bold">[✓] Approved</span>' : '<span class="text-warning">[ ] Pending</span>';
            document.getElementById('mFormL2Status').innerHTML = l2;
            
            let actions = '';
            if(status === 'Level 1 Approved') {
                actions = `<form method="post" asp-page-handler="ApproveMonthly" class="m-0"><input type="hidden" name="id" value="${id}" /><button type="submit" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Approve (Level 2)</button></form>`;
            } else {
                actions = `<span class="text-success fw-bold"><i class="bi bi-check-circle-fill me-1"></i>Fully Approved</span>`;
            }
            document.getElementById('mApprovalFormActions').innerHTML = actions;
            
            new bootstrap.Modal(document.getElementById('monthlyApprovalFormModal')).show();
        }

        function openApproveModal(id, type, kg, wereda, driver) {
            document.getElementById('approveId').value = id;
            document.getElementById('approveType').value = type;
            document.getElementById('approveKg').value = kg;
            document.getElementById('approvePricePerKg').value = defaultPrice;
            document.getElementById('infoWereda').textContent = wereda;
            document.getElementById('infoDriver').textContent = driver;
            calculateTotal();
            new bootstrap.Modal(document.getElementById('approveModal')).show();
        }

        function calculateTotal() {
            var kg = parseFloat(document.getElementById('approveKg').value) || 0;
            var price = parseFloat(document.getElementById('approvePricePerKg').value) || 0;
            var total = kg * price;
            document.getElementById('approveTotal').value = total.toFixed(2);
            document.getElementById('approveTotalDisplay').innerHTML =
                total.toFixed(2) + ' <span class="fs-5">ETB</span>';
        }

        function toggleSidebar() {
            document.getElementById('sidebarMenu').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }

        function showImages(imageUrls, startIndex) {
            const urls = imageUrls.split(',').map(u => u.trim()).filter(u => u.length > 0);
            const inner = document.getElementById('carouselInner');
            inner.innerHTML = '';
            urls.forEach((url, index) => {
                const active = index === startIndex ? 'active' : '';
                inner.innerHTML += `<div class="carousel-item ${active}">
                    <img src="${url}" class="d-block w-100 rounded shadow"
                         style="max-height:80vh;object-fit:contain;"
                         onerror="this.onerror=null;this.src='/images/placeholder.png';" />
                </div>`;
            });
            const controls = document.querySelectorAll('.carousel-control-prev, .carousel-control-next');
            controls.forEach(c => c.style.display = urls.length > 1 ? '' : 'none');
        }

        document.querySelectorAll('#sidebarMenu .nav-link').forEach(function (link) {
            link.addEventListener('click', function () {
                if (window.innerWidth < 992) toggleSidebar();
            });
        });

        // Auto-switch to history tab if requested
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('tab') === 'history') switchTab('history');
        if (urlParams.get('tab') === 'monthly') switchTab('monthly');
    </script>
}
