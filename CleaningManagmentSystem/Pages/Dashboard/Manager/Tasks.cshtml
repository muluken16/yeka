@page
@model CleaningManagmentSystem.Pages.Dashboard.Manager.TasksModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Tasks";
}
@section Styles {
<style>
.page-header h4 { font-weight:800; margin:0; }
.tbl-card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; }
.tbl-card table th { background:#f8fafc; font-size:.7rem; text-transform:uppercase; letter-spacing:.4px; color:#64748b; font-weight:700; padding:10px 14px !important; }
.tbl-card table td { font-size:.83rem; padding:10px 14px !important; border-color:#f1f5f9 !important; vertical-align:middle; }
.tbl-card table tr:last-child td { border-bottom:none !important; }
</style>
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-clipboard-check text-primary me-2"></i>Task Management</h4>
        <p class="text-muted mb-0 small">@Model.TasksList.Count task@(Model.TasksList.Count == 1 ? "" : "s") total</p>
    </div>
    <button class="btn btn-primary btn-sm rounded-pill px-3" data-bs-toggle="modal" data-bs-target="#addModal">
        <i class="bi bi-plus-lg me-1"></i>Add Task
    </button>
</div>

<div class="tbl-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>#</th><th>Task #</th><th>Date</th><th>Priority</th><th>Status</th><th>Description</th></tr>
            </thead>
            <tbody>
                @if (!Model.TasksList.Any()) {
                    <tr><td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-clipboard-x fs-2 opacity-25 d-block mb-2"></i>No tasks found
                    </td></tr>
                }
                @{ int n = 0; }
                @foreach (var t in Model.TasksList) { n++;
                    string pCls = t.priority switch { "High" => "bg-danger", "Low" => "bg-info text-dark", _ => "bg-secondary" };
                    string sCls = t.status == "Completed" ? "bg-success" : t.status == "In Progress" ? "bg-primary" : "bg-warning text-dark";
                    <tr>
                        <td class="text-muted">@n</td>
                        <td><span class="fw-semibold" style="font-family:monospace">@t.task_number</span></td>
                        <td class="text-muted">@t.task_date.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @pCls rounded-pill" style="font-size:.7rem">@t.priority</span></td>
                        <td><span class="badge @sCls rounded-pill" style="font-size:.7rem">@t.status</span></td>
                        <td class="text-muted">@(t.description.Length > 60 ? t.description[..60] + "…" : t.description)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Task Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle text-primary me-2"></i>Add Task</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-2">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Task Number <span class="text-danger">*</span></label>
                            <input type="text" class="form-control rounded-3" name="TaskNumber" required placeholder="TSK-001" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control rounded-3" name="TaskDate" required value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Priority</label>
                            <select class="form-select rounded-3" name="Priority">
                                <option value="Low">Low</option>
                                <option value="Normal" selected>Normal</option>
                                <option value="High">High</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Description <span class="text-danger">*</span></label>
                            <textarea class="form-control rounded-3" name="Description" rows="3" required placeholder="Task details..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-check2 me-1"></i>Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
