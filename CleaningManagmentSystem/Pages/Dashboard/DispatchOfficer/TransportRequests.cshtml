// ── 9-Step Progress Tracker ──────────────────────────────────
const STEPS = [
    { key: 'PendingDispatcher',      label: 'Submitted',         actor: 'Mahberat' },
    { key: 'DriverAssigned',         label: 'Assigned',          actor: 'Dispatch' },
    { key: 'DriverAccepted',         label: 'Accepted',          actor: 'Driver' },
    { key: 'PickedUp',               label: 'Picked Up',         actor: 'Driver' },
    { key: 'MahberatApprovedPickup', label: 'Verified',          actor: 'Mahberat' },
    { key: 'ReceiptSubmitted',       label: 'Receipt',           actor: 'Driver' },
    { key: 'ReceiptVerified',        label: 'Confirmed',         actor: 'Mahberat' },
    { key: 'StaffApproved',          label: 'Approved',          actor: 'Staff' },
    { key: 'Paid',                   label: 'Paid',              actor: 'Finance' },
];
const REJECTED = ['DispatcherRejected','DriverRejected','StaffRejected'];

function stepTracker(currentStatus) {
    if (REJECTED.includes(currentStatus)) {
        return `<div class="d-flex align-items-center gap-3 py-3 px-4 bg-danger bg-opacity-10 w-100">
            <div class="fs-3 text-danger"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div>
                <h6 class="text-danger fw-bold mb-0">Request Rejected — ${currentStatus.replace('Rejected','').replace(/([A-Z])/g,' $1').trim()}</h6>
                <small class="text-danger opacity-75">This transport operation has been cancelled and closed.</small>
            </div>
        </div>`;
    }
    const currentIdx = STEPS.findIndex(s => s.key === currentStatus);
    return `<div class="step-flow">
        ${STEPS.map((s, i) => {
            let cls = '';
            if (i < currentIdx)        cls = 'step-done';
            else if (i === currentIdx) cls = 'step-active';
            const icon = i < currentIdx ? '<i class="bi bi-check-lg"></i>' : (i + 1);
            return `<div class="step-item ${cls}">
                <div class="step-circle">${icon}</div>
                <div class="step-label">${s.label}</div>
                <div class="step-actor">${s.actor}</div>
            </div>`;
        }).join('')}
    </div>`;
}

loadStats();
loadRequests();
setInterval(() => { loadStats(); loadRequests(); }, 30000);
</script>
