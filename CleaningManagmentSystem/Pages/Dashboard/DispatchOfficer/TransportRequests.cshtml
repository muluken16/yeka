@page
@model CleaningManagmentSystem.Pages.Dashboard.DispatchOfficer.TransportRequestsModel
@{
    Layout = "_DispatchLayout";
    ViewData["Title"] = "Transport Requests";
    var userName = HttpContext.Session.GetString("UserName");
    if (userName == null) { Response.Redirect("/Login"); return; }
}

@section Styles {
    <style>
        /* Modern Premium Aesthetic */
        :root {
            --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            --success-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
            --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            --info-gradient: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            --card-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
            --hover-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --transition-speed: 0.3s;
        }

        .main-content {
            background-color: #f8fafc;
            min-height: 100vh;
        }

        .page-title {
            font-weight: 800;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        /* Stat Cards */
        .stat-card {
            border-radius: 1rem;
            border: none;
            background: #ffffff;
            box-shadow: var(--card-shadow);
            transition: transform var(--transition-speed), box-shadow var(--transition-speed);
            overflow: hidden;
            position: relative;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--hover-shadow);
        }
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 4px;
        }
        .stat-card.pending::before { background: var(--warning-gradient); }
        .stat-card.assigned::before { background: var(--primary-gradient); }
        .stat-card.active-trips::before { background: var(--success-gradient); }
        .stat-card.total::before { background: var(--info-gradient); }
        
        .stat-icon {
            font-size: 2.5rem;
            opacity: 0.1;
            position: absolute;
            right: 15px;
            bottom: 10px;
        }

        /* Data Table */
        .table-card {
            border-radius: 1rem;
            border: none;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }
        .table > :not(caption) > * > * {
            padding: 0.75rem 1rem;
            vertical-align: middle;
        }
        .table-hover tbody tr {
            transition: background-color var(--transition-speed);
        }
        .table-hover tbody tr:hover {
            background-color: #f1f5f9;
        }
        thead {
            background-color: #f8fafc;
            border-bottom: 2px solid #e2e8f0;
        }
        thead th {
            font-weight: 600;
            color: #475569;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
        }

        /* Status Badges */
        .status-badge {
            font-size: 0.75rem;
            padding: 0.4em 0.8em;
            border-radius: 2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }
        .status-badge::before {
            content: '';
            width: 6px; height: 6px;
            border-radius: 50%;
            display: inline-block;
        }
        
        .status-PendingDispatcher { background: #fef3c7; color: #b45309; }
        .status-PendingDispatcher::before { background: #b45309; }
        
        .status-DriverAssigned { background: #e0e7ff; color: #4338ca; }
        .status-DriverAssigned::before { background: #4338ca; }
        
        .status-DriverAccepted { background: #d1fae5; color: #059669; }
        .status-DriverAccepted::before { background: #059669; }
        
        .status-PickedUp { background: #e0f2fe; color: #0369a1; }
        .status-PickedUp::before { background: #0369a1; }
        
        .status-ReceiptSubmitted { background: #f3e8ff; color: #7e22ce; }
        .status-ReceiptSubmitted::before { background: #7e22ce; }
        
        .status-ReceiptVerified { background: #dcfce7; color: #15803d; }
        .status-ReceiptVerified::before { background: #15803d; }
        
        .status-StaffApproved { background: #dcfce7; color: #166534; }
        .status-StaffApproved::before { background: #166534; }
        
        .status-Paid { background: #10b981; color: #ffffff; }
        .status-Paid::before { background: #ffffff; }
        
        .status-DispatcherRejected, .status-StaffRejected { background: #fee2e2; color: #b91c1c; }
        .status-DispatcherRejected::before { background: #b91c1c; }

        /* Premium Buttons */
        .btn-modern {
            border-radius: 0.5rem;
            font-weight: 600;
            letter-spacing: 0.02em;
            transition: all var(--transition-speed);
        }
        .btn-modern:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        /* ── 9-Step Progress Tracker (Modernized) ── */
        .tracker-row {
            background-color: #fafafa;
            border-top: 1px dashed #e2e8f0;
        }
        .step-flow {
            display: flex;
            align-items: flex-start;
            overflow-x: auto;
            padding: 1.5rem 1rem;
            gap: 0;
            scrollbar-width: none; /* Firefox */
        }
        .step-flow::-webkit-scrollbar { display: none; /* Chrome */ }
        
        .step-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 90px;
            position: relative;
            flex: 1;
        }
        .step-item:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 16px;
            left: calc(50% + 18px);
            right: calc(-50% + 18px);
            height: 4px;
            background: #e2e8f0;
            z-index: 0;
            border-radius: 2px;
            transition: background 0.4s ease;
        }
        .step-item:not(:last-child).step-done::after {
            background: var(--primary-gradient);
        }
        .step-item:not(:last-child).step-active::after {
            background: linear-gradient(90deg, #6366f1 50%, #e2e8f0 50%);
            background-size: 200% 100%;
            animation: moveGradient 2s linear infinite;
        }
        
        @@keyframes moveGradient {
            0% { background-position: 100% 0; }
            100% { background-position: -100% 0; }
        }

        .step-circle {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            z-index: 1;
            position: relative;
            border: 3px solid #e2e8f0;
            background: #ffffff;
            color: #94a3b8;
            transition: all 0.3s ease;
        }
        .step-done .step-circle {
            background: #4f46e5;
            border-color: #4f46e5;
            color: #ffffff;
            box-shadow: 0 0 10px rgba(79, 70, 229, 0.4);
        }
        .step-active .step-circle {
            background: #ffffff;
            border-color: #4f46e5;
            color: #4f46e5;
            box-shadow: 0 0 0 5px rgba(79, 70, 229, 0.15);
            animation: pulseActive 2s infinite;
        }
        
        @@keyframes pulseActive {
            0% { box-shadow: 0 0 0 0 rgba(79, 70, 229, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(79, 70, 229, 0); }
            100% { box-shadow: 0 0 0 0 rgba(79, 70, 229, 0); }
        }

        .step-rejected .step-circle {
            background: #ef4444;
            border-color: #ef4444;
            color: #ffffff;
            box-shadow: 0 0 10px rgba(239, 68, 68, 0.4);
        }
        
        .step-label {
            font-size: 11px;
            text-align: center;
            margin-top: 8px;
            line-height: 1.4;
            color: #64748b;
            font-weight: 500;
            max-width: 80px;
        }
        .step-done .step-label { color: #334155; font-weight: 700; }
        .step-active .step-label { color: #4f46e5; font-weight: 800; }
        .step-rejected .step-label { color: #ef4444; font-weight: 700; }
        
        .step-actor {
            font-size: 9px;
            text-align: center;
            color: #94a3b8;
            margin-top: 2px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Modals */
        .modal-content {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
        }
        .modal-header {
            border-bottom: 1px solid #f1f5f9;
            padding: 1rem 1.5rem;
        }
        .modal-body {
            padding: 1rem 1.5rem;
        }
        .modal-footer {
            border-top: 1px solid #f1f5f9;
            padding: 1rem 1.5rem;
            background-color: #f8fafc;
        }
        .form-control, .form-select {
            border-radius: 0.5rem;
            border: 1px solid #cbd5e1;
            padding: 0.6rem 1rem;
            transition: all 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #818cf8;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }
        
        /* Timeline inside Detail Modal */
        .activity-timeline {
            position: relative;
            padding-left: 1.5rem;
        }
        .activity-timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: #e2e8f0;
        }
        .timeline-item {
            position: relative;
            margin-bottom: 1.5rem;
        }
        .timeline-item::before {
            content: '';
            position: absolute;
            left: -1.5rem;
            top: 0.25rem;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #6366f1;
            transform: translateX(-5px);
            border: 2px solid #ffffff;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }
    </style>
}

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content pb-5" style="margin-top: 20px;">
    <!-- Header Section -->
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-2 pb-2 mb-3">
        <div>
            <h1 class="h2 page-title mb-0"><i class="bi bi-rocket-takeoff me-2"></i>Transport Operations</h1>
            <p class="text-muted small mt-1 mb-0">Manage and track fleet logistics in real-time.</p>
        </div>
        <div class="d-flex gap-3 align-items-center">
            <div class="input-group shadow-sm" style="border-radius: 0.5rem; overflow:hidden;">
                <span class="input-group-text bg-white border-0 text-muted"><i class="bi bi-funnel"></i></span>
                <select id="statusFilter" class="form-select border-0 bg-white shadow-none" onchange="filterRequests()" style="min-width: 200px;">
                    <option value="">All Statuses</option>
                    <option value="PendingDispatcher">Pending Review</option>
                    <option value="DriverAssigned">Driver Assigned</option>
                    <option value="DriverAccepted">Driver Accepted</option>
                    <option value="PickedUp">Picked Up</option>
                    <option value="MahberatApprovedPickup">Pickup Approved</option>
                    <option value="ReceiptSubmitted">Receipt Submitted</option>
                    <option value="MahberatVerified">Mahberat Verified</option>
                    <option value="StaffApproved">Staff Approved</option>
                    <option value="Paid">Paid</option>
                    <option value="DispatcherRejected">Rejected</option>
                </select>
            </div>
            <button class="btn btn-primary btn-modern shadow-sm" onclick="loadRequests()"><i class="bi bi-arrow-clockwise me-1"></i> Refresh</button>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-5" id="statsRow">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card stat-card pending p-4 h-100">
                <i class="bi bi-inbox stat-icon text-warning"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Pending Review</h6>
                <div class="fs-1 fw-bolder text-dark" id="statPending">-</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card stat-card assigned p-4 h-100">
                <i class="bi bi-person-check stat-icon text-primary"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Driver Assigned</h6>
                <div class="fs-1 fw-bolder text-dark" id="statAssigned">-</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card stat-card active-trips p-4 h-100">
                <i class="bi bi-truck stat-icon text-success"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Active Trips</h6>
                <div class="fs-1 fw-bolder text-dark" id="statActive">-</div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card stat-card total p-4 h-100">
                <i class="bi bi-bar-chart stat-icon text-info"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-1">Total Requests</h6>
                <div class="fs-1 fw-bolder text-dark" id="statTotal">-</div>
            </div>
        </div>
    </div>

    <!-- Requests Table -->
    <div class="card table-card mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
            <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-list-ul me-2 text-primary"></i>Active Log</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="requestsTable">
                    <thead>
                        <tr>
                            <th class="ps-4">Request #</th>
                            <th>Mahberat</th>
                            <th>Route</th>
                            <th>Date</th>
                            <th>Driver Details</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="requestsBody">
                        <tr><td colspan="7" class="text-center py-5">
                            <div class="spinner-border text-primary mb-2" role="status"></div>
                            <div class="text-muted">Loading logistics data...</div>
                        </td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--success-gradient); color: white;">
                <h5 class="modal-title fw-bold"><i class="bi bi-shield-check me-2"></i>Assign Driver</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="approveRequestId" />
                
                <div class="alert alert-info border-0 bg-info bg-opacity-10 mb-4 rounded-3 d-flex align-items-center">
                    <i class="bi bi-info-circle-fill fs-4 text-info me-3"></i>
                    <small>Select an available driver. The vehicle is automatically matched to the driver's profile.</small>
                </div>

                <div class="mb-3">
                    <label class="form-label text-muted fw-bold small text-uppercase">Select Driver <span class="text-danger">*</span></label>
                    <select class="form-select form-select-lg" id="driverSelect">
                        <option value="">Loading drivers...</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label text-muted fw-bold small text-uppercase">Assigned Vehicle</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-truck text-muted"></i></span>
                        <input type="text" class="form-control bg-light border-start-0 ps-0 text-dark fw-bold" id="vehicleDisplay" readonly placeholder="Waiting for selection..." />
                    </div>
                    <input type="hidden" id="vehicleIdHidden" />
                </div>
                <div class="mb-2">
                    <label class="form-label text-muted fw-bold small text-uppercase">Dispatcher Notes (Optional)</label>
                    <textarea class="form-control" id="approveNotes" rows="2" placeholder="Add any special instructions..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light fw-bold px-4" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-success btn-modern px-4" onclick="submitApprove()"><i class="bi bi-check2-circle me-1"></i> Confirm Assignment</button>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-octagon me-2"></i>Reject Request</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="rejectRequestId" />
                <p class="text-muted">You are about to reject this transport request. This action cannot be undone.</p>
                <div class="mb-3">
                    <label class="form-label fw-bold text-uppercase small text-danger">Reason for Rejection <span class="text-danger">*</span></label>
                    <textarea class="form-control border-danger" id="rejectNotes" rows="3" placeholder="Explain why this request is being rejected..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-modern" onclick="submitReject()">Reject Request</button>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal -->
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content h-100">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-journal-text me-2"></i>Comprehensive Request Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light" id="detailBody">
                <div class="text-center py-5"><div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div></div>
            </div>
        </div>
    </div>
</div>

<script>
const API = '/api/transport';
const userId = @(HttpContext.Session.GetInt32("UserId") ?? 0);
const userName = '@(HttpContext.Session.GetString("UserName") ?? "")';
let allRequests = [];
let drivers = [];

async function loadStats() {
    const r = await fetch(`${API}/stats`);
    const s = await r.json();
    document.getElementById('statPending').textContent = s.pending ?? 0;
    document.getElementById('statAssigned').textContent = s.assigned ?? 0;
    document.getElementById('statActive').textContent = (s.accepted ?? 0) + (s.pickedUp ?? 0);
    document.getElementById('statTotal').textContent = s.total ?? 0;
}

async function loadRequests() {
    const status = document.getElementById('statusFilter').value;
    const url = status ? `${API}/requests?status=${status}` : `${API}/requests`;
    const r = await fetch(url);
    allRequests = await r.json();
    renderTable(allRequests);
}

function filterRequests() { loadRequests(); }

function statusBadge(s) {
    return `<span class="status-badge status-${s}">${s.replace(/([A-Z])/g,' $1').trim()}</span>`;
}

function renderTable(data) {
    const tbody = document.getElementById('requestsBody');
    if (!data.length) { 
        tbody.innerHTML = '<tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No requests found matching criteria</td></tr>'; 
        return; 
    }
    tbody.innerHTML = data.map(r => `
        <tr>
            <td class="ps-4">
                <span class="text-primary fw-bold">#${r.request_number}</span>
            </td>
            <td>
                <div class="fw-bold text-dark">${r.mahberat_user_name ?? ''}</div>
                <div class="text-muted small"><i class="bi bi-building me-1"></i>${r.mahberat_name || 'N/A'}</div>
            </td>
            <td>
                <div class="small fw-semibold text-dark"><i class="bi bi-geo-alt text-success me-1"></i>${r.pickup_location}</div>
                <div class="small text-muted"><i class="bi bi-flag text-danger me-1"></i>${r.destination}</div>
            </td>
            <td>
                <div class="fw-semibold text-dark">${r.requested_date ? r.requested_date.substring(0,10) : ''}</div>
                <div class="text-muted small"><i class="bi bi-clock me-1"></i>${r.requested_time ?? '--:--'}</div>
            </td>
            <td>
                <div class="fw-bold text-dark">${r.driver_name ?? '<span class="badge bg-light text-secondary border">Unassigned</span>'}</div>
                ${r.vehicle_plate ? `<div class="text-muted small"><i class="bi bi-truck me-1"></i>${r.vehicle_plate}</div>` : ''}
            </td>
            <td>${statusBadge(r.status)}</td>
            <td class="text-end pe-4">
                <button class="btn btn-sm btn-light border shadow-sm me-1 text-primary" onclick="showDetail(${r.id})" title="View Details"><i class="bi bi-eye"></i></button>
                ${r.status === 'PendingDispatcher' ? `
                    <button class="btn btn-sm btn-success shadow-sm me-1" onclick="openApprove(${r.id})" title="Assign Driver"><i class="bi bi-check-lg"></i></button>
                    <button class="btn btn-sm btn-danger shadow-sm" onclick="openReject(${r.id})" title="Reject"><i class="bi bi-x-lg"></i></button>
                ` : r.status === 'DriverAssigned' ? `
                    <button class="btn btn-sm btn-warning shadow-sm text-dark" onclick="openReassign(${r.id})" title="Reassign"><i class="bi bi-arrow-repeat"></i> Re-assign</button>
                ` : ''}
            </td>
        </tr>
        <tr class="tracker-row">
            <td colspan="7" class="p-0 border-0">${stepTracker(r.status)}</td>
        </tr>`).join('');
}

async function loadDrivers() {
    const r = await fetch(`${API}/drivers/available`);
    drivers = await r.json();
    const sel = document.getElementById('driverSelect');
    sel.innerHTML = '<option value="">-- Choose a Driver --</option>' +
        drivers.map(d => `<option value="${d.id}" data-vehicle-id="${d.vehicleId ?? ''}" data-vehicle-plate="${d.vehiclePlate ?? ''}">${d.name} ${d.vehiclePlate ? '— [' + d.vehiclePlate + ']' : ''}</option>`).join('');
    sel.onchange = function() {
        const opt = sel.options[sel.selectedIndex];
        document.getElementById('vehicleDisplay').value = opt.dataset.vehiclePlate || '';
        document.getElementById('vehicleIdHidden').value = opt.dataset.vehicleId || '';
    };
}

function openApprove(id) {
    document.getElementById('approveRequestId').value = id;
    document.getElementById('approveNotes').value = '';
    document.getElementById('vehicleDisplay').value = '';
    document.getElementById('vehicleIdHidden').value = '';
    
    const header = document.querySelector('#approveModal .modal-header');
    header.style.background = 'var(--success-gradient)';
    document.querySelector('#approveModal .modal-title').innerHTML = '<i class="bi bi-shield-check me-2"></i>Assign Driver';
    
    loadDrivers();
    new bootstrap.Modal(document.getElementById('approveModal')).show();
}

function openReassign(id) {
    document.getElementById('approveRequestId').value = id;
    document.getElementById('approveNotes').value = '';
    document.getElementById('vehicleDisplay').value = '';
    document.getElementById('vehicleIdHidden').value = '';
    
    const header = document.querySelector('#approveModal .modal-header');
    header.style.background = 'var(--warning-gradient)';
    document.querySelector('#approveModal .modal-title').innerHTML = '<i class="bi bi-arrow-repeat me-2"></i>Re-assign Driver';
    
    loadDrivers();
    new bootstrap.Modal(document.getElementById('approveModal')).show();
}

function openReject(id) {
    document.getElementById('rejectRequestId').value = id;
    document.getElementById('rejectNotes').value = '';
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
}

async function submitApprove() {
    const id = document.getElementById('approveRequestId').value;
    const driverId = document.getElementById('driverSelect').value;
    if (!driverId) { alert('Please select a driver.'); return; }
    const vehicleId = document.getElementById('vehicleIdHidden').value || null;
    const notes = document.getElementById('approveNotes').value;
    
    const btn = document.querySelector('#approveModal .btn-success');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Processing...';
    btn.disabled = true;

    try {
        const r = await fetch(`${API}/requests/${id}/dispatcher-action`, {
            method: 'POST', headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ dispatcherId: userId, dispatcherName: userName, action: 'Approve', driverId: parseInt(driverId), vehicleId: vehicleId ? parseInt(vehicleId) : null, notes })
        });
        const data = await r.json();
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('approveModal')).hide();
            loadRequests(); loadStats();
        } else {
            alert(data.message || 'Error processing request.');
        }
    } catch(e) {
        alert('A network error occurred.');
    } finally {
        btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Confirm Assignment';
        btn.disabled = false;
    }
}

async function submitReject() {
    const id = document.getElementById('rejectRequestId').value;
    const notes = document.getElementById('rejectNotes').value;
    if (!notes.trim()) { alert('Please provide a reason for rejection.'); return; }
    
    const r = await fetch(`${API}/requests/${id}/dispatcher-action`, {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ dispatcherId: userId, dispatcherName: userName, action: 'Reject', notes })
    });
    const data = await r.json();
    if (data.success) { bootstrap.Modal.getInstance(document.getElementById('rejectModal')).hide(); loadRequests(); loadStats(); }
    else alert(data.message || 'Error rejecting request');
}

