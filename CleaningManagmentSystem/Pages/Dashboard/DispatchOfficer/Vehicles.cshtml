@page
@model CleaningManagmentSystem.Pages.Dashboard.DispatchOfficer.VehiclesModel
@{
    Layout = "_DispatchLayout";
    ViewData["Title"] = "Vehicles";
}

@section Styles {
<style>
    body { background: #f4f6fb !important; }

    /* ── Page wrapper ───────────────────────────── */
    .page-wrap { padding: 0 4px; }

    /* ── Top bar ────────────────────────────────── */
    .top-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 14px;
    }
    .top-bar h5 { margin: 0; font-weight: 700; font-size: 1.05rem; color: #1e293b; }

    /* ── Stat badges ────────────────────────────── */
    .stat-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .75rem;
        font-weight: 600;
        padding: 4px 10px;
        border-radius: 20px;
        background: #f1f5f9;
        color: #475569;
    }
    .stat-badge .dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        display: inline-block;
    }

    /* ── Search bar ─────────────────────────────── */
    .search-bar {
        max-width: 260px;
    }
    .search-bar .input-group-text {
        background: #fff;
        border-right: none;
        border-color: #e2e8f0;
        color: #94a3b8;
    }
    .search-bar .form-control {
        border-left: none;
        border-color: #e2e8f0;
        font-size: .84rem;
    }
    .search-bar .form-control:focus {
        box-shadow: none;
        border-color: #93c5fd;
    }

    /* ── Table ──────────────────────────────────── */
    .v-table-wrap {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,.07);
        overflow: hidden;
    }
    .v-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .84rem;
    }
    .v-table thead th {
        background: #f8fafc;
        color: #64748b;
        font-weight: 600;
        font-size: .73rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        padding: 11px 16px;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
    }
    .v-table tbody tr {
        border-bottom: 1px solid #f1f5f9;
        transition: background .12s;
    }
    .v-table tbody tr:last-child { border-bottom: none; }
    .v-table tbody tr:hover { background: #f8fafc; }
    .v-table td {
        padding: 11px 16px;
        color: #334155;
        vertical-align: middle;
    }

    /* ── Plate cell ─────────────────────────────── */
    .plate-num {
        font-family: monospace;
        font-weight: 800;
        font-size: .92rem;
        color: #1d4ed8;
        letter-spacing: .5px;
    }

    /* ── Status pill ────────────────────────────── */
    .s-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
    }
    .s-available  { background: #dcfce7; color: #16a34a; }
    .s-assigned   { background: #dbeafe; color: #2563eb; }
    .s-maintenance{ background: #fef3c7; color: #d97706; }
    .s-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }

    /* ── Action buttons ─────────────────────────── */
    .act-btn {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        padding: 3px 9px;
        font-size: .72rem;
        font-weight: 500;
        border-radius: 6px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: opacity .12s;
        white-space: nowrap;
    }
    .act-btn:hover { opacity: .8; }
    .ab-avail  { background: #dcfce7; color: #16a34a; border-color: #bbf7d0; }
    .ab-maint  { background: #fef3c7; color: #d97706; border-color: #fde68a; }
    .ab-edit   { background: #eff6ff; color: #2563eb; border-color: #bfdbfe; }
    .ab-del    { background: #fff1f2; color: #e11d48; border-color: #fecdd3; }

    /* ── Empty state ────────────────────────────── */
    .empty-row td {
        text-align: center;
        padding: 48px 16px;
        color: #94a3b8;
    }
</style>
}

<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 main-content" style="margin-top:56px">
<div class="page-wrap">

    @{
        int avail    = Model.Vehicles.Count(v => v.Status == "Available");
        int assigned = Model.Vehicles.Count(v => v.Status == "Assigned");
        int maint    = Model.Vehicles.Count(v => v.Status == "Maintenance");
    }

    <!-- Top bar -->
    <div class="top-bar">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-truck text-primary"></i>
            <h5>Vehicle Management</h5>
            <span class="stat-badge ms-1">@Model.Vehicles.Count Total</span>
            <span class="stat-badge"><span class="dot" style="background:#16a34a"></span>@avail Available</span>
            <span class="stat-badge"><span class="dot" style="background:#2563eb"></span>@assigned Assigned</span>
            <span class="stat-badge"><span class="dot" style="background:#d97706"></span>@maint Maintenance</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="search-bar">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search" style="font-size:.8rem"></i></span>
                    <input type="text" id="searchBox" class="form-control" placeholder="Search…" oninput="filterRows()"/>
                </div>
            </div>
            <button class="btn btn-primary btn-sm rounded-3 px-3"
                    data-bs-toggle="modal" data-bs-target="#addModal">
                <i class="bi bi-plus-lg me-1"></i>Register
            </button>
        </div>
    </div>

    <!-- Alerts -->
    @if (!string.IsNullOrEmpty(Model.SuccessMessage)) {
    <div class="alert alert-success alert-dismissible fade show rounded-3 py-2 mb-3" style="font-size:.85rem">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage)) {
    <div class="alert alert-danger alert-dismissible fade show rounded-3 py-2 mb-3" style="font-size:.85rem">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    }

    <!-- Table -->
    <div class="v-table-wrap">
        <table class="v-table" id="vehicleTable">
            <thead>
                <tr>
                    <th style="width:40px">#</th>
                    <th>Plate Number</th>
                    <th>Type</th>
                    <th>Model</th>
                    <th>Color</th>
                    <th>Status</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Vehicles.Any()) {
                <tr class="empty-row">
                    <td colspan="7">
                        <i class="bi bi-truck fs-2 d-block mb-2 opacity-25"></i>
                        No vehicles registered yet.<br/>
                        <button class="btn btn-primary btn-sm rounded-3 mt-3 px-3"
                                data-bs-toggle="modal" data-bs-target="#addModal">
                            <i class="bi bi-plus-lg me-1"></i>Register Vehicle
                        </button>
                    </td>
                </tr>
                } else {
                    int row = 1;
                    @foreach (var v in Model.Vehicles) {
                        var pillClass = v.Status switch {
                            "Available"   => "s-available",
                            "Assigned"    => "s-assigned",
                            "Maintenance" => "s-maintenance",
                            _             => "s-maintenance"
                        };
                <tr class="v-row" data-search="@v.PlateNumber @v.VehicleType @v.Model @v.Color @v.Status".ToLower()>
                    <td style="color:#cbd5e1;font-size:.78rem">@row</td>
                    <td><span class="plate-num">@v.PlateNumber</span></td>
                    <td>@v.VehicleType</td>
                    <td>@(string.IsNullOrEmpty(v.Model) ? "-" : v.Model)</td>
                    <td>@(string.IsNullOrEmpty(v.Color) ? "-" : v.Color)</td>
                    <td>
                        <span class="s-pill @pillClass">
                            <span class="s-dot"></span>@v.Status
                        </span>
                    </td>
                    <td>
                        <div class="d-flex justify-content-end gap-1 flex-wrap">
                            @if (v.Status != "Available") {
                            <form method="post" asp-page-handler="SetStatus" style="display:inline">
                                <input type="hidden" name="id" value="@v.Id"/>
                                <input type="hidden" name="status" value="Available"/>
                                <button type="submit" class="act-btn ab-avail">
                                    <i class="bi bi-check-circle" style="font-size:.75rem"></i> Available
                                </button>
                            </form>
                            }
                            @if (v.Status != "Maintenance") {
                            <form method="post" asp-page-handler="SetStatus" style="display:inline">
                                <input type="hidden" name="id" value="@v.Id"/>
                                <input type="hidden" name="status" value="Maintenance"/>
                                <button type="submit" class="act-btn ab-maint">
                                    <i class="bi bi-tools" style="font-size:.75rem"></i> Maintenance
                                </button>
                            </form>
                            }
                            <button class="act-btn ab-edit"
                                    onclick="openEdit(@v.Id, '@v.PlateNumber', '@v.VehicleType', '@(v.Model?.Replace("'", "\\'"))', '@(v.Color?.Replace("'", "\\'"))', '@v.Status')">
                                <i class="bi bi-pencil" style="font-size:.75rem"></i> Edit
                            </button>
                            <form method="post" asp-page-handler="Delete" style="display:inline"
                                  onsubmit="return confirm('Delete @v.PlateNumber?')">
                                <input type="hidden" name="id" value="@v.Id"/>
                                <button type="submit" class="act-btn ab-del">
                                    <i class="bi bi-trash" style="font-size:.75rem"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                        row++;
                    }
                }
            </tbody>
        </table>
    </div>

</div>
</main>

<!-- ══ ADD MODAL ══════════════════════════════════════════════════════════ -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h6 class="modal-title fw-bold"><i class="bi bi-plus-circle text-primary me-2"></i>Register Vehicle</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Add">
                <div class="modal-body px-4 py-3">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Plate Number <span class="text-danger">*</span></label>
                        <input name="PlateNumber" class="form-control rounded-3" placeholder="e.g. AA-12345" required/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Vehicle Type <span class="text-danger">*</span></label>
                        <select name="VehicleType" class="form-select rounded-3" required>
                            <option value="">-- Select --</option>
                            <option>Truck</option>
                            <option>Van</option>
                            <option>Car</option>
                            <option>Pickup</option>
                            <option>Minibus</option>
                            <option>Motorcycle</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Model</label>
                        <input name="Model" class="form-control rounded-3" placeholder="e.g. Hilux, FSR..."/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Color</label>
                        <input name="Color" class="form-control rounded-3" placeholder="e.g. White, Blue..."/>
                    </div>
                    <div class="mb-1">
                        <label class="form-label small fw-semibold">Status</label>
                        <select name="Status" class="form-select rounded-3">
                            <option value="Available">Available</option>
                            <option value="Assigned">Assigned</option>
                            <option value="Maintenance">Maintenance</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-1">
                    <button type="button" class="btn btn-secondary btn-sm rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm rounded-3 px-4">
                        <i class="bi bi-save me-1"></i>Register
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ══ EDIT MODAL ════════════════════════════════════════════════════════ -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h6 class="modal-title fw-bold"><i class="bi bi-pencil text-success me-2"></i>Edit Vehicle</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <div class="modal-body px-4 py-3">
                    <input type="hidden" name="EditId" id="editId"/>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Plate Number <span class="text-danger">*</span></label>
                        <input id="editPlate" name="PlateNumber" class="form-control rounded-3" required/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Vehicle Type</label>
                        <select id="editType" name="VehicleType" class="form-select rounded-3">
                            <option>Truck</option><option>Van</option><option>Car</option>
                            <option>Pickup</option><option>Minibus</option><option>Motorcycle</option><option>Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Model</label>
                        <input id="editModel" name="Model" class="form-control rounded-3"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Color</label>
                        <input id="editColor" name="Color" class="form-control rounded-3"/>
                    </div>
                    <div class="mb-1">
                        <label class="form-label small fw-semibold">Status</label>
                        <select id="editStatus" name="Status" class="form-select rounded-3">
                            <option value="Available">Available</option>
                            <option value="Assigned">Assigned</option>
                            <option value="Maintenance">Maintenance</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4 pt-1">
                    <button type="button" class="btn btn-secondary btn-sm rounded-3" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-sm rounded-3 px-4">
                        <i class="bi bi-save me-1"></i>Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function openEdit(id, plate, type, model, color, status) {
    document.getElementById('editId').value     = id;
    document.getElementById('editPlate').value  = plate;
    document.getElementById('editType').value   = type;
    document.getElementById('editModel').value  = model;
    document.getElementById('editColor').value  = color;
    document.getElementById('editStatus').value = status;
    new bootstrap.Modal(document.getElementById('editModal')).show();
}

function filterRows() {
    const q = document.getElementById('searchBox').value.toLowerCase();
    document.querySelectorAll('#vehicleTable .v-row').forEach(row => {
        row.style.display = row.dataset.search.includes(q) ? '' : 'none';
    });
}
</script>
}
