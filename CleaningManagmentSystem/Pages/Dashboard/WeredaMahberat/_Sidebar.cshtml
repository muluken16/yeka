                <span class="nav-label ms-2">Logout</span>
            </a>
        </li>
    </ul>
</div>

<script>
(function() {
    // Restore collapse state from localStorage
    var collapsed = localStorage.getItem('sidebarCollapsed') === '1';
    if (collapsed) _applySidebarCollapse(true, false);

    function _applySidebarCollapse(isCollapsed, animate) {
        var body = document.body;
        var icon = document.getElementById('sidebarToggleIcon');
        if (isCollapsed) {
            body.classList.add('sidebar-collapsed');
            if (icon) { icon.classList.remove('bi-chevron-left'); icon.classList.add('bi-chevron-right'); }
        } else {
            body.classList.remove('sidebar-collapsed');
            if (icon) { icon.classList.remove('bi-chevron-right'); icon.classList.add('bi-chevron-left'); }
        }
    }

    window.toggleSidebarCollapse = function() {
        var isNowCollapsed = !document.body.classList.contains('sidebar-collapsed');
        _applySidebarCollapse(isNowCollapsed, true);
        localStorage.setItem('sidebarCollapsed', isNowCollapsed ? '1' : '0');
    };
})();
</script>
