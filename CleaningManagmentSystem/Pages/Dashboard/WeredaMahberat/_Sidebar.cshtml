                <span class="nav-label ms-2">
                    <span class="text-success fw-semibold">Monthly Receipt</span>
                    <span style="background:#10b981;color:#fff;font-size:.58rem;padding:1px 5px;border-radius:8px;margin-left:4px;font-weight:700">Paid</span>
