        <i class="bi bi-droplet-fill text-info fs-5 flex-shrink-0"></i>
        <div class="sidebar-brand-text">
            <div class="text-white fw-bold" style="font-size:.95rem;line-height:1.2">Yeka Cleaning</div>
            <div class="text-white-50" style="font-size:.68rem">Wereda Mahberat</div>
        </div>
    </div>

    <ul class="nav flex-column">
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat", true) ? "active" : "")" href="/Dashboard/WeredaMahberat" title="Dashboard">
                <i class="bi bi-speedometer2 flex-shrink-0"></i>
                <span class="nav-label ms-2">Dashboard</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/PayrollReport") ? "active" : "")" href="/Dashboard/WeredaMahberat/PayrollReport" title="Payroll Report">
                <i class="bi bi-cash-stack flex-shrink-0"></i>
                <span class="nav-label ms-2">Payroll Report</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/Capital") ? "active" : "")" href="/Dashboard/WeredaMahberat/Capital" title="Capital">
                <i class="bi bi-bank flex-shrink-0"></i>
                <span class="nav-label ms-2">Capital</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/Gallery") ? "active" : "")" href="/Dashboard/WeredaMahberat/Gallery" title="Gallery">
                <i class="bi bi-images flex-shrink-0"></i>
                <span class="nav-label ms-2">Gallery</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/Contact") ? "active" : "")" href="/Dashboard/WeredaMahberat/Contact" title="Contact">
                <i class="bi bi-envelope flex-shrink-0"></i>
                <span class="nav-label ms-2">Contact</span>
            </a>
        </li>

        <!-- Divider -->
        <li class="nav-item">
            <div style="border-top:1px solid rgba(255,255,255,.15);margin:6px 12px"></div>
        </li>

        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/TransportRequests") ? "active" : "")" href="/Dashboard/WeredaMahberat/TransportRequests" title="Transport Requests">
                <i class="bi bi-truck flex-shrink-0"></i>
                <span class="nav-label ms-2">Transport Requests</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(IsActive("/Dashboard/WeredaMahberat/MonthlyReceipt") ? "active" : "")" href="/Dashboard/WeredaMahberat/MonthlyReceipt"
