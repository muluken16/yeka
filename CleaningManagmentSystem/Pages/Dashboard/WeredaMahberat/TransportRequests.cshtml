@page
@model CleaningManagmentSystem.Pages.Dashboard.WeredaMahberat.TransportRequestsModel
@{
    var userName = HttpContext.Session.GetString("UserName");
    var userId   = HttpContext.Session.GetInt32("UserId") ?? 0;
    if (userName == null) { Response.Redirect("/Login"); return; }
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Transport Requests — Yeka Cleaning</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/dashboard.css"/>
<style>
/* ── base ── */
body { background:#f4f6fb !important; }

/* ── page header ── */
.pg-top {
  display:flex; align-items:center; justify-content:space-between;
  flex-wrap:wrap; gap:10px;
  padding:14px 0 14px; border-bottom:2px solid #e2e8f0;
  margin-bottom:18px;
}
.pg-top-left { display:flex; align-items:center; gap:10px; }
.pg-top-icon {
  width:38px; height:38px; border-radius:10px;
  background:linear-gradient(135deg,#1d4ed8,#0891b2);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:1.1rem; flex-shrink:0;
}
.pg-top h1 { font-size:1.1rem; font-weight:800; color:#1e293b; margin:0; }
.pg-top small { font-size:.73rem; color:#64748b; display:block; margin-top:1px; }
.btn-new {
  background:linear-gradient(135deg,#1d4ed8,#0891b2);
  color:#fff; border:none; padding:8px 18px;
  border-radius:10px; font-weight:700; font-size:.82rem; cursor:pointer;
  display:inline-flex; align-items:center; gap:6px; transition:all .2s;
}

/* ── stats ── */
.stats-row { display:grid; grid-template-columns:repeat(5,1fr); gap:10px; margin-bottom:20px; }
@@media(max-width:640px){ .stats-row { grid-template-columns:repeat(3,1fr); } }
.stat-box {
  background:#fff; border-radius:14px; padding:14px 10px; text-align:center;
  box-shadow:0 1px 4px rgba(0,0,0,.06); border-top:3px solid var(--c,#1d4ed8);
}
.stat-box .sv { font-size:1.8rem; font-weight:900; color:var(--c,#1d4ed8); line-height:1; }
.stat-box .sl { font-size:.68rem; color:#6b7280; margin-top:2px; }

/* ── action alert ── */
.act-alert {
  background:linear-gradient(135deg,#fef3c7,#fde68a);
  border:1px solid #fbbf24; border-radius:14px; padding:14px 18px; margin-bottom:16px;
}
.act-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:9px 0; border-bottom:1px dashed #fcd34d; gap:10px; flex-wrap:wrap;
}
.act-row:last-child { border:none; padding-bottom:0; }

/* ── main table ── */
.req-table-wrap {
  background:#fff; border-radius:16px;
  box-shadow:0 1px 4px rgba(0,0,0,.07),0 4px 16px rgba(0,0,0,.04);
  overflow:hidden; margin-bottom:24px;
}
.req-table-head { background:linear-gradient(135deg,#1d4ed8,#0891b2); }
.req-table-head th {
  color:#fff; font-weight:700; font-size:.76rem; padding:11px 14px;
  white-space:nowrap; letter-spacing:.3px;
}
.req-table tbody tr { transition:background .15s; }
.req-table tbody tr:hover td { background:#eff6ff; }
.req-table td { font-size:.81rem; padding:11px 14px; vertical-align:middle; border-top:1px solid #f1f5f9; }
.req-table tbody tr:nth-child(even) td { background:#f8fafc; }
.req-table tbody tr:nth-child(even):hover td { background:#eff6ff; }

/* ── path steps inline ── */
.path-row {
  display:flex; align-items:center; gap:0; font-size:.62rem;
  white-space:nowrap; overflow-x:auto;
}
.ps { display:flex; align-items:center; gap:0; }
.ps-dot {
  width:20px; height:20px; border-radius:50%; display:inline-flex;
  align-items:center; justify-content:center; font-size:9px; font-weight:800;
  border:2px solid #e2e8f0; background:#fff; color:#94a3b8; flex-shrink:0;
}
.ps-dot.done  { background:#1d4ed8; border-color:#1d4ed8; color:#fff; }
.ps-dot.active{ background:#fff; border-color:#1d4ed8; color:#1d4ed8;
  box-shadow:0 0 0 3px rgba(29,78,216,.15); }
.ps-dot.rej   { background:#ef4444; border-color:#ef4444; color:#fff; }
.ps-dot.paid  { background:#059669; border-color:#059669; color:#fff; }
.ps-line { width:14px; height:2px; background:#e2e8f0; flex-shrink:0; }
.ps-line.done { background:#1d4ed8; }
.ps-lbl { font-size:.58rem; color:#94a3b8; margin-top:2px; text-align:center; max-width:44px; line-height:1.2; }
.ps-lbl.done,.ps-lbl.active { color:#1d4ed8; font-weight:700; }
.ps-lbl.paid { color:#059669; font-weight:700; }
.ps-lbl.rej  { color:#ef4444; font-weight:700; }
.ps-col { display:flex; flex-direction:column; align-items:center; }

/* ── status badge ── */
.sb { display:inline-flex; align-items:center; gap:3px; padding:3px 9px;
  border-radius:20px; font-size:.68rem; font-weight:700; white-space:nowrap; }
.sb-blue  { background:#dbeafe; color:#1e40af; }
.sb-green { background:#d1fae5; color:#065f46; }
.sb-amber { background:#fef3c7; color:#92400e; }
.sb-purple{ background:#ede9fe; color:#4c1d95; }
.sb-teal  { background:#ccfbf1; color:#0f4c3a; }
.sb-pay   { background:#059669; color:#fff; }
.sb-red   { background:#fee2e2; color:#7f1d1d; }
.sb-gray  { background:#f1f5f9; color:#475569; }

/* ── action buttons ── */
.btn-act {
  padding:5px 12px; border-radius:8px; border:none; font-size:.74rem;
  font-weight:600; cursor:pointer; display:inline-flex; align-items:center;
  gap:4px; transition:all .15s; white-space:nowrap;
}
.btn-act-primary { background:#1d4ed8; color:#fff; }
.btn-act-primary:hover { background:#1e40af; }
.btn-act-success { background:#059669; color:#fff; }
.btn-act-success:hover { background:#047857; }
.btn-act-outline {
  background:#fff; color:#64748b; border:1.5px solid #e2e8f0;
}
.btn-act-outline:hover { border-color:#1d4ed8; color:#1d4ed8; }
.btn-act-amber { background:#f59e0b; color:#fff; }
.btn-act-amber:hover { background:#d97706; }

/* ── section title ── */
.sec-title {
  display:flex; align-items:center; gap:8px;
  font-weight:800; font-size:.9rem; color:#1e293b; margin-bottom:8px;
}
.sec-badge {
  padding:2px 8px; border-radius:12px; font-size:.68rem; font-weight:700;
}

/* ── bills table ── */
.bill-table-wrap {
  background:#fff; border-radius:16px; overflow:hidden;
  box-shadow:0 1px 4px rgba(0,0,0,.06); margin-bottom:24px;
  border:1px solid #d1fae5;
}
.bill-table-head th {
  background:linear-gradient(135deg,#059669,#0d9488);
  color:#fff; font-weight:700; font-size:.76rem; padding:10px 12px;
}
.bill-table td { font-size:.8rem; padding:9px 12px; vertical-align:middle; }
.bill-table tbody tr:nth-child(even) td { background:#f0fdf4; }
.bill-table tbody tr:hover td { background:#d1fae5; }

/* ── rejected table ── */
.rej-table-wrap {
  background:#fff; border-radius:14px; overflow:hidden;
  border:1px solid #fecaca; margin-bottom:24px;
}

/* ── notice box ── */
.notice-box {
  background:#eff6ff; border:1px solid #bfdbfe; border-radius:12px;
  padding:11px 16px; margin-bottom:16px; display:flex;
  align-items:center; justify-content:space-between; flex-wrap:wrap; gap:8px;
}
.notice-box a.view-btn {
  background:#1d4ed8; color:#fff; padding:5px 14px; border-radius:8px;
  font-size:.76rem; font-weight:600; text-decoration:none;
  display:inline-flex; align-items:center; gap:4px;
}

/* ── empty ── */
.empty-box {
  text-align:center; padding:40px 20px; color:#94a3b8;
}
.empty-box .ei { font-size:3rem; opacity:.2; display:block; margin-bottom:8px; }

/* ── toast ── */
.tp-toast {
  position:fixed; bottom:24px; right:24px; z-index:9999;
  padding:12px 18px; border-radius:12px; font-size:.83rem; font-weight:600;
  box-shadow:0 8px 24px rgba(0,0,0,.15); display:flex; align-items:center;
  gap:8px; animation:slideUp .3s ease;
}
@@keyframes slideUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

/* ── modal polish ── */
.modal-content { border:none; border-radius:18px; box-shadow:0 20px 60px rgba(0,0,0,.18); }
.modal-header  { border:none; border-radius:18px 18px 0 0; }
.modal-footer  { border:none; }
</style>
</head>
<body>
<div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

<!-- Navbar -->
<nav class="navbar navbar-dark dashboard-navbar fixed-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/Dashboard/WeredaMahberat"><i class="bi bi-droplet-fill"></i> Yeka Cleaning</a>
    <div class="nav-user">
      @await Html.PartialAsync("~/Pages/Dashboard/WeredaMahberat/_NavProfileDropdown.cshtml")
    </div>
  </div>
</nav>
<nav class="navbar navbar-dark dashboard-navbar fixed-top d-lg-none">
  <div class="container-fluid">
    <button class="navbar-toggler" type="button" onclick="toggleSidebar()"><span class="navbar-toggler-icon"></span></button>
    <a class="navbar-brand" href="/Dashboard/WeredaMahberat"><i class="bi bi-droplet-fill"></i> Yeka</a>
    <a class="btn-logout" href="/Login?logout=1"><i class="bi bi-box-arrow-right"></i></a>
  </div>
</nav>

<!-- Sidebar -->
<nav id="sidebarMenu" class="sidebar d-lg-none">
  @await Html.PartialAsync("~/Pages/Dashboard/WeredaMahberat/_Sidebar.cshtml")
</nav>
<nav class="col-md-3 col-lg-2 d-none d-md-block sidebar" style="transform:none;padding-top:56px;">
  @await Html.PartialAsync("~/Pages/Dashboard/WeredaMahberat/_Sidebar.cshtml")
</nav>

<!-- Main -->
<main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 main-content" style="padding-top:24px!important">

  <!-- Compact Page Header -->
  <div class="pg-top">
    <div class="pg-top-left">
      <div class="pg-top-icon"><i class="bi bi-truck"></i></div>
      <div>
        <h1>Transport Requests</h1>
        <small>Track and manage your transport requests</small>
      </div>
    </div>
    <button class="btn-new" data-bs-toggle="modal" data-bs-target="#newRequestModal">
      <i class="bi bi-plus-circle-fill"></i> New Request
    </button>
  </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-box" style="--c:#f59e0b">
        <i class="bi bi-hourglass-split" style="color:#f59e0b;font-size:1.1rem"></i>
        <div class="sv" id="statPending">—</div><div class="sl">Pending</div>
      </div>
      <div class="stat-box" style="--c:#0891b2">
        <i class="bi bi-truck" style="color:#0891b2;font-size:1.1rem"></i>
        <div class="sv" id="statActive">—</div><div class="sl">Active</div>
      </div>
      <div class="stat-box" style="--c:#8b5cf6">
        <i class="bi bi-receipt" style="color:#8b5cf6;font-size:1.1rem"></i>
        <div class="sv" id="statReceipt">—</div><div class="sl">Receipt</div>
      </div>
      <div class="stat-box" style="--c:#059669">
        <i class="bi bi-cash-coin" style="color:#059669;font-size:1.1rem"></i>
        <div class="sv" id="statPaid">—</div><div class="sl">Paid</div>
      </div>
      <div class="stat-box" style="--c:#1d4ed8">
        <i class="bi bi-list-ul" style="color:#1d4ed8;font-size:1.1rem"></i>
        <div class="sv" id="statTotal">—</div><div class="sl">Total</div>
      </div>
    </div>

    <!-- Action Required Banner -->
    <div id="actionRequired"></div>

    <!-- Refresh bar -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div style="font-weight:700;font-size:.88rem;color:#1e293b">
        <i class="bi bi-table me-1 text-primary"></i> All Requests
      </div>
      <button class="btn-act btn-act-outline" onclick="loadRequests();loadStats()">
        <i class="bi bi-arrow-clockwise"></i> Refresh
      </button>
    </div>

    <!-- Main content area -->
    <div id="cardsContainer">
      <div class="empty-box"><span class="ei"><i class="bi bi-hourglass-split"></i></span>Loading…</div>
    </div>

  </div>
</main>

<!-- ══════════════════════════════════════════════════════════
     MODALS
══════════════════════════════════════════════════════════ -->

<!-- New Request Modal -->
<div class="modal fade" id="newRequestModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:linear-gradient(135deg,#1d4ed8,#0891b2)">
        <h5 class="modal-title"><i class="bi bi-truck me-2"></i>New Transport Request</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label fw-semibold">Pickup Location <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="pickup" placeholder="Enter pickup address"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Destination <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="destination" placeholder="Enter destination"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Requested Date <span class="text-danger">*</span></label>
            <input type="date" class="form-control" id="reqDate" min="@DateTime.Now.ToString("yyyy-MM-dd")"/>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Requested Time</label>
            <input type="time" class="form-control" id="reqTime"/>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Passenger / Item Details</label>
            <textarea class="form-control" id="details" rows="2" placeholder="Who or what is being transported?"></textarea>
          </div>
          <div class="col-12">
            <label class="form-label fw-semibold">Special Instructions</label>
            <textarea class="form-control" id="instructions" rows="2" placeholder="Any special requirements…"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer px-4 pb-4">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary px-4" onclick="submitRequest()">
          <i class="bi bi-send me-1"></i>Submit Request
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Pickup Confirm Modal -->
<div class="modal fade" id="pickupModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:linear-gradient(135deg,#0891b2,#0e7490)">
        <h5 class="modal-title"><i class="bi bi-box-seam me-2"></i>Confirm Pickup</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <input type="hidden" id="pickupRequestId"/>
        <div class="alert alert-info border-0 py-2">
          <i class="bi bi-info-circle me-2"></i><span id="pickupDesc"></span>
        </div>
        <label class="form-label fw-semibold">Notes</label>
        <textarea class="form-control" id="pickupNotes" rows="2" placeholder="Optional notes…"></textarea>
      </div>
      <div class="modal-footer px-4 pb-4">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-danger" onclick="pickupAction('Reject')"><i class="bi bi-x-circle me-1"></i>Reject</button>
        <button class="btn btn-success px-4" onclick="pickupAction('Approve')"><i class="bi bi-check-circle me-1"></i>Confirm</button>
      </div>
    </div>
  </div>
</div>

<!-- Receipt Approve Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header text-white" style="background:linear-gradient(135deg,#059669,#0d9488)">
        <h5 class="modal-title"><i class="bi bi-receipt-cutoff me-2"></i>Approve Receipt — Mahberat Level 1</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <input type="hidden" id="receiptRequestId"/>
        <div class="px-4 pt-3 pb-2 bg-light border-bottom">
          <div class="row g-2" id="receiptTripInfo">
            <div class="col-12 text-center text-muted py-2"><div class="spinner-border spinner-border-sm"></div> Loading…</div>
          </div>
        </div>
        <div class="px-4 py-3">
          <div class="row g-3 mb-3" id="receiptKgTotal"></div>
          <div id="receiptPhotoContainer" class="mb-3"></div>
          <div id="receiptDriverNotes" class="mb-3"></div>
          <label class="form-label fw-semibold"><i class="bi bi-chat-left-text me-1 text-success"></i>Your Approval Notes</label>
          <textarea class="form-control" id="receiptNotes" rows="2" placeholder="e.g. KG verified, service satisfactory…"></textarea>
        </div>
      </div>
      <div class="modal-footer px-4 pb-4 justify-content-between">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <div class="d-flex gap-2">
          <button class="btn btn-warning" onclick="receiptAction('RequestCorrection')"><i class="bi bi-pencil me-1"></i>Request Correction</button>
          <button class="btn btn-success px-4" onclick="receiptAction('Verify')"><i class="bi bi-check-circle me-1"></i>Approve & Forward to Staff</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Approval Form Modal -->
<div class="modal fade" id="approvalFormModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title w-100 text-center fw-bold"><i class="bi bi-file-earmark-check me-2"></i>Receipt Approval Form</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4" id="approvalFormBody">
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
      </div>
      <div class="modal-footer justify-content-between px-4">
        <div id="approvalFormActions" class="d-flex gap-2"></div>
        <div class="d-flex gap-2">
          <button class="btn btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-1"></i>Print</button>
          <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Level 1 Approve Modal -->
<div class="modal fade" id="level1ApproveModal" tabindex="-1" style="z-index:1060">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title"><i class="bi bi-check-circle me-2"></i>Approve — Level 1 (Mahberat)</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-4">
        <input type="hidden" id="l1RequestId"/>
        <div class="alert alert-info py-2 small"><i class="bi bi-info-circle me-2"></i>Your approval forwards this to <strong>Staff</strong> for final payment.</div>
        <label class="form-label fw-semibold">Your Comments <span class="text-danger">*</span></label>
        <textarea class="form-control" id="l1Comments" rows="3" placeholder="e.g. Driver arrived on time, service was satisfactory…"></textarea>
      </div>
      <div class="modal-footer px-4 pb-4">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-success px-4" onclick="submitLevel1Approve()"><i class="bi bi-check-circle me-1"></i>Approve & Forward</button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════════════════════ -->
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
const API      = '/api/transport';
const userId   = @userId;
const userName = '@Html.Raw(userName?.Replace("'","\\'")??"")';

// ── sidebar ──────────────────────────────────────────────
function toggleSidebar() {
  document.getElementById('sidebarMenu').classList.toggle('show');
  document.getElementById('sidebarBackdrop').classList.toggle('show');
}

// ── status config ─────────────────────────────────────────
const STATUS_CFG = {
  PendingDispatcher :{ label:'Pending Dispatch', cls:'sb-amber',  icon:'hourglass-split'   },
  DriverAssigned    :{ label:'Driver Assigned',  cls:'sb-blue',   icon:'person-check'      },
  DriverAccepted    :{ label:'Driver Accepted',  cls:'sb-blue',   icon:'truck'             },
  PickedUp          :{ label:'Picked Up',        cls:'sb-teal',   icon:'box-seam'          },
  MahberatApprovedPickup:{ label:'Pickup OK',    cls:'sb-green',  icon:'check-circle'      },
  ReceiptSubmitted  :{ label:'Receipt Submitted',cls:'sb-purple', icon:'receipt'           },
  MahberatVerified  :{ label:'You Approved',     cls:'sb-green',  icon:'patch-check'       },
  ReceiptVerified   :{ label:'Staff Verified',   cls:'sb-green',  icon:'shield-check'      },
  StaffApproved     :{ label:'Staff Approved',   cls:'sb-green',  icon:'check2-circle'     },
  Paid              :{ label:'Paid ✓',           cls:'sb-pay',    icon:'cash-coin'         },
  DispatcherRejected:{ label:'Rejected',         cls:'sb-red',    icon:'x-circle'          },
  DriverRejected    :{ label:'Rejected',         cls:'sb-red',    icon:'x-circle'          },
  StaffRejected     :{ label:'Rejected',         cls:'sb-red',    icon:'x-circle'          },
};
function statusBadge(s) {
  const c = STATUS_CFG[s] || { label: s.replace(/([A-Z])/g,' $1').trim(), cls:'sb-gray', icon:'circle' };
  return `<span class="sb ${c.cls}"><i class="bi bi-${c.icon}"></i> ${c.label}</span>`;
}

// ── path steps ────────────────────────────────────────────
const PATH_STEPS = [
  { key:'PendingDispatcher',       short:'Submit'    },
  { key:'DriverAssigned',          short:'Dispatch'  },
  { key:'DriverAccepted',          short:'Accept'    },
  { key:'PickedUp',                short:'Pickup'    },
  { key:'MahberatApprovedPickup',  short:'OK Pickup' },
  { key:'ReceiptSubmitted',        short:'Receipt'   },
  { key:'MahberatVerified',        short:'Verified'  },
  { key:'StaffApproved',           short:'Approved'  },
  { key:'Paid',                    short:'Paid'      },
];
const REJECTED_S = ['DispatcherRejected','DriverRejected','StaffRejected'];
const PAID_S     = ['Paid','StaffApproved','ReceiptVerified'];

function buildPath(status) {
  if (REJECTED_S.includes(status))
    return `<span style="color:#ef4444;font-size:.72rem;font-weight:700"><i class="bi bi-x-circle me-1"></i>${status.replace('Rejected','').replace(/([A-Z])/g,' $1').trim()} Rejected</span>`;

  const idx = PATH_STEPS.findIndex(s => s.key === status);
  const isPaid = status === 'Paid';

  return `<div class="path-row">` + PATH_STEPS.map((s, i) => {
    let dotCls = '';
    if (isPaid || i < idx)       dotCls = isPaid ? 'paid' : 'done';
    else if (i === idx)          dotCls = 'active';
    const lineCls = (i < idx || isPaid) ? 'done' : '';
    const lblCls  = dotCls;
    const icon    = (dotCls === 'done' || dotCls === 'paid') ? '✓' : (i + 1);
    const line    = i < PATH_STEPS.length - 1 ? `<div class="ps-line ${lineCls}"></div>` : '';
    return `<div class="ps-col">
      <div class="ps-dot ${dotCls}">${icon}</div>
      <div class="ps-lbl ${lblCls}">${s.short}</div>
    </div>${line}`;
  }).join('') + `</div>`;
}

// ── stats ─────────────────────────────────────────────────
async function loadStats() {
  const r = await fetch(`${API}/stats?userId=${userId}&role=WeredaMahberat`);
  const s = await r.json();
  document.getElementById('statPending').textContent  = s.pending ?? 0;
  document.getElementById('statActive').textContent   = (s.assigned??0)+(s.accepted??0)+(s.pickedUp??0);
  document.getElementById('statReceipt').textContent  = (s.receiptSubmitted??0)+(s.receiptVerified??0);
  document.getElementById('statPaid').textContent     = s.paid ?? 0;
  document.getElementById('statTotal').textContent    = s.total ?? 0;
}

// ── load & render ─────────────────────────────────────────
