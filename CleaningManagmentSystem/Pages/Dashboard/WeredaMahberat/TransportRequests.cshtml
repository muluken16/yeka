        </tbody>
      </table>
      <div class="fw-bold bg-dark text-white px-2 py-1 mb-2">D — Activity Log</div>
      <div class="px-2">
        ${logs.length?logs.map((l,i)=>`
        <div class="d-flex mb-2">
          <div class="me-2 text-center" style="min-width:26px">
            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:22px;height:22px;font-size:10px">${i+1}</div>
          </div>
          <div class="bg-light rounded p-2 flex-grow-1">
            <div class="d-flex justify-content-between">
              <strong>${l.actor_name??'System'}</strong>
              <small class="text-muted">${new Date(l.created_at).toLocaleString()}</small>
            </div>
            <span class="badge bg-secondary me-1">${l.from_status||'Start'}</span>
            <i class="bi bi-arrow-right text-muted me-1"></i>
            <span class="badge bg-primary">${l.to_status}</span>
            ${l.notes?`<div class="mt-1 small fst-italic text-muted">"${l.notes}"</div>`:''}
          </div>
        </div>`).join(''):'<p class="text-muted">No activity logged.</p>'}
      </div>
    </div>`;
    const lvl1 = req.level_1_mahberat_status;
    if (!lvl1||lvl1==='Pending') {
      document.getElementById('approvalFormActions').innerHTML = `<button class="btn btn-success" onclick="openLevel1Approve(${id})"><i class="bi bi-check-circle me-1"></i>Approve (Level 1)</button>`;
    } else {
      document.getElementById('approvalFormActions').innerHTML = `<span class="text-success fw-semibold"><i class="bi bi-check-circle-fill me-1"></i>Level 1 Approved</span>`;
    }
  } catch(err) {
    document.getElementById('approvalFormBody').innerHTML = `<div class="alert alert-danger">Error loading form: ${err.message}</div>`;
  }
}
function openLevel1Approve(id) {
  document.getElementById('l1RequestId').value = id;
  document.getElementById('l1Comments').value  = '';
  new bootstrap.Modal(document.getElementById('level1ApproveModal')).show();
}
async function submitLevel1Approve() {
  const id  = document.getElementById('l1RequestId').value;
  const cmt = document.getElementById('l1Comments').value.trim();
  if (!cmt) { alert('Please enter your comments.'); return; }
  const r = await fetch(`/api/transport/requests/${id}/mahberat-verify`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ userId, userName, action:'Verify', notes: cmt })
  });
  const d = await r.json();
  if (d.success) {
    bootstrap.Modal.getInstance(document.getElementById('level1ApproveModal'))?.hide();
    bootstrap.Modal.getInstance(document.getElementById('approvalFormModal'))?.hide();
    loadRequests(); loadStats();
    showToast('✓ Receipt approved — forwarded to Staff','success');
  } else alert(d.message||'Error');
}

// ── toast ─────────────────────────────────────────────────
function showToast(msg, type='success') {
  const bg = {success:'#059669',warning:'#f59e0b',danger:'#ef4444'}[type]||'#1d4ed8';
  const t  = document.createElement('div');
  t.className = 'tp-toast';
  t.style.background = bg; t.style.color = '#fff';
  t.innerHTML = msg;
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 3200);
}

// ── path steps config ─────────────────────────────────────
const STEPS = [
  { key:'PendingDispatcher',       label:'Submit',    actor:'You'       },
  { key:'DriverAssigned',          label:'Dispatch',  actor:'Dispatcher'},
  { key:'DriverAccepted',          label:'Accept',    actor:'Driver'    },
  { key:'PickedUp',                label:'Pickup',    actor:'Driver'    },
  { key:'MahberatApprovedPickup',  label:'OK Pickup', actor:'You'       },
  { key:'ReceiptSubmitted',        label:'Receipt',   actor:'Driver'    },
  { key:'MahberatVerified',        label:'Verified',  actor:'You'       },
  { key:'StaffApproved',           label:'Approved',  actor:'Staff'     },
  { key:'Paid',                    label:'Paid',      actor:'Finance'   },
];
const REJECTED = ['DispatcherRejected','DriverRejected','StaffRejected'];

// ── init ──────────────────────────────────────────────────
loadStats();
loadRequests();
setInterval(()=>{ loadStats(); loadRequests(); }, 30000);
</script>
