// ── submit new request ────────────────────────────────────
async function submitRequest() {
  const pickup = document.getElementById('pickup').value.trim();
  const dest   = document.getElementById('destination').value.trim();
  const date   = document.getElementById('reqDate').value;
  if (!pickup||!dest||!date){ alert('Please fill in Pickup, Destination and Date.'); return; }
  const r = await fetch(`${API}/requests`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({
      userId, userName,
      pickupLocation: pickup, destination: dest,
      passengerItemDetails: document.getElementById('details').value,
      requestedDate: date, requestedTime: document.getElementById('reqTime').value,
      specialInstructions: document.getElementById('instructions').value
    })
  });
  const d = await r.json();
  if (d.success) {
    bootstrap.Modal.getInstance(document.getElementById('newRequestModal')).hide();
    loadRequests(); loadStats();
    showToast(`✓ Request ${d.requestNumber} submitted!`,'success');
  } else alert(d.message||'Error submitting request');
}

// ── pickup ────────────────────────────────────────────────
function openPickup(id, num) {
  document.getElementById('pickupRequestId').value = id;
  document.getElementById('pickupDesc').textContent = `Confirm driver has arrived and picked up for trip ${num}?`;
  document.getElementById('pickupNotes').value = '';
  new bootstrap.Modal(document.getElementById('pickupModal')).show();
}
async function pickupAction(action) {
  const id = document.getElementById('pickupRequestId').value;
  const r = await fetch(`${API}/requests/${id}/mahberat-pickup`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ userId, userName, action, notes: document.getElementById('pickupNotes').value })
  });
  const d = await r.json();
  if (d.success) { bootstrap.Modal.getInstance(document.getElementById('pickupModal')).hide(); loadRequests(); loadStats(); showToast('Pickup updated','success'); }
  else alert(d.message||'Error');
}

// ── receipt ───────────────────────────────────────────────
async function openReceipt(id) {
  document.getElementById('receiptRequestId').value = id;
  document.getElementById('receiptNotes').value = '';
  document.getElementById('receiptTripInfo').innerHTML = '<div class="col-12 text-center py-2"><div class="spinner-border spinner-border-sm"></div></div>';
  document.getElementById('receiptKgTotal').innerHTML = '';
  document.getElementById('receiptPhotoContainer').innerHTML = '';
  document.getElementById('receiptDriverNotes').innerHTML = '';
  new bootstrap.Modal(document.getElementById('receiptModal')).show();
  try {
    const r   = await fetch(`${API}/requests/${id}`);
    const d   = await r.json();
    const req = d.request ?? d;
    // resolve best available mahberat name
    const mahberatName = req.receipt_mahberat_name ?? req.mahberat_name ?? req.mahberat_user_name ?? '—';
    const weredaName   = req.receipt_wereda_name   ?? '—';
    document.getElementById('receiptTripInfo').innerHTML = `
      <div class="col-md-6"><small class="text-muted d-block">Request #</small><strong>${req.request_number??'—'}</strong></div>
      <div class="col-md-6"><small class="text-muted d-block">Driver</small><strong>${req.driver_name??'—'}</strong> ${req.vehicle_plate?`<span class="badge bg-secondary">${req.vehicle_plate}</span>`:''}</div>
      <div class="col-md-6"><small class="text-muted d-block">Route</small>${req.pickup_location??'—'} → ${req.destination??'—'}</div>
      <div class="col-md-6"><small class="text-muted d-block">Mahberat</small><strong class="text-success">${mahberatName}</strong></div>`;
    const kg   = parseFloat(req.actual_kilogram??0);
    const cost = parseFloat(req.transport_cost??0);
    document.getElementById('receiptKgTotal').innerHTML = `
      <div class="col-md-4"><div class="border rounded-3 p-3 text-center bg-white"><div class="text-muted small">Actual KG</div><div class="fs-3 fw-bold text-primary">${kg>0?kg.toFixed(1):'—'}</div></div></div>
      <div class="col-md-4"><div class="border rounded-3 p-3 text-center bg-white"><div class="text-muted small">Mahberat Name</div><div class="fw-bold text-success">${mahberatName}</div><div class="text-muted" style="font-size:.7rem">${weredaName}</div></div></div>
      <div class="col-md-4"><div class="border rounded-3 p-3 text-center" style="background:linear-gradient(135deg,#d1e7dd,#a3cfbb)"><div class="text-muted small">Transport Cost</div><div class="fs-4 fw-bold text-success">${cost>0?'ETB '+cost.toFixed(2):'Set by Staff'}</div></div></div>`;
    if (req.receipt_photo_url) {
      const photos = req.receipt_photo_url.split(',').map(p=>p.trim()).filter(p=>p);
      document.getElementById('receiptPhotoContainer').innerHTML = `
        <label class="form-label fw-semibold text-muted small text-uppercase">Receipt Photo(s)</label>
        <div class="d-flex flex-wrap gap-2">${photos.map(p=>`<a href="${p}" target="_blank"><img src="${p}" class="rounded border shadow-sm" style="width:90px;height:90px;object-fit:cover" onerror="this.style.display='none'"/></a>`).join('')}</div>`;
    } else {
      document.getElementById('receiptPhotoContainer').innerHTML = '<div class="alert alert-warning py-2"><i class="bi bi-exclamation-triangle me-2"></i>No receipt photo uploaded.</div>';
    }
    if (req.receipt_notes) document.getElementById('receiptDriverNotes').innerHTML = `<div class="alert alert-light border py-2"><small class="text-muted d-block"><i class="bi bi-chat-left-quote me-1"></i>Driver Notes</small>${req.receipt_notes}</div>`;
  } catch(err) {
    document.getElementById('receiptTripInfo').innerHTML = `<div class="col-12"><div class="alert alert-danger">Error: ${err.message}</div></div>`;
  }
}
async function receiptAction(action) {
  const id    = document.getElementById('receiptRequestId').value;
  const notes = document.getElementById('receiptNotes').value;
  if (action==='RequestCorrection'&&!notes.trim()) { alert('Please provide correction notes.'); return; }
  const r = await fetch(`${API}/requests/${id}/mahberat-verify`, {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ userId, userName, action, notes })
  });
  const d = await r.json();
  if (d.success) {
    bootstrap.Modal.getInstance(document.getElementById('receiptModal')).hide();
    loadRequests(); loadStats();
    showToast(action==='Verify'?'✓ Receipt approved — forwarded to Staff':'⚠ Correction requested', action==='Verify'?'success':'warning');
  } else alert(d.message||'Error');
}

